@page "/admin/products"
@inject IAdminCatalogClient AdminCatalog
@inject ISnackbar Snackbar
@inject IStringLocalizer<AppStrings> L

<PageTitle>@L["Admin.Products.PageTitle"]</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="py-8">
    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-6">
        <MudStack Spacing="0">
            <MudText Typo="Typo.h4" Style="font-weight: 700;">@L["Admin.Products.Title"]</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">@L["Admin.Products.Subtitle"]</MudText>
        </MudStack>
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Outlined.Add"
                   Href="/admin/products/new"
                   Style="border-radius:100px;">
            @L["Admin.Products.New"]
        </MudButton>
    </MudStack>

    @if (_loading)
    {
        <MudStack AlignItems="AlignItems.Center" Class="py-12">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
        </MudStack>
    }
    else if (_products.Count == 0)
    {
        <MudPaper Elevation="0" Class="pa-12 text-center" Style="border-radius:16px;border:1px solid var(--mud-palette-divider);">
            <MudIcon Icon="@Icons.Material.Outlined.Inventory2" Color="Color.Secondary" Style="font-size:64px;" Class="mb-3" />
            <MudText Typo="Typo.h6">@L["Admin.Products.None"]</MudText>
        </MudPaper>
    }
    else
    {
        <MudPaper Elevation="0" Style="border-radius:16px;border:1px solid var(--mud-palette-divider);overflow:hidden;">
            <MudTable Items="_products" Hover="true" Dense="false">
                <HeaderContent>
                    <MudTh>@L["Admin.Products.ColSKU"]</MudTh>
                    <MudTh>@L["Admin.Products.ColName"]</MudTh>
                    <MudTh>@L["Admin.Products.ColCategory"]</MudTh>
                    <MudTh Style="text-align:right;">@L["Admin.Products.ColPrice"]</MudTh>
                    <MudTh Style="text-align:right;">@L["Admin.Products.ColStock"]</MudTh>
                    <MudTh>@L["Admin.Products.ColStatus"]</MudTh>
                    <MudTh Style="text-align:right;">@L["Admin.Products.ColAction"]</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="@L["Admin.Products.ColSKU"]">
                        <MudText Typo="Typo.body2" Class="os-mono">@context.SKU</MudText>
                    </MudTd>
                    <MudTd DataLabel="@L["Admin.Products.ColName"]">
                        <MudText Typo="Typo.body2" Style="font-weight:500;">@context.Name</MudText>
                    </MudTd>
                    <MudTd DataLabel="@L["Admin.Products.ColCategory"]">
                        <MudText Typo="Typo.body2">@context.CategoryName</MudText>
                    </MudTd>
                    <MudTd DataLabel="@L["Admin.Products.ColPrice"]" Style="text-align:right;">
                        <MudText Typo="Typo.body2" Style="font-weight:600;">
                            @Formatting.Currency(context.Price)
                        </MudText>
                    </MudTd>
                    <MudTd DataLabel="@L["Admin.Products.ColStock"]" Style="text-align:right;">
                        <MudText Typo="Typo.body2"
                                 Style="@(context.Stock < 10 ? "color:var(--mud-palette-warning);font-weight:600;" : "")">
                            @context.Stock
                        </MudText>
                    </MudTd>
                    <MudTd DataLabel="@L["Admin.Products.ColStatus"]">
                        <MudChip T="string"
                                 Color="@(context.IsActive ? Color.Success : Color.Default)"
                                 Size="Size.Small" Variant="Variant.Filled"
                                 Style="border-radius:100px;">
                            @(context.IsActive ? L["Common.Active"] : L["Common.Inactive"])
                        </MudChip>
                    </MudTd>
                    <MudTd DataLabel="@L["Admin.Products.ColAction"]" Style="text-align:right;">
                        <MudIconButton Icon="@Icons.Material.Outlined.Edit"
                                       Color="Color.Primary" Size="Size.Small"
                                       Href="@($"/admin/products/{context.Id}")" />
                        <MudIconButton Icon="@Icons.Material.Outlined.Delete"
                                       Color="Color.Error" Size="Size.Small"
                                       OnClick="@(() => DeleteAsync(context.Id, context.Name))" />
                    </MudTd>
                </RowTemplate>
            </MudTable>
        </MudPaper>
    }
<MudMessageBox @ref="_msgBox" Title="@L["Admin.Products.DeleteTitle"]" CancelText="@L["Common.Cancel"]">
    <MessageContent>@L["Admin.Products.DeleteConfirm", _pendingDeleteName]</MessageContent>
    <YesButton>
        <MudButton Variant="Variant.Filled" Color="Color.Error">@L["Common.Delete"]</MudButton>
    </YesButton>
</MudMessageBox>

</MudContainer>

@code {
    private List<AdminProductDto> _products = [];
    private bool _loading = true;
    private MudMessageBox? _msgBox;
    private string _pendingDeleteName = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        try { var r = await AdminCatalog.GetProductsAsync(); if (r.IsSuccess) _products = r.Value!; else Snackbar.Add(r.Error!.Message, Severity.Error); }
        catch (Exception ex) { Snackbar.Add(L["Common.Error", ex.Message], Severity.Error); }
        finally { _loading = false; }
    }

    private async Task DeleteAsync(Guid id, string name)
    {
        _pendingDeleteName = name;
        var confirmed = await _msgBox!.ShowAsync();
        if (confirmed != true) return;

        var result = await AdminCatalog.DeleteProductAsync(id);
        if (result.IsSuccess) { _products.RemoveAll(p => p.Id == id); Snackbar.Add(L["Admin.Products.Deleted"], Severity.Success); }
        else Snackbar.Add(result.Error!.Message, Severity.Error);
    }
}

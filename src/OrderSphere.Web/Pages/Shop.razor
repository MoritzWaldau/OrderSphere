@page "/shop"
@page "/shop/category/{Category}"
@attribute [Authorize]
@inject ICatalogClient Catalog
@inject IOrderingClient Ordering
@inject CartState CartState
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<PageTitle>Produkte – OrderSphere</PageTitle>

<PageHero Eyebrow="Alle Produkte" Title="Unsere Auswahl"
          Subtitle="Sorgfältig kuratierte Tech-Geräte und Zubehör." />

<section style="padding:48px 0 80px;">
    <MudContainer MaxWidth="MaxWidth.Large">
        @if (_loading)
        {
            <MudStack AlignItems="AlignItems.Center" Style="min-height:40vh;justify-content:center;">
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
            </MudStack>
        }
        else if (!_products.Any())
        {
            <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Style="min-height:40vh;padding:64px 0;">
                <MudIcon Icon="@Icons.Material.Outlined.Inventory2"
                         Style="font-size:64px;color:var(--mud-palette-divider);" />
                <MudText Typo="Typo.h5" Style="margin-top:20px;font-weight:600;">Keine Produkte vorhanden</MudText>
                <MudText Typo="Typo.body2" Class="text-muted" Style="margin-top:4px;">Schau später nochmal vorbei.</MudText>
            </MudStack>
        }
        else
        {
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:32px;">
                <MudText Typo="Typo.body2" Class="text-muted">
                    <span class="os-mono">@_products.Count</span> Produkte
                </MudText>
            </div>

            <MudGrid Spacing="3">
                @foreach (var product in _products)
                {
                    <MudItem xs="12" sm="6" md="4">
                        <ProductCard Product="product"
                                     ShowCategory="true"
                                     OnOpen="OpenDetails"
                                     OnAdd="OpenQuantityPopup" />
                    </MudItem>
                }
            </MudGrid>

            <!-- Quantity dialog -->
            <MudDialog @bind-Visible="_popupOpen">
                <TitleContent>
                    <MudText Typo="Typo.h6">@_selectedProduct?.Name</MudText>
                </TitleContent>
                <DialogContent>
                    <MudText Typo="Typo.body2" Class="mb-4">Anzahl wählen (max. @(_selectedProduct?.Stock ?? 1)):</MudText>
                    <MudNumericField T="int" @bind-Value="_quantity"
                                     Min="1" Max="@(_selectedProduct?.Stock ?? 1)"
                                     Label="Menge" Variant="Variant.Outlined" />
                </DialogContent>
                <DialogActions>
                    <MudButton OnClick="ClosePopup">Abbrechen</MudButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               OnClick="ConfirmAddToCartAsync" Disabled="_addingToCart">
                        @if (_addingToCart)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                        }
                        In den Warenkorb
                    </MudButton>
                </DialogActions>
            </MudDialog>
        }
    </MudContainer>
</section>

@code {
    [Parameter] public string? Category { get; set; }

    private List<ProductDto> _products = [];
    private bool _loading = true;
    private bool _popupOpen;
    private bool _addingToCart;
    private ProductDto? _selectedProduct;
    private int _quantity = 1;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var all = await Catalog.GetProductsAsync();
            _products = all.Items.Where(p => p.IsActive).ToList();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Fehler beim Laden: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private void OpenDetails(ProductDto product)
        => Navigation.NavigateTo($"/shop/{Uri.EscapeDataString(product.CategoryName)}/{Uri.EscapeDataString(product.Slug)}");

    private void OpenQuantityPopup(ProductDto product)
    {
        _selectedProduct = product;
        _quantity = 1;
        _popupOpen = true;
    }

    private void ClosePopup()
    {
        _popupOpen = false;
        _selectedProduct = null;
    }

    private async Task ConfirmAddToCartAsync()
    {
        if (_selectedProduct is null) return;

        _addingToCart = true;
        try
        {
            var ok = await Ordering.AddToCartAsync(_selectedProduct.Id, _quantity);
            if (ok)
            {
                Snackbar.Add($"{_quantity}× {_selectedProduct.Name} wurde hinzugefügt.", Severity.Success);
                await CartState.RefreshAsync();
                ClosePopup();
            }
            else
            {
                Snackbar.Add("Fehler beim Hinzufügen zum Warenkorb.", Severity.Error);
            }
        }
        finally
        {
            _addingToCart = false;
        }
    }
}

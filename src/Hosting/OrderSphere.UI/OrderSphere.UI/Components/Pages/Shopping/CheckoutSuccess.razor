@page "/checkout/success"
@layout MainLayout
@using Microsoft.AspNetCore.Authorization
@using MediatR
@using OrderSphere.Application.Features.Order.GetOrderByCorrelationId
@using OrderSphere.Application.Models
@using OrderSphere.UI.Services.Auth

@inject ISender Sender
@inject ICurrentUserService CurrentUserService
@inject NavigationManager Navigation

@attribute [Authorize]
@rendermode InteractiveServer

<PageTitle>Bestellung bestätigt — OrderSphere</PageTitle>

<section style="padding: 80px 0 48px; background: var(--mud-palette-background);">
    <MudContainer MaxWidth="MaxWidth.Small">
        <MudStack AlignItems="AlignItems.Center" Spacing="4" Style="text-align: center;">
            <div style="width: 72px; height: 72px; border-radius: 50%; background: var(--mud-palette-success); display: flex; align-items: center; justify-content: center;">
                <MudIcon Icon="@Icons.Material.Outlined.Check"
                         Style="font-size: 36px; color: #ffffff;" />
            </div>

            <div>
                <span class="os-eyebrow">Bestellung bestätigt</span>
                <MudText Typo="Typo.h2" Style="margin-top: 12px; letter-spacing: -0.025em; line-height: 1.1;">
                    Vielen Dank!
                </MudText>
            </div>

            @if (_order is not null)
            {
                <div style="display: inline-block; background: var(--mud-palette-background-grey); border: 1px solid var(--mud-palette-divider); border-radius: 100px; padding: 8px 20px;">
                    <span class="os-mono" style="font-size: 0.875rem; font-weight: 600; color: var(--mud-palette-text-primary);">
                        #@_order.Id.ToString("N")[..8].ToUpperInvariant()
                    </span>
                </div>
            }
            else if (_pollingTimedOut)
            {
                <MudText Typo="Typo.body2" Class="text-muted">
                    Deine Bestellung wird noch verarbeitet.
                </MudText>
            }
            else
            {
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Justify="Justify.Center">
                    <MudProgressCircular Color="Color.Primary" Size="Size.Small" Indeterminate="true" />
                    <MudText Typo="Typo.body2" Class="text-muted">
                        Bestellung wird verarbeitet…
                    </MudText>
                </MudStack>
            }

            <MudText Typo="Typo.body1" Class="text-muted" Style="max-width: 480px; line-height: 1.7;">
                Eine Bestätigung mit allen Details haben wir an deine E-Mail-Adresse gesendet.
            </MudText>
        </MudStack>
    </MudContainer>
</section>

<section style="padding: 0 0 80px;">
    <MudContainer MaxWidth="MaxWidth.Small">
        <MudPaper Elevation="0" Class="surface-card-lg pa-8">

            @if (_order is not null && !string.IsNullOrWhiteSpace(_order.TrackingNumber))
            {
                <MudStack Spacing="2" AlignItems="AlignItems.Center" Class="mb-6">
                    <MudText Typo="Typo.caption" Class="text-muted">
                        Deine Tracking-Nummer
                    </MudText>
                    <MudText Typo="Typo.h4" Class="text-tracking" Style="font-weight: 700;">
                        @_order.TrackingNumber
                    </MudText>
                </MudStack>

                <MudDivider Class="mb-6" />
            }

            <MudText Typo="Typo.h5" Class="mb-6" Style="font-weight: 600;">
                So geht's weiter
            </MudText>

            <MudStack Spacing="5">
                <MudStack Row="true" Spacing="4" AlignItems="AlignItems.Start">
                    <MudIcon Icon="@Icons.Material.Outlined.MarkEmailRead"
                             Color="Color.Primary" Style="font-size: 32px;" />
                    <MudStack Spacing="1">
                        <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">
                            Bestätigung per E-Mail
                        </MudText>
                        <MudText Typo="Typo.body2" Class="text-muted">
                            Du erhältst gleich eine E-Mail mit der Bestellübersicht und deiner Rechnung.
                        </MudText>
                    </MudStack>
                </MudStack>

                <MudStack Row="true" Spacing="4" AlignItems="AlignItems.Start">
                    <MudIcon Icon="@Icons.Material.Outlined.Inventory2"
                             Color="Color.Primary" Style="font-size: 32px;" />
                    <MudStack Spacing="1">
                        <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">
                            Verpackung &amp; Versand
                        </MudText>
                        <MudText Typo="Typo.body2" Class="text-muted">
                            Wir verpacken deine Bestellung sorgfältig und übergeben sie an unseren Versandpartner.
                        </MudText>
                    </MudStack>
                </MudStack>

                <MudStack Row="true" Spacing="4" AlignItems="AlignItems.Start">
                    <MudIcon Icon="@Icons.Material.Outlined.LocalShipping"
                             Color="Color.Primary" Style="font-size: 32px;" />
                    <MudStack Spacing="1">
                        <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">
                            Lieferung
                        </MudText>
                        <MudText Typo="Typo.body2" Class="text-muted">
                            Mit dem Versand schicken wir dir einen Tracking-Link, damit du deine Sendung verfolgen kannst.
                        </MudText>
                    </MudStack>
                </MudStack>
            </MudStack>

            @if (!string.IsNullOrWhiteSpace(Total))
            {
                <MudDivider Class="my-6" />
                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Baseline">
                    <MudText Typo="Typo.body2" Class="text-muted">Gesamtbetrag</MudText>
                    <span class="os-mono" style="font-size: 1.125rem; font-weight: 700; color: var(--mud-palette-text-primary);">
                        @FormattedTotal
                    </span>
                </MudStack>
            }

            <MudStack Row="true" Spacing="3" Wrap="Wrap.Wrap" Justify="Justify.Center" Class="mt-8">
                @if (_order is not null)
                {
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               Size="Size.Large"
                               Href="@($"/account/orders/{_order.Id}")"
                               StartIcon="@Icons.Material.Outlined.Receipt"
                               Class="btn-pill">
                        Bestelldetails ansehen
                    </MudButton>
                }
                else
                {
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               Size="Size.Large"
                               Href="/account/orders"
                               StartIcon="@Icons.Material.Outlined.ShoppingBag"
                               Class="btn-pill">
                        Meine Bestellungen
                    </MudButton>
                }
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Primary"
                           Size="Size.Large"
                           Href="/shop"
                           Class="btn-pill">
                    Weiter einkaufen
                </MudButton>
            </MudStack>
        </MudPaper>
    </MudContainer>
</section>

@code {
    [SupplyParameterFromQuery(Name = "correlationId")]
    public Guid? CorrelationId { get; set; }

    [SupplyParameterFromQuery(Name = "total")]
    public string? Total { get; set; }

    private OrderDto? _order;
    private bool _pollingTimedOut;

    private string FormattedTotal =>
        decimal.TryParse(Total, System.Globalization.NumberStyles.Number, System.Globalization.CultureInfo.InvariantCulture, out var value)
            ? value.ToString("0.00", System.Globalization.CultureInfo.GetCultureInfo("de-DE")) + " €"
            : "—";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        if (CorrelationId is null || CorrelationId == Guid.Empty)
        {
            _pollingTimedOut = true;
            StateHasChanged();
            return;
        }

        var customerId = await CurrentUserService.GetCustomerIdAsync();
        if (customerId is null)
        {
            _pollingTimedOut = true;
            StateHasChanged();
            return;
        }

        const int maxAttempts = 10;
        const int delayMs = 500;

        for (int attempt = 0; attempt < maxAttempts; attempt++)
        {
            var result = await Sender.Send(
                new GetOrderByCorrelationIdQuery(CorrelationId.Value, customerId.Value));

            if (result.IsSuccess && result.Value is not null)
            {
                _order = result.Value;
                StateHasChanged();
                return;
            }

            await Task.Delay(delayMs);
        }

        _pollingTimedOut = true;
        StateHasChanged();
    }
}

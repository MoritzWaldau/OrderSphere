<footer>
    <div class="footer-main">
        <MudContainer>
            <MudGrid>
                <MudItem xs="12" md="4">
                    <MudLink Href="/" Underline="Underline.None">
                        <MudText Typo="Typo.h6" Style="font-weight: 700;">OrderSphere</MudText>
                    </MudLink>
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-3" Style="max-width: 280px; line-height: 1.6;">
                        Dein Shop für moderne IT-Geräte. Schnell, zuverlässig und smart.
                    </MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-2">📧 support@ordersphere.dev</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-1">🤖 AI Assistant verfügbar</MudText>
                </MudItem>

                @foreach (var section in _sections)
                {
                    <MudItem xs="6" md="2">
                        <MudText Typo="Typo.overline" Style="font-weight: 700;">@(section.Title)</MudText>
                        <MudStack Spacing="2" Class="mt-3">
                            @foreach (var link in section.Links)
                            {
                                <a href="@link.Href" class="footer-link">@link.Label</a>
                            }
                        </MudStack>
                    </MudItem>
                }
            </MudGrid>
        </MudContainer>
    </div>

    <div class="footer-bottom">
        <MudContainer>
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                <MudText Typo="Typo.caption" Style="color: #98989D;">
                    © @DateTime.Now.Year OrderSphere — Alle Rechte vorbehalten
                </MudText>
                <MudStack Row="true" Spacing="3">
                    <a href="/imprint" class="footer-bottom-link">Impressum</a>
                    <a href="/privacy" class="footer-bottom-link">Datenschutz</a>
                    <a href="/cookies" class="footer-bottom-link">Cookies</a>
                </MudStack>
            </MudStack>
        </MudContainer>
    </div>
</footer>

@code {
    private readonly List<FooterSection> _sections =
    [
        new("Shop", [
            new("Startseite", "/"),
            new("Produkte", "/products"),
            new("Angebote", "/offers"),
            new("Deals", "/deals"),
        ]),
        new("Kategorien", [
            new("Laptops", "/categories/laptops"),
            new("Smartphones", "/categories/smartphones"),
            new("Tablets", "/categories/tablets"),
            new("Zubehör", "/categories/accessories"),
        ]),
        new("Rechtliches", [
            new("Impressum", "/imprint"),
            new("Datenschutz", "/privacy"),
            new("Cookies", "/cookies"),
            new("AGB", "/terms"),
        ]),
        new("Support", [
            new("AI Assistant", "/assistant"),
            new("Kontakt", "/contact"),
            new("FAQ", "/faq"),
            new("Rückgabe", "/returns"),
        ]),
    ];

    private record FooterLink(string Label, string Href);
    private record FooterSection(string Title, List<FooterLink> Links);
}
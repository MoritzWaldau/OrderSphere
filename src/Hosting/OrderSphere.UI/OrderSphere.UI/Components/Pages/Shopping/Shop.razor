@page "/shop"
@page "/shop/category/{category}"
@attribute [Authorize]
@rendermode InteractiveServer

@using Microsoft.AspNetCore.Authorization
@using OrderSphere.UI.Components.Component.Loading
@inherits OrderSphereComponentBase

<PageTitle>Produkte – OrderSphere</PageTitle>

<PageHero Variant="PageHero.PageHeroVariant.Compact"
          Eyebrow="Alle Produkte"
          Title="Unsere Auswahl"
          Subtitle="Sorgfältig kuratierte Tech-Geräte und Zubehör." />

<section style="padding: 48px 0 80px;">
    <MudContainer MaxWidth="MaxWidth.Large">
        <LoadingWrapper IsLoading="IsLoading">

            <Loading>
                <ProductsSkeleton />
            </Loading>

            <ChildContent>
                @if (!_products.Any())
                {
                    <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Style="min-height: 40vh; padding: 64px 0;">
                        <MudIcon Icon="@Icons.Material.Outlined.Inventory2"
                                 Style="font-size: 64px; color: var(--mud-palette-divider);" />
                        <MudText Typo="Typo.h5" Style="margin-top: 20px; font-weight: 600;">Keine Produkte vorhanden</MudText>
                        <MudText Typo="Typo.body2" Class="text-muted" Style="margin-top: 4px;">
                            Schau später nochmal vorbei.
                        </MudText>
                    </MudStack>
                }
                else
                {
                    <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 32px;">
                        <MudText Typo="Typo.body2" Class="text-muted">
                            <span class="os-mono">@_products.Count()</span> Produkte
                        </MudText>
                    </div>

                    <MudGrid Spacing="3">
                        @foreach (var product in _products)
                        {
                            <MudItem xs="12" sm="6" md="4">
                                <ProductCard Product="product"
                                             ShowCategory="true"
                                             OnOpen="OpenDetails"
                                             OnAdd="OpenQuantityPopup" />
                            </MudItem>
                        }
                    </MudGrid>

                    <QuantityPopup IsOpen="_popupOpen"
                                   MaxQuantity="@(_selectedProduct?.Stock ?? 1)"
                                   OnCancel="ClosePopup"
                                   OnConfirm="ConfirmAddToCartAsync" />
                }
            </ChildContent>

        </LoadingWrapper>
    </MudContainer>
</section>

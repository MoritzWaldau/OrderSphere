@page "/categories"
@attribute [Authorize]
@inject ICatalogClient Catalog
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject IStringLocalizer<AppStrings> L

<PageTitle>@L["Categories.PageTitle"]</PageTitle>

<PageHero Eyebrow="@L["Categories.HeroEyebrow"]" Title="@L["Nav.Categories"]"
          Subtitle="@L["Categories.HeroSubtitle"]" />

<section style="padding: 48px 0 80px;">
    <MudContainer MaxWidth="MaxWidth.Large">
        @if (_loading)
        {
            <MudStack AlignItems="AlignItems.Center" Style="min-height:40vh;justify-content:center;">
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
            </MudStack>
        }
        else if (_categories.Count == 0)
        {
            <MudPaper Elevation="0" Class="surface-card-lg pa-12 text-center">
                <MudIcon Icon="@Icons.Material.Outlined.Category"
                         Color="Color.Primary"
                         Style="font-size: 80px;" Class="mb-4" />
                <MudText Typo="Typo.h5" Style="font-weight: 600;">
                    @L["Categories.None"]
                </MudText>
            </MudPaper>
        }
        else
        {
            <MudGrid Spacing="4">
                @foreach (var category in _categories)
                {
                    <MudItem xs="12" sm="6" md="4">
                        <MudPaper Elevation="0"
                                  Class="surface-card pa-6"
                                  Style="height: 100%; cursor: pointer;"
                                  @onclick="@(() => Navigation.NavigateTo($"/shop/category/{Uri.EscapeDataString(category.Name)}"))">
                            <MudStack Spacing="3">
                                <MudIcon Icon="@GetCategoryIcon(category.Name)"
                                         Color="Color.Primary"
                                         Style="font-size: 56px;" />
                                <MudText Typo="Typo.h5" Style="font-weight: 600;">
                                    @category.Name
                                </MudText>
                                @if (!string.IsNullOrWhiteSpace(category.Description))
                                {
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                                        @category.Description
                                    </MudText>
                                }
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mt-2">
                                    <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Filled"
                                             Style="border-radius: 100px;">
                                        @category.ProductCount @(category.ProductCount == 1 ? L["Categories.ProductSingular"] : L["Categories.ProductPlural"])
                                    </MudChip>
                                </MudStack>
                            </MudStack>
                        </MudPaper>
                    </MudItem>
                }
            </MudGrid>
        }
    </MudContainer>
</section>

@code {
    private List<CategoryDto> _categories = [];
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var res = await Catalog.GetCategoriesAsync();
            if (res.IsSuccess)
                _categories = res.Value!.Items.ToList();
            else
                Snackbar.Add(res.Error!.Message, Severity.Error);
        }
        catch (Exception ex)
        {
            Snackbar.Add(L["Categories.LoadError", ex.Message], Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private static string GetCategoryIcon(string name) => name.ToLowerInvariant() switch
    {
        var n when n.Contains("laptop") => Icons.Material.Outlined.Laptop,
        var n when n.Contains("phone") || n.Contains("smartphone") => Icons.Material.Outlined.PhoneIphone,
        var n when n.Contains("tablet") => Icons.Material.Outlined.Tablet,
        var n when n.Contains("zubehör") || n.Contains("accessor") => Icons.Material.Outlined.Headphones,
        var n when n.Contains("audio") => Icons.Material.Outlined.Speaker,
        var n when n.Contains("monitor") || n.Contains("display") => Icons.Material.Outlined.Monitor,
        var n when n.Contains("kamera") || n.Contains("camera") => Icons.Material.Outlined.PhotoCamera,
        _ => Icons.Material.Outlined.Devices
    };
}

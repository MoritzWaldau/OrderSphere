@inherits LayoutComponentBase
@using OrderSphere.UI.Configuration
@using OrderSphere.UI.Services
@inject IThemeService ThemeService
@inject IJSRuntime JS
@implements IDisposable

<MudThemeProvider Theme="ThemeConfiguration.ApplicationTheme()" IsDarkMode="ThemeService.IsDarkMode" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>

    <MudAppBar Elevation="0"
               Color="Color.Surface"
               Style="border-bottom: 1px solid var(--mud-palette-divider);">
        <MudIconButton Icon="@Icons.Material.Outlined.Menu"
                       Color="Color.Default"
                       OnClick="@ToggleDrawer"
                       aria-label="Navigation umschalten"
                       Class="mr-2" />
        <MudText Typo="Typo.h6" Style="font-weight: 600;">
            OrderSphere Admin
        </MudText>
        <MudSpacer />

        <MudTooltip Text="@(ThemeService.IsDarkMode ? "Helles Design" : "Dunkles Design")">
            <MudIconButton Icon="@(ThemeService.IsDarkMode ? Icons.Material.Outlined.LightMode : Icons.Material.Outlined.DarkMode)"
                           Color="Color.Default"
                           Class="theme-toggle mr-2"
                           aria-label="Design umschalten"
                           OnClick="ToggleThemeAsync" />
        </MudTooltip>

        <MudButton Variant="Variant.Text"
                   StartIcon="@Icons.Material.Outlined.Storefront"
                   Color="Color.Default"
                   Href="/">
            Zum Shop
        </MudButton>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen"
               Elevation="0"
               Variant="DrawerVariant.Mini"
               OpenMiniOnHover="true"
               Style="border-right: 1px solid var(--mud-palette-divider);">

        <MudNavMenu Class="mt-4">
            <MudNavLink Href="/admin"
                        Match="NavLinkMatch.All"
                        Icon="@Icons.Material.Outlined.Dashboard">
                Dashboard
            </MudNavLink>
            <MudNavLink Href="/admin/orders"
                        Icon="@Icons.Material.Outlined.Receipt">
                Bestellungen
            </MudNavLink>
            <MudNavLink Href="/admin/products"
                        Icon="@Icons.Material.Outlined.Inventory2">
                Produkte
            </MudNavLink>
            <MudNavLink Href="/admin/categories"
                        Icon="@Icons.Material.Outlined.Category">
                Kategorien
            </MudNavLink>
            <MudNavLink Href="/admin/users"
                        Icon="@Icons.Material.Outlined.People">
                Benutzer
            </MudNavLink>
        </MudNavMenu>
    </MudDrawer>

    <MudMainContent Style="background: var(--mud-palette-background-grey); min-height: 100vh;">
        @Body
    </MudMainContent>

</MudLayout>

@code {
    private bool _drawerOpen = true;
    private bool _initialized;

    protected override void OnInitialized()
    {
        ThemeService.OnChange += OnThemeChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_initialized)
        {
            _initialized = true;
            bool? prefersDark = null;
            try
            {
                prefersDark = await JS.InvokeAsync<bool>("prefersDarkScheme");
            }
            catch
            {
                // Ignore JS unavailable.
            }
            await ThemeService.InitializeAsync(prefersDark);
        }
    }

    private void OnThemeChanged() => InvokeAsync(StateHasChanged);

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;

    private Task ToggleThemeAsync() => ThemeService.ToggleAsync();

    public void Dispose()
    {
        ThemeService.OnChange -= OnThemeChanged;
    }
}

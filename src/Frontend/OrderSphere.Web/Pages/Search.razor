@page "/search"
@attribute [Authorize]
@inject ICatalogClient Catalog
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject IStringLocalizer<AppStrings> L

<PageTitle>@L["Search.PageTitle"]</PageTitle>

<PageHero Eyebrow="@L["Search.HeroEyebrow"]" Title="@L["Search.HeroTitle"]"
          Subtitle="@L["Search.HeroSubtitle"]">
    <LeadingContent>
        <MudPaper Elevation="0" Class="pa-2 mx-auto"
                  Style="max-width: 600px; border-radius: 100px; background: var(--mud-palette-surface);">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="0" Class="px-4">
                <MudIcon Icon="@Icons.Material.Outlined.Search" Color="Color.Default" />
                <MudTextField T="string"
                              @bind-Value="_queryInput"
                              Placeholder="@L["Search.Placeholder"]"
                              Variant="Variant.Text"
                              Underline="false"
                              FullWidth="true"
                              Class="mx-3"
                              OnKeyDown="OnSearchKeyDown" />
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           OnClick="ApplySearch"
                           Style="border-radius: 100px;">
                    @L["Search.Button"]
                </MudButton>
            </MudStack>
        </MudPaper>
    </LeadingContent>
</PageHero>

<section style="padding: 48px 0 80px; min-height: 50vh;">
    <MudContainer MaxWidth="MaxWidth.Large">
        @if (_loading)
        {
            <MudStack AlignItems="AlignItems.Center" Style="min-height:40vh;justify-content:center;">
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
            </MudStack>
        }
        else if (string.IsNullOrWhiteSpace(Query))
        {
            <MudPaper Elevation="0" Class="surface-card-lg pa-12 text-center">
                <MudIcon Icon="@Icons.Material.Outlined.Search"
                         Color="Color.Primary"
                         Style="font-size: 80px;" Class="mb-4" />
                <MudText Typo="Typo.h5" Style="font-weight: 600;">
                    @L["Search.Prompt"]
                </MudText>
                <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mt-2">
                    @L["Search.PromptHint"]
                </MudText>
            </MudPaper>
        }
        else if (_results.Count == 0)
        {
            <MudPaper Elevation="0" Class="surface-card-lg pa-12 text-center">
                <MudIcon Icon="@Icons.Material.Outlined.SearchOff"
                         Color="Color.Primary"
                         Style="font-size: 80px;" Class="mb-4" />
                <MudText Typo="Typo.h5" Style="font-weight: 600;">
                    @L["Search.NoResults", Query!]
                </MudText>
                <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mt-2 mb-6">
                    @L["Search.NoResultsHint"]
                </MudText>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large"
                           Href="/shop" Style="border-radius: 100px;">
                    @L["Cart.ToShop"]
                </MudButton>
            </MudPaper>
        }
        else
        {
            <MudText Typo="Typo.h5" Class="mb-6" Style="font-weight: 600;">
                @L["Search.ResultsCount", _totalCount, Query!]
            </MudText>

            <MudGrid Spacing="3">
                @foreach (var product in _results)
                {
                    <MudItem xs="12" sm="6" md="4">
                        <ProductCard Product="product"
                                     ShowCategory="true"
                                     OnOpen="OpenDetails"
                                     OnAdd="_ => { }" />
                    </MudItem>
                }
            </MudGrid>

            @if (_totalPages > 1)
            {
                <MudStack AlignItems="AlignItems.Center" Class="mt-8">
                    <MudPagination Color="Color.Primary" Count="_totalPages"
                                   Selected="_page" SelectedChanged="OnPageChangedAsync" />
                </MudStack>
            }
        }
    </MudContainer>
</section>

@code {
    [SupplyParameterFromQuery(Name = "q")]
    public string? Query { get; set; }

    private string _queryInput = string.Empty;
    private List<ProductDto> _results = [];
    private bool _loading;

    private const int PageSize = 12;
    private int _page = 1;
    private int _totalCount;
    private int _totalPages;

    protected override void OnInitialized()
    {
        _queryInput = Query ?? string.Empty;
    }

    protected override async Task OnParametersSetAsync()
    {
        _queryInput = Query ?? string.Empty;
        _page = 1;
        await RunSearchAsync();
    }

    private async Task RunSearchAsync()
    {
        if (string.IsNullOrWhiteSpace(Query))
        {
            _results = [];
            _totalCount = 0;
            _totalPages = 0;
            return;
        }

        _loading = true;
        try
        {
            var res = await Catalog.GetProductsAsync(
                new ProductQuery(Page: _page, PageSize: PageSize, Search: Query.Trim()));
            if (!res.IsSuccess)
            {
                Snackbar.Add(res.Error!.Message, Severity.Error);
                _results = [];
                _totalCount = 0;
                _totalPages = 0;
                return;
            }

            _results = res.Value!.Items.ToList();
            _totalCount = res.Value.TotalCount;
            _totalPages = res.Value.TotalPages;
        }
        catch (Exception ex)
        {
            Snackbar.Add(L["Search.Error", ex.Message], Severity.Error);
            _results = [];
            _totalCount = 0;
            _totalPages = 0;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task OnPageChangedAsync(int page)
    {
        _page = page;
        await RunSearchAsync();
    }

    private void OpenDetails(ProductDto product)
        => Navigation.NavigateTo($"/shop/{Uri.EscapeDataString(product.CategoryName)}/{Uri.EscapeDataString(product.Slug)}");

    private void ApplySearch()
    {
        var trimmed = _queryInput?.Trim() ?? string.Empty;
        var url = string.IsNullOrEmpty(trimmed) ? "/search" : $"/search?q={Uri.EscapeDataString(trimmed)}";
        Navigation.NavigateTo(url);
    }

    private void OnSearchKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") ApplySearch();
    }
}

@page "/admin"
@inject IAdminOrderingClient AdminOrdering
@inject IAdminCatalogClient AdminCatalog
@inject ISnackbar Snackbar
@inject IStringLocalizer<AppStrings> L

<PageTitle>@L["Admin.Dashboard.PageTitle"]</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="py-8">
    <MudText Typo="Typo.h4" Class="mb-2" Style="font-weight: 700;">@L["Admin.Dashboard.Title"]</MudText>
    <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mb-8">@L["Admin.Dashboard.Subtitle"]</MudText>

    @if (_loading)
    {
        <MudStack AlignItems="AlignItems.Center" Class="py-12">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
        </MudStack>
    }
    else if (_stats is null)
    {
        <MudAlert Severity="Severity.Error">@L["Common.LoadError", "–"]</MudAlert>
    }
    else
    {
        <MudGrid Class="mb-8">
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Elevation="0" Class="pa-5" Style="border-radius:16px;border:1px solid var(--mud-palette-divider);">
                    <MudStack Spacing="1">
                        <MudIcon Icon="@Icons.Material.Outlined.Receipt" Color="Color.Primary" />
                        <MudText Typo="Typo.h4" Style="font-weight:700;">@_stats.TotalOrders</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">@L["Admin.Dashboard.TotalOrders"]</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">@L["Admin.Dashboard.OrdersToday", _stats.OrdersToday]</MudText>
                    </MudStack>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Elevation="0" Class="pa-5" Style="border-radius:16px;border:1px solid var(--mud-palette-divider);">
                    <MudStack Spacing="1">
                        <MudIcon Icon="@Icons.Material.Outlined.Euro" Color="Color.Success" />
                        <MudText Typo="Typo.h4" Style="font-weight:700;">@Formatting.Currency(_stats.TotalRevenue)</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">@L["Admin.Dashboard.TotalRevenue"]</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">@Formatting.Currency(_stats.RevenueToday) @L["Admin.Dashboard.OrdersToday", ""]</MudText>
                    </MudStack>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Elevation="0" Class="pa-5" Style="border-radius:16px;border:1px solid var(--mud-palette-divider);">
                    <MudStack Spacing="1">
                        <MudIcon Icon="@Icons.Material.Outlined.LocalShipping" Color="Color.Warning" />
                        <MudText Typo="Typo.h4" Style="font-weight:700;">@_stats.PendingShipments</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">@L["Admin.Dashboard.PendingShipments"]</MudText>
                    </MudStack>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Elevation="0" Class="pa-5" Style="border-radius:16px;border:1px solid var(--mud-palette-divider);">
                    <MudStack Spacing="1">
                        <MudIcon Icon="@Icons.Material.Outlined.Warning" Color="Color.Error" />
                        <MudText Typo="Typo.h4" Style="font-weight:700;">@_lowStockCount</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">@L["Admin.Dashboard.LowStock"]</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">@L["Admin.Dashboard.LowStockOf", _totalProducts]</MudText>
                    </MudStack>
                </MudPaper>
            </MudItem>
        </MudGrid>

        <MudGrid>
            <MudItem xs="12" md="7">
                <MudPaper Elevation="0" Class="pa-6" Style="border-radius:16px;border:1px solid var(--mud-palette-divider);">
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-4">
                        <MudText Typo="Typo.h6" Style="font-weight:600;">@L["Admin.Dashboard.RecentOrders"]</MudText>
                        <MudButton Variant="Variant.Text" Size="Size.Small" Href="/admin/orders">@L["Admin.Dashboard.ViewAll"]</MudButton>
                    </MudStack>
                    @if (!_stats.RecentOrders.Any())
                    {
                        <MudText Typo="Typo.body2" Color="Color.Secondary">@L["Admin.Dashboard.NoOrders"]</MudText>
                    }
                    else
                    {
                        <MudStack Spacing="3">
                            @foreach (var order in _stats.RecentOrders)
                            {
                                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                    <MudStack Spacing="0">
                                        <MudText Typo="Typo.body2" Style="font-weight:500;">@order.CustomerName</MudText>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                                            #@order.Id.ToString("N")[..8].ToUpperInvariant() · @Formatting.DateTime(order.CreatedAt.ToLocalTime())
                                        </MudText>
                                    </MudStack>
                                    <MudStack Spacing="0" AlignItems="AlignItems.End">
                                        <MudText Typo="Typo.body2" Style="font-weight:600;">@Formatting.Currency(order.Total)</MudText>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">@order.Status</MudText>
                                    </MudStack>
                                </MudStack>
                            }
                        </MudStack>
                    }
                </MudPaper>
            </MudItem>

            <MudItem xs="12" md="5">
                <MudPaper Elevation="0" Class="pa-6" Style="border-radius:16px;border:1px solid var(--mud-palette-divider);">
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-4">
                        <MudText Typo="Typo.h6" Style="font-weight:600;">@L["Admin.Dashboard.LowStock"]</MudText>
                        <MudButton Variant="Variant.Text" Size="Size.Small" Href="/admin/products">@L["Admin.Dashboard.Products"]</MudButton>
                    </MudStack>
                    @if (!_lowStockProducts.Any())
                    {
                        <MudStack AlignItems="AlignItems.Center" Class="py-4">
                            <MudIcon Icon="@Icons.Material.Outlined.CheckCircle" Color="Color.Success" Style="font-size:48px;" />
                            <MudText Typo="Typo.body2" Color="Color.Secondary">@L["Admin.Dashboard.AllGood"]</MudText>
                        </MudStack>
                    }
                    else
                    {
                        <MudStack Spacing="2">
                            @foreach (var p in _lowStockProducts)
                            {
                                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                    <MudStack Spacing="0">
                                        <MudText Typo="Typo.body2">@p.Name</MudText>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="os-mono">@p.SKU</MudText>
                                    </MudStack>
                                    <MudChip T="string"
                                             Color="@(p.Stock == 0 ? Color.Error : Color.Warning)"
                                             Size="Size.Small" Variant="Variant.Filled"
                                             Style="border-radius:100px;">
                                        @p.Stock
                                    </MudChip>
                                </MudStack>
                            }
                        </MudStack>
                    }
                </MudPaper>
            </MudItem>
        </MudGrid>
    }
</MudContainer>

@code {
    private OrderStatsDto? _stats;
    private List<AdminProductDto> _lowStockProducts = [];
    private int _lowStockCount;
    private int _totalProducts;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var stats = await AdminOrdering.GetStatsAsync();
            _stats = stats.Value;
            if (!stats.IsSuccess) Snackbar.Add(stats.Error!.Message, Severity.Error);

            var products = await AdminCatalog.GetProductsAsync();
            if (products.IsSuccess)
            {
                var items = products.Value!;
                _lowStockProducts = items.Where(p => p.Stock < 10).OrderBy(p => p.Stock).Take(5).ToList();
                _lowStockCount = items.Count(p => p.Stock < 10);
                _totalProducts = items.Count;
            }
            else
            {
                Snackbar.Add(products.Error!.Message, Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add(L["Common.LoadError", ex.Message], Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }
}

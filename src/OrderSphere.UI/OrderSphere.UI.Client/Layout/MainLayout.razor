@using OrderSphere.UI.Client.Configuration
@inherits LayoutComponentBase

<MudThemeProvider Theme="ThemeConfiguration.ApplicationTheme()" IsDarkMode="true" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />


<MudLayout>
    <AppBar/>
    <NavMenu/>

    <MudMainContent Style="padding-top:1.5rem !important">
        <MudContainer MaxWidth="MaxWidth.ExtraExtraLarge" Class="mt-10">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

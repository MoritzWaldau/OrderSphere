  "roles": {
    "realm": [
      {
        "id": "c3d4e5f6-a7b8-9012-cdef-123456789012",
        "name": "customer",
        "description": "Regular shop customer — can browse, add to cart, checkout, and access own orders",
        "composite": false,
        "clientRole": false
      },
      {
        "id": "b2c3d4e5-0000-0001-0000-000000000001",
        "name": "csr",
        "description": "Customer Service Representative — read-only access to all orders and customer data. Composite: includes requires-mfa.",
        "composite": true,
        "clientRole": false,
        "composites": {
          "realm": ["requires-mfa"]
        }
      },
      {
        "id": "b2c3d4e5-0000-0002-0000-000000000002",
        "name": "order-manager",
        "description": "Order operations staff — may update order status and cancel orders. Composite: includes requires-mfa.",
        "composite": true,
        "clientRole": false,
        "composites": {
          "realm": ["requires-mfa"]
        }
      },
      {
        "id": "b2c3d4e5-0000-0003-0000-000000000003",
        "name": "catalog-admin",
        "description": "Merchandising role — full CRUD access to catalog products and categories. Composite: includes requires-mfa.",
        "composite": true,
        "clientRole": false,
        "composites": {
          "realm": ["requires-mfa"]
        }
      },
      {
        "id": "d4e5f6a7-b8c9-0123-defa-234567890123",
        "name": "admin",
        "description": "Platform administrator — composite of csr + order-manager + catalog-admin + requires-mfa",
        "composite": true,
        "clientRole": false,
        "composites": {
          "realm": ["csr", "order-manager", "catalog-admin", "requires-mfa"]
        }
      },
      {
        "id": "b2c3d4e5-0000-0006-0000-000000000006",
        "name": "requires-mfa",
        "description": "MFA gating role — users who effectively hold this role are required to complete a second factor (WebAuthn or OTP) in the conditional browser flow. Automatically included in csr, order-manager, catalog-admin, and admin via composite role inheritance.",
        "composite": false,
        "clientRole": false
      },
      {
        "id": "b2c3d4e5-0000-0004-0000-000000000004",
        "name": "svc.ordering",
        "description": "Machine identity for Ordering.Worker — assigned to the ordering-worker service account",
        "composite": false,
        "clientRole": false
      },
      {
        "id": "b2c3d4e5-0000-0005-0000-000000000005",
        "name": "svc.notification",
        "description": "Machine identity for Notification.Worker — assigned to the notification-worker service account",
        "composite": false,
        "clientRole": false
      }
    ]
  },


<div class="cart-quantity-control" style="@_containerStyle">
    <MudIconButton Icon="@Icons.Material.Filled.Remove"
                   Size="@ButtonSize"
                   aria-label="Menge verringern"
                   Disabled="@(Value <= Min || Disabled)"
                   OnClick="Decrease"
                   Class="@_buttonClass" />

    <MudText Typo="Typo.body2" Class="stepper-value">
        @Value
    </MudText>

    <MudIconButton Icon="@Icons.Material.Filled.Add"
                   Size="@ButtonSize"
                   aria-label="Menge erhöhen"
                   Disabled="@(Value >= Max || Disabled)"
                   OnClick="Increase"
                   Class="@_buttonClass" />
</div>

@code {
    [Parameter] public int Value { get; set; } = 1;
    [Parameter] public EventCallback<int> ValueChanged { get; set; }
    [Parameter] public int Min { get; set; } = 1;
    [Parameter] public int Max { get; set; } = 99;
    [Parameter] public Size ButtonSize { get; set; } = Size.Small;
    [Parameter] public StepperSize Variant { get; set; } = StepperSize.Default;
    [Parameter] public bool Disabled { get; set; }

    private string _buttonClass => Variant == StepperSize.Compact ? "stepper-btn-sm" : "stepper-btn";
    private string _containerStyle => Variant == StepperSize.Inline ? "width: fit-content;" : string.Empty;

    private async Task Increase()
    {
        if (Value >= Max) return;
        Value++;
        await ValueChanged.InvokeAsync(Value);
    }

    private async Task Decrease()
    {
        if (Value <= Min) return;
        Value--;
        await ValueChanged.InvokeAsync(Value);
    }

    public enum StepperSize { Default, Compact, Inline }
}

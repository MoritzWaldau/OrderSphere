@using OrderSphere.Application.Models
@using OrderSphere.UI.Services
@using OrderSphere.Application.Features.Cart.GetCart
@inject IJSRuntime JS
@inject ICartService CartService
@inject MediatR.ISender Sender
@implements IAsyncDisposable

<MudDrawer Open="IsOpen"
           OpenChanged="IsOpenChanged"
           Anchor="Anchor.Right"
           Elevation="4"
           Variant="DrawerVariant.Temporary"
           Width="420px"
           Style="height: 100vh;">

    <!-- Header -->
    <div style="padding: 20px 24px; display: flex; align-items: center; justify-content: space-between; flex-shrink: 0; border-bottom: 1px solid #D2D2D7;">
        <MudStack Spacing="0">
            <MudText Typo="Typo.h6" Style="color: #1D1D1F; font-weight: 700;">Warenkorb</MudText>
            <MudText Typo="Typo.caption" Style="color: #6E6E73;">
                @_items.Count Artikel
            </MudText>
        </MudStack>
        <MudIconButton Icon="@Icons.Material.Filled.Close"
                       OnClick="@(() => IsOpenChanged.InvokeAsync(false))"
                       Style="background: #F5F5F7; border-radius: 50%;" />
    </div>

    @if (!_items.Any())
    {
        <!-- Leer -->
        <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Style="flex: 1; padding: 48px 24px;">
            <div style="background: #F5F5F7; border-radius: 50%; width: 80px; height: 80px; display: flex; align-items: center; justify-content: center;">
                <MudIcon Icon="@Icons.Material.Filled.ShoppingCart"
                         Style="font-size: 2.5rem; color: #D2D2D7;" />
            </div>
            <MudText Typo="Typo.h6" Class="mt-4" Style="color: #1D1D1F;">
                Dein Warenkorb ist leer
            </MudText>
            <MudText Typo="Typo.body2" Align="Align.Center" Style="color: #6E6E73; margin-top: 4px;">
                Füge Produkte hinzu um loszulegen.
            </MudText>
            <MudButton Variant="Variant.Filled"
                       Href="/products"
                       Style="background: #0071E3; color: #FFFFFF; border-radius: 100px; padding: 10px 28px; margin-top: 24px; font-weight: 600;">
                Produkte entdecken
            </MudButton>
        </MudStack>
    }
    else
    {
        <!-- Items -->
        <div style="flex: 1; overflow-y: auto; overflow-x: hidden; align-content: start;">
            @foreach (var item in _items)
            {
                <div style="padding: 16px 24px; border-bottom: 1px solid #F5F5F7;">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="0">

                        <!-- Icon -->
                        <div style="width: 64px; height: 64px; min-width: 64px; background: linear-gradient(135deg, #F5F5F7, #E8E8ED); border-radius: 12px; display: flex; align-items: center; justify-content: center;">
                            <MudIcon Icon="@Icons.Material.Filled.Devices"
                                     Style="font-size: 1.75rem; color: #98989D;" />
                        </div>

                        <!-- Name & Controls -->
                        <div style="flex: 1; margin: 0 12px;">
                            <MudText Typo="Typo.body1" Style="color: #1D1D1F; font-weight: 500;">
                                @item.ProductName
                            </MudText>
                            <MudText Typo="Typo.caption" Style="color: #0071E3; font-weight: 600;">
                                @item.Price.ToString("C") / Stk.
                            </MudText>

                            <!-- +/- Controls -->
                            <div style="display: inline-flex; align-items: center; background: #F5F5F7; border-radius: 100px; padding: 2px; margin-top: 8px;">
                                <MudIconButton Icon="@Icons.Material.Filled.Remove"
                                               Size="Size.Small"
                                               OnClick="@(() => DecreaseQuantity(item))"
                                               Style="width: 28px; height: 28px; background: #FFFFFF; border-radius: 50%; box-shadow: 0 1px 4px rgba(0,0,0,0.1);" />
                                <MudText Typo="Typo.body2" Style="min-width: 32px; text-align: center; font-weight: 600; color: #1D1D1F;">
                                    @item.Quantity
                                </MudText>
                                <MudIconButton Icon="@Icons.Material.Filled.Add"
                                               Size="Size.Small"
                                               OnClick="@(() => IncreaseQuantity(item))"
                                               Style="width: 28px; height: 28px; background: #FFFFFF; border-radius: 50%; box-shadow: 0 1px 4px rgba(0,0,0,0.1);" />
                            </div>
                        </div>

                        <!-- Preis & Löschen -->
                        <MudStack AlignItems="AlignItems.End" Spacing="1">
                            <MudText Typo="Typo.body1" Style="color: #1D1D1F; font-weight: 700;">
                                @((item.Price * item.Quantity).ToString("C"))
                            </MudText>
                            <MudIconButton Icon="@Icons.Material.Filled.DeleteOutline"
                                           Size="Size.Small"
                                           OnClick="@(() => RemoveItem(item))"
                                           Style="color: #FF3B30;" />
                        </MudStack>

                    </MudStack>
                </div>
            }
        </div>

        <!-- Footer -->
        <div style="flex-shrink: 0; padding: 20px 24px; border-top: 1px solid #D2D2D7;">

            <!-- Zwischensumme -->
            <MudStack Row="true" Justify="Justify.SpaceBetween" Class="mb-2">
                <MudText Typo="Typo.body2" Style="color: #6E6E73;">Zwischensumme</MudText>
                <MudText Typo="Typo.body2" Style="color: #1D1D1F;">
                    @_items.Sum(x => x.Price * x.Quantity).ToString("C")
                </MudText>
            </MudStack>

            <MudStack Row="true" Justify="Justify.SpaceBetween" Class="mb-2">
                <MudText Typo="Typo.body2" Style="color: #6E6E73;">Versand</MudText>
                <MudText Typo="Typo.body2" Style="color: #06C167; font-weight: 600;">Kostenlos</MudText>
            </MudStack>

            <MudDivider Class="my-3" />

            <MudStack Row="true" Justify="Justify.SpaceBetween" Class="mb-4">
                <MudText Typo="Typo.h6" Style="color: #1D1D1F; font-weight: 700;">Gesamt</MudText>
                <MudText Typo="Typo.h6" Style="color: #0071E3; font-weight: 700;">
                    @_items.Sum(x => x.Price * x.Quantity).ToString("C")
                </MudText>
            </MudStack>

            <MudButton Variant="Variant.Filled"
                       FullWidth="true"
                       Href="/checkout"
                       Style="background: #0071E3; color: #FFFFFF; border-radius: 100px; padding: 14px; font-weight: 600; font-size: 1rem;">
                Zur Kasse →
            </MudButton>

            <MudButton Variant="Variant.Text"
                       FullWidth="true"
                       Href="/shop"
                       Style="color: #6E6E73; margin-top: 8px; border-radius: 100px;">
                Weiter shoppen
            </MudButton>

        </div>
    }

</MudDrawer>

@code {
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public EventCallback<bool> IsOpenChanged { get; set; }
    [Parameter] public EventCallback<int> OnItemCountChanged { get; set; }
    [Parameter] public Guid CustomerId { get; set; }

    private List<CartItemViewModel> _items = [];

    protected override async Task OnInitializedAsync()
    {
        CartService.OnCartUpdated += OnCartUpdated;
    }

    protected override async Task OnParametersSetAsync()
    {
        // Load cart when drawer is opened
        if (IsOpen && CustomerId != Guid.Empty)
        {
            await LoadCartAsync();
        }
    }

    private async Task LoadCartAsync()
    {
        try
        {
            var result = await Sender.Send(new GetCartQuery(CustomerId));
            if (result.IsSuccess)
            {
                CartService.UpdateCart(result.Value);
            }
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"Error loading cart: {ex.Message}");
        }
    }

    private void OnCartUpdated(CartDto cart)
    {
        _items = cart.Items
            .Select(item => CartItemViewModel.FromDto(item))
            .ToList();
        StateHasChanged();
        _ = UpdateItemCount();
    }

    private async Task IncreaseQuantity(CartItemViewModel item)
    {
        item.Quantity++;
        await UpdateItemCount();
    }

    private async Task DecreaseQuantity(CartItemViewModel item)
    {
        if (item.Quantity <= 1) await RemoveItem(item);
        else item.Quantity--;
        await UpdateItemCount();
    }

    private async Task RemoveItem(CartItemViewModel item)
    {
        _items.Remove(item);
        await UpdateItemCount();
    }

    private async Task UpdateItemCount() =>
        await OnItemCountChanged.InvokeAsync(_items.Sum(x => x.Quantity));

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        var method = IsOpen ? "lock" : "unlock";
        await JS.InvokeVoidAsync(method);
    }

    private class CartItemViewModel
    {
        public Guid ProductId { get; init; }
        public string ProductName { get; init; } = string.Empty;
        public decimal Price { get; init; }
        public int Quantity { get; set; }

        public static CartItemViewModel FromDto(CardItemDto dto) => new()
        {
            ProductId = dto.ProductId,
            ProductName = dto.ProductName,
            Price = dto.Price,
            Quantity = dto.Quantity
        };

        public CardItemDto ToDto() => new(ProductId, ProductName, Price, Quantity);
    }

    async ValueTask IAsyncDisposable.DisposeAsync()
    {
        CartService.OnCartUpdated -= OnCartUpdated;
        await Task.CompletedTask;
    }
}
@page "/checkout"
@attribute [Authorize]
@inject IOrderingClient Ordering
@inject CartState CartState
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<PageTitle>Checkout — OrderSphere</PageTitle>

<PageHero Eyebrow="Warenkorb → Checkout → Bestätigung"
          Title="Checkout"
          Subtitle="Prüfe deine Angaben, wähle Versand und Zahlung." />

<section style="padding:48px 0 80px;">
    <MudContainer>
        <MudGrid Spacing="4">
            <!-- Left: form -->
            <MudItem xs="12" lg="8">
                <MudStack Spacing="4">
                    <!-- Shipping -->
                    <MudPaper Elevation="0" Class="surface-card-lg pa-6">
                        <MudText Typo="Typo.h5" Class="mb-4">Lieferadresse</MudText>
                        <MudGrid Spacing="3">
                            <MudItem xs="12" md="6">
                                <MudTextField T="string" Label="Vorname" Variant="Variant.Outlined"
                                              FullWidth="true" Required="true"
                                              @bind-Value="_model.FirstName" />
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudTextField T="string" Label="Nachname" Variant="Variant.Outlined"
                                              FullWidth="true" Required="true"
                                              @bind-Value="_model.LastName" />
                            </MudItem>
                            <MudItem xs="12">
                                <MudTextField T="string" Label="Straße und Hausnummer" Variant="Variant.Outlined"
                                              FullWidth="true" Required="true"
                                              @bind-Value="_model.Street" />
                            </MudItem>
                            <MudItem xs="12" md="4">
                                <MudTextField T="string" Label="PLZ" Variant="Variant.Outlined"
                                              FullWidth="true" Required="true"
                                              @bind-Value="_model.PostalCode" />
                            </MudItem>
                            <MudItem xs="12" md="5">
                                <MudTextField T="string" Label="Stadt" Variant="Variant.Outlined"
                                              FullWidth="true" Required="true"
                                              @bind-Value="_model.City" />
                            </MudItem>
                            <MudItem xs="12" md="3">
                                <MudSelect T="string" Label="Land" Variant="Variant.Outlined"
                                           FullWidth="true" @bind-Value="_model.Country">
                                    <MudSelectItem T="string" Value="@("Deutschland")">Deutschland</MudSelectItem>
                                    <MudSelectItem T="string" Value="@("Österreich")">Österreich</MudSelectItem>
                                    <MudSelectItem T="string" Value="@("Schweiz")">Schweiz</MudSelectItem>
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudTextField T="string" Label="E-Mail" Variant="Variant.Outlined"
                                              FullWidth="true" Required="true" InputType="InputType.Email"
                                              @bind-Value="_model.Email" />
                            </MudItem>
                        </MudGrid>
                    </MudPaper>

                    <!-- Payment -->
                    <MudPaper Elevation="0" Class="surface-card-lg pa-6">
                        <MudText Typo="Typo.h5" Class="mb-4">Zahlungsart</MudText>
                        <MudRadioGroup T="int" @bind-Value="_model.PaymentMethod">
                            <MudStack Spacing="2">
                                <MudPaper Elevation="0" Class="surface-card pa-4">
                                    <MudRadio T="int" Value="0" Color="Color.Primary">Kreditkarte</MudRadio>
                                </MudPaper>
                                <MudPaper Elevation="0" Class="surface-card pa-4">
                                    <MudRadio T="int" Value="1" Color="Color.Primary">PayPal</MudRadio>
                                </MudPaper>
                                <MudPaper Elevation="0" Class="surface-card pa-4">
                                    <MudRadio T="int" Value="2" Color="Color.Primary">Kauf auf Rechnung</MudRadio>
                                </MudPaper>
                            </MudStack>
                        </MudRadioGroup>
                    </MudPaper>
                </MudStack>
            </MudItem>

            <!-- Right: order summary -->
            <MudItem xs="12" lg="4">
                <MudPaper Elevation="0" Class="surface-card-lg pa-6"
                          Style="position:sticky;top:100px;">
                    <MudText Typo="Typo.h5" Class="mb-4">Bestellübersicht</MudText>
                    <MudStack Spacing="3">
                        @foreach (var item in _cartItems)
                        {
                            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                <MudStack Spacing="0">
                                    <MudText Typo="Typo.subtitle2">@item.ProductName</MudText>
                                    <MudText Typo="Typo.caption" Class="text-muted">Menge: @item.Quantity</MudText>
                                </MudStack>
                                <MudText Typo="Typo.body2">
                                    @((item.Price * item.Quantity).ToString("0.00")) €
                                </MudText>
                            </MudStack>
                        }

                        <MudDivider />

                        <MudStack Row="true" Justify="Justify.SpaceBetween">
                            <MudText Typo="Typo.body1">Zwischensumme</MudText>
                            <MudText Typo="Typo.body1">@Subtotal.ToString("0.00") €</MudText>
                        </MudStack>
                        <MudStack Row="true" Justify="Justify.SpaceBetween">
                            <MudText Typo="Typo.body1">Versand</MudText>
                            <MudText Typo="Typo.body1">Kostenlos</MudText>
                        </MudStack>

                        <MudDivider />

                        <MudStack Row="true" Justify="Justify.SpaceBetween">
                            <MudText Typo="Typo.h6">Gesamt</MudText>
                            <MudText Typo="Typo.h6">@Subtotal.ToString("0.00") €</MudText>
                        </MudStack>

                        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                   FullWidth="true" Class="btn-pill my-4" Size="Size.Large"
                                   Disabled="_submitting"
                                   OnClick="SubmitAsync">
                            @if (_submitting)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                            }
                            Bestellung abschließen
                        </MudButton>

                        <MudText Typo="Typo.caption" Class="text-muted">
                            Mit dem Abschluss stimmst du unseren AGB zu.
                        </MudText>
                    </MudStack>
                </MudPaper>
            </MudItem>
        </MudGrid>
    </MudContainer>
</section>

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private List<CartItemDto> _cartItems = [];
    private bool _submitting;

    // Generated once per page visit. Stable across Polly retries; changes on navigation/refresh.
    private Guid _idempotencyKey = Guid.CreateVersion7();

    private readonly CheckoutFormModel _model = new()
    {
        Country = "Deutschland",
        PaymentMethod = 0
    };

    private decimal Subtotal => _cartItems.Sum(i => i.Quantity * i.Price);

    protected override async Task OnInitializedAsync()
    {
        var state = await (AuthState ?? Task.FromResult(new AuthenticationState(new System.Security.Claims.ClaimsPrincipal())));
        var email = state.User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value ?? string.Empty;
        _model.Email = email;

        _cartItems = CartState.Cart?.Items ?? [];
        if (!_cartItems.Any())
        {
            var cart = await Ordering.GetCartAsync();
            _cartItems = cart?.Items ?? [];
        }
    }

    private async Task SubmitAsync()
    {
        if (string.IsNullOrWhiteSpace(_model.FirstName) || string.IsNullOrWhiteSpace(_model.LastName) ||
            string.IsNullOrWhiteSpace(_model.Street) || string.IsNullOrWhiteSpace(_model.City) ||
            string.IsNullOrWhiteSpace(_model.PostalCode) || string.IsNullOrWhiteSpace(_model.Email))
        {
            Snackbar.Add("Bitte alle Pflichtfelder ausfüllen.", Severity.Warning);
            return;
        }

        _submitting = true;
        try
        {
            // Identity fields (CustomerId, CustomerEmail, CustomerName) are derived
            // from the JWT token server-side and not included in the request body.
            var request = new CheckoutRequest(
                new CheckoutAddress(_model.FirstName, _model.LastName, _model.Street,
                    _model.City, _model.PostalCode, _model.Country),
                _model.PaymentMethod);

            var correlationId = await Ordering.CheckoutAsync(request, _idempotencyKey);
            if (correlationId is null)
            {
                Snackbar.Add("Bestellung konnte nicht abgeschlossen werden.", Severity.Error);
                return;
            }

            await CartState.RefreshAsync();
            Navigation.NavigateTo(
                $"/checkout/success?correlationId={correlationId}&total={Subtotal.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture)}");
        }
        finally
        {
            _submitting = false;
        }
    }

    private sealed class CheckoutFormModel
    {
        public string FirstName { get; set; } = string.Empty;
        public string LastName  { get; set; } = string.Empty;
        public string Street    { get; set; } = string.Empty;
        public string PostalCode { get; set; } = string.Empty;
        public string City      { get; set; } = string.Empty;
        public string Country   { get; set; } = string.Empty;
        public string Email     { get; set; } = string.Empty;
        public int PaymentMethod { get; set; }
    }
}

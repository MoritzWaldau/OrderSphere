<footer>

    <!-- Main Footer -->
    <div style="background: #F5F5F7; padding: 60px 0 40px 0; border-top: 1px solid #D2D2D7;">
        <MudContainer>
            <MudGrid>

                <!-- Brand -->
                <MudItem xs="12" md="4">
                    <MudLink Href="/" Underline="Underline.None">
                        <MudText Typo="Typo.h6" Style="color: #1D1D1F; font-weight: 700; letter-spacing: -0.01em;">
                            OrderSphere
                        </MudText>
                    </MudLink>
                    <MudText Typo="Typo.body2" Style="color: #6E6E73; margin-top: 12px; max-width: 280px; line-height: 1.6;">
                        Dein Shop für moderne IT-Geräte. Schnell, zuverlässig und smart.
                    </MudText>
                    <MudText Typo="Typo.body2" Style="color: #6E6E73; margin-top: 8px;">
                        📧 support@ordersphere.dev
                    </MudText>
                    <MudText Typo="Typo.body2" Style="color: #6E6E73; margin-top: 4px;">
                        🤖 AI Assistant verfügbar
                    </MudText>
                </MudItem>

                <!-- Shop -->
                <MudItem xs="6" md="2">
                    <MudText Typo="Typo.caption" Style="color: #1D1D1F; font-weight: 700; letter-spacing: 0.08em;">
                        SHOP
                    </MudText>
                    <MudStack Spacing="2" Class="mt-3">
                        @foreach (var link in _shopLinks)
                        {
                            <MudLink Href="@link.Href"
                                     Underline="Underline.None"
                                     Style="color: #6E6E73; font-size: 0.875rem; transition: color 0.15s ease;"
                                     onmouseover="this.style.color='#0071E3'"
                                     onmouseout="this.style.color='#6E6E73'">
                                @link.Label
                            </MudLink>
                        }
                    </MudStack>
                </MudItem>

                <!-- Kategorien -->
                <MudItem xs="6" md="2">
                    <MudText Typo="Typo.caption" Style="color: #1D1D1F; font-weight: 700; letter-spacing: 0.08em;">
                        KATEGORIEN
                    </MudText>
                    <MudStack Spacing="2" Class="mt-3">
                        @foreach (var link in _categoryLinks)
                        {
                            <MudLink Href="@link.Href"
                                     Underline="Underline.None"
                                     Style="color: #6E6E73; font-size: 0.875rem; transition: color 0.15s ease;"
                                     onmouseover="this.style.color='#0071E3'"
                                     onmouseout="this.style.color='#6E6E73'">
                                @link.Label
                            </MudLink>
                        }
                    </MudStack>
                </MudItem>

                <!-- Rechtliches -->
                <MudItem xs="6" md="2">
                    <MudText Typo="Typo.caption" Style="color: #1D1D1F; font-weight: 700; letter-spacing: 0.08em;">
                        RECHTLICHES
                    </MudText>
                    <MudStack Spacing="2" Class="mt-3">
                        @foreach (var link in _legalLinks)
                        {
                            <MudLink Href="@link.Href"
                                     Underline="Underline.None"
                                     Style="color: #6E6E73; font-size: 0.875rem; transition: color 0.15s ease;"
                                     onmouseover="this.style.color='#0071E3'"
                                     onmouseout="this.style.color='#6E6E73'">
                                @link.Label
                            </MudLink>
                        }
                    </MudStack>
                </MudItem>

                <!-- Support -->
                <MudItem xs="6" md="2">
                    <MudText Typo="Typo.caption" Style="color: #1D1D1F; font-weight: 700; letter-spacing: 0.08em;">
                        SUPPORT
                    </MudText>
                    <MudStack Spacing="2" Class="mt-3">
                        @foreach (var link in _supportLinks)
                        {
                            <MudLink Href="@link.Href"
                                     Underline="Underline.None"
                                     Style="color: #6E6E73; font-size: 0.875rem; transition: color 0.15s ease;"
                                     onmouseover="this.style.color='#0071E3'"
                                     onmouseout="this.style.color='#6E6E73'">
                                @link.Label
                            </MudLink>
                        }
                    </MudStack>
                </MudItem>

            </MudGrid>
        </MudContainer>
    </div>

    <!-- Bottom Bar -->
    <div style="background: #1D1D1F; padding: 20px 0;">
        <MudContainer>
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                <MudText Typo="Typo.caption" Style="color: #98989D;">
                    © @DateTime.Now.Year OrderSphere — Alle Rechte vorbehalten
                </MudText>
                <MudStack Row="true" Spacing="3">
                    <MudLink Href="/imprint" Underline="Underline.None"
                             Style="color: #98989D; font-size: 0.75rem;"
                             onmouseover="this.style.color='#FFFFFF'"
                             onmouseout="this.style.color='#98989D'">
                        Impressum
                    </MudLink>
                    <MudLink Href="/privacy" Underline="Underline.None"
                             Style="color: #98989D; font-size: 0.75rem;"
                             onmouseover="this.style.color='#FFFFFF'"
                             onmouseout="this.style.color='#98989D'">
                        Datenschutz
                    </MudLink>
                    <MudLink Href="/cookies" Underline="Underline.None"
                             Style="color: #98989D; font-size: 0.75rem;"
                             onmouseover="this.style.color='#FFFFFF'"
                             onmouseout="this.style.color='#98989D'">
                        Cookies
                    </MudLink>
                </MudStack>
            </MudStack>
        </MudContainer>
    </div>

</footer>

@code {
    private readonly List<FooterLink> _shopLinks =
    [
        new("Home", "/"),
        new("Shop", "/shop"),
        new("Deals", "/deals"),
    ];

    private readonly List<FooterLink> _categoryLinks =
    [
        new("Laptops", "/shop/categories/laptops"),
        new("Smartphones", "/shop/categories/smartphones"),
        new("Tablets", "/shop/categories/tablets"),
        new("Accessories", "/shop/categories/accessories"),
    ];

    private readonly List<FooterLink> _legalLinks =
    [
        new("Imprint", "/imprint"),
        new("Privacy", "/privacy"),
        new("Cookies", "/cookies"),
        new("Terms", "/terms"),
    ];

    private readonly List<FooterLink> _supportLinks =
    [
        new("AI Assistant", "/assistant"),
        new("Contact", "/contact"),
        new("FAQ", "/faq"),
        new("Returns", "/returns"),
    ];

    private record FooterLink(string Label, string Href);
}
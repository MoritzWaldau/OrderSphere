{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*",
  "Keycloak": {
    "Authority": "http://localhost:8080/realms/ordersphere",
    "ClientId": "web-bff"
  },
  "ReverseProxy": {
    "Routes": {
      "catalog-public-products": {
        "ClusterId": "api-gateway",
        "AuthorizationPolicy": "anonymous",
        "Match": {
          "Path": "/api/v1/products/{**rest}",
          "Methods": [ "GET" ]
        }
      },
      "catalog-public-categories": {
        "ClusterId": "api-gateway",
        "AuthorizationPolicy": "anonymous",
        "Match": {
          "Path": "/api/v1/categories/{**rest}",
          "Methods": [ "GET" ]
        }
      },
      "to-gateway": {
        "ClusterId": "api-gateway",
        "Match": {
          "Path": "/api/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "api-gateway": {
        "Destinations": {
          "gateway-default": {
            "Address": "https+http://ordersphere-apigateway"
          }
        }
      }
    }
  }
}

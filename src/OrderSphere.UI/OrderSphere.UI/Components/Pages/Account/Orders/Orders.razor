@page "/account/orders"
@layout MainLayout
@using Microsoft.AspNetCore.Authorization
@inherits OrderSphereComponentBase

@attribute [Authorize]

<PageTitle>Meine Bestellungen — OrderSphere</PageTitle>

<section style="background: linear-gradient(135deg, #0071E3 0%, #0051A8 100%); padding: 60px 0;">
    <MudContainer>
        <MudText Typo="Typo.h2" Align="Align.Center" Style="color: #FFFFFF; letter-spacing: -0.02em;">
            Meine Bestellungen
        </MudText>
        <MudText Typo="Typo.body1" Align="Align.Center" Style="color: rgba(255,255,255,0.8); margin-top: 8px;">
            Übersicht aller deiner Bestellungen bei OrderSphere.
        </MudText>
    </MudContainer>
</section>

<section style="background: #F5F5F7; padding: 60px 0; min-height: 60vh;">
    <MudContainer MaxWidth="MaxWidth.Medium">
        @if (IsLoading)
        {
            <MudStack AlignItems="AlignItems.Center" Class="py-12">
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-4">
                    Bestellungen werden geladen...
                </MudText>
            </MudStack>
        }
        else if (_orders.Count == 0)
        {
            <MudPaper Elevation="0" Class="pa-12 text-center"
                      Style="border-radius: 20px; border: 1px solid var(--mud-palette-divider);">
                <MudIcon Icon="@Icons.Material.Outlined.ShoppingBag"
                         Color="Color.Primary"
                         Style="font-size: 80px;" Class="mb-4" />
                <MudText Typo="Typo.h5" Class="mb-2" Style="font-weight: 600;">
                    Noch keine Bestellungen
                </MudText>
                <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mb-6">
                    Sobald du etwas bestellst, findest du hier deine Bestellhistorie.
                </MudText>
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           Size="Size.Large"
                           Href="/shop"
                           StartIcon="@Icons.Material.Outlined.Storefront"
                           Class="btn-pill">
                    Jetzt entdecken
                </MudButton>
            </MudPaper>
        }
        else
        {
            <MudStack Spacing="4">
                @foreach (var order in _orders)
                {
                    <MudPaper Elevation="0" Class="pa-6"
                              Style="border-radius: 16px; border: 1px solid var(--mud-palette-divider); background: var(--mud-palette-surface);">
                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Start" Wrap="Wrap.Wrap" Class="mb-4">
                            <MudStack Spacing="1">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                    Bestellnummer
                                </MudText>
                                <MudText Typo="Typo.subtitle1" Style="font-weight: 600; font-family: monospace;">
                                    #@order.Id.ToString("N")[..8].ToUpperInvariant()
                                </MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                    @order.CreatedAt.ToLocalTime().ToString("dd. MMMM yyyy, HH:mm", System.Globalization.CultureInfo.GetCultureInfo("de-DE"))
                                </MudText>
                            </MudStack>

                            <MudChip T="string"
                                     Color="@GetStatusColor(order.Status)"
                                     Variant="Variant.Filled"
                                     Size="Size.Medium"
                                     Style="border-radius: 100px; font-weight: 600;">
                                @GetStatusLabel(order.Status)
                            </MudChip>
                        </MudStack>

                        <MudDivider Class="mb-4" />

                        <MudStack Spacing="2" Class="mb-4">
                            @foreach (var line in order.Items)
                            {
                                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                    <MudText Typo="Typo.body2">
                                        @line.Quantity × @line.ProductName
                                    </MudText>
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                                        @((line.Price * line.Quantity).ToString("0.00", System.Globalization.CultureInfo.GetCultureInfo("de-DE"))) €
                                    </MudText>
                                </MudStack>
                            }
                        </MudStack>

                        <MudDivider Class="mb-4" />

                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap">
                            <MudStack Spacing="0">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                    Lieferung an
                                </MudText>
                                <MudText Typo="Typo.body2">
                                    @order.ShippingAddress.FirstName @order.ShippingAddress.LastName, @order.ShippingAddress.City
                                </MudText>
                            </MudStack>

                            <MudStack Spacing="0" AlignItems="AlignItems.End">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                    Gesamt
                                </MudText>
                                <MudText Typo="Typo.h6" Style="font-weight: 700;">
                                    @order.Total.ToString("0.00", System.Globalization.CultureInfo.GetCultureInfo("de-DE")) €
                                </MudText>
                            </MudStack>
                        </MudStack>
                    </MudPaper>
                }
            </MudStack>
        }
    </MudContainer>
</section>

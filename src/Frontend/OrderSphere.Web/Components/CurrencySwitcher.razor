@inject IJSRuntime JS
@inject NavigationManager Navigation
@inject IStringLocalizer<AppStrings> L

<MudMenu Icon="@Icons.Material.Outlined.Payments"
         Color="Color.Default"
         AnchorOrigin="Origin.BottomRight"
         TransformOrigin="Origin.TopRight"
         aria-label="@L["Currency.Label"]"
         Dense="true">
    @foreach (var currency in SupportedCurrencies.All)
    {
        <MudMenuItem OnClick="@(() => SelectCurrencyAsync(currency.Code))">
            <div class="d-flex align-center gap-3" style="min-width: 160px;">
                <span style="width: 2rem;">@currency.Symbol</span>
                <span>@currency.Name</span>
                @if (currency.Code == _current)
                {
                    <MudIcon Icon="@Icons.Material.Filled.Check"
                             Size="Size.Small"
                             Color="Color.Primary"
                             Class="ml-auto" />
                }
            </div>
        </MudMenuItem>
    }
</MudMenu>

@code {
    private string _current = SupportedCurrencies.Default;

    protected override void OnInitialized()
        => _current = Formatting.DisplayCurrency;

    private async Task SelectCurrencyAsync(string code)
    {
        if (code == _current) return;

        try { await JS.InvokeVoidAsync("localStorage.setItem", SupportedCurrencies.StorageKey, code); }
        catch { /* localStorage unavailable (e.g. private mode) */ }

        // The display currency and rate are bound at startup; a full reload re-applies them and
        // re-renders every price through Formatting.Currency — mirrors the culture switch.
        Navigation.NavigateTo(Navigation.Uri, forceLoad: true);
    }
}

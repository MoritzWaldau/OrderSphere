@page "/checkout"
@attribute [Authorize]
@inject IOrderingClient Ordering
@inject CartState CartState
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject IStringLocalizer<AppStrings> L

<PageTitle>@L["Checkout.PageTitle"]</PageTitle>

<PageHero Eyebrow="@L["Checkout.Eyebrow"]"
          Title="@L["Checkout.Title"]"
          Subtitle="@L["Checkout.Subtitle"]" />

<section style="padding:48px 0 80px;">
    <MudContainer>
        <MudGrid Spacing="4">
            <!-- Left: form -->
            <MudItem xs="12" lg="8">
                <MudStack Spacing="4">
                    <CheckoutAddressForm Model="_model" />
                    <CheckoutPaymentForm Model="_model" />
                </MudStack>
            </MudItem>

            <!-- Right: order summary -->
            <MudItem xs="12" lg="4">
                <OrderSummary Title="@L["Checkout.Summary"]"
                              ShowLineItems="true"
                              Items="_cartItems"
                              Subtotal="Subtotal"
                              Discount="_discount"
                              StickyTop="100px">
                    <CouponSlot>
                        @if (string.IsNullOrEmpty(_appliedCoupon))
                        {
                            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                <MudTextField T="string" @bind-Value="_couponInput"
                                              Placeholder="@L["Checkout.CouponPlaceholder"]"
                                              Variant="Variant.Outlined" Margin="Margin.Dense" />
                                <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                                           OnClick="ApplyCouponAsync" Disabled="_couponValidating">
                                    @L["Checkout.CouponApply"]
                                </MudButton>
                            </MudStack>
                        }
                        else
                        {
                            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                <MudChip T="string" Color="Color.Success" Size="Size.Small" Variant="Variant.Filled"
                                         Icon="@Icons.Material.Outlined.LocalOffer">@_appliedCoupon</MudChip>
                                <MudButton Variant="Variant.Text" Size="Size.Small" OnClick="RemoveCoupon">
                                    @L["Checkout.CouponRemove"]
                                </MudButton>
                            </MudStack>
                        }
                        @if (!string.IsNullOrEmpty(_couponMessage))
                        {
                            <MudText Typo="Typo.caption" Class="text-muted">@_couponMessage</MudText>
                        }
                        <MudDivider />
                    </CouponSlot>
                    <Actions>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                   FullWidth="true" Class="btn-pill my-4" Size="Size.Large"
                                   Disabled="_submitting"
                                   OnClick="SubmitAsync">
                            @if (_submitting)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                            }
                            @L["Checkout.Submit"]
                        </MudButton>

                        <MudText Typo="Typo.caption" Class="text-muted">
                            @L["Checkout.TermsNote"]
                        </MudText>
                    </Actions>
                </OrderSummary>
            </MudItem>
        </MudGrid>
    </MudContainer>
</section>

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private List<CartItemDto> _cartItems = [];
    private bool _submitting;

    // Generated once per page visit. Stable across Polly retries; changes on navigation/refresh.
    private Guid _idempotencyKey = Guid.CreateVersion7();

    private readonly CheckoutFormModel _model = new();

    // Coupon state. The discount shown here is a preview; the worker recomputes it authoritatively.
    private string _couponInput = string.Empty;
    private string? _appliedCoupon;
    private decimal _discount;
    private string? _couponMessage;
    private bool _couponValidating;

    private decimal Subtotal => _cartItems.Sum(i => i.Quantity * i.Price);

    private async Task ApplyCouponAsync()
    {
        var code = _couponInput?.Trim() ?? string.Empty;
        if (string.IsNullOrEmpty(code)) return;

        _couponValidating = true;
        try
        {
            var result = await Ordering.ValidateCouponAsync(code, Subtotal);
            if (!result.IsSuccess)
            {
                _couponMessage = result.Error!.Message;
                _appliedCoupon = null;
                _discount = 0;
                return;
            }

            var dto = result.Value!;
            _couponMessage = dto.Message;
            if (dto.IsValid)
            {
                _appliedCoupon = code;
                _discount = dto.DiscountAmount;
            }
            else
            {
                _appliedCoupon = null;
                _discount = 0;
            }
        }
        finally
        {
            _couponValidating = false;
        }
    }

    private void RemoveCoupon()
    {
        _appliedCoupon = null;
        _discount = 0;
        _couponMessage = null;
        _couponInput = string.Empty;
    }

    protected override async Task OnInitializedAsync()
    {
        var state = await (AuthState ?? Task.FromResult(new AuthenticationState(new System.Security.Claims.ClaimsPrincipal())));
        var email = state.User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value ?? string.Empty;
        _model.Email = email;

        _cartItems = CartState.Cart?.Items ?? [];
        if (!_cartItems.Any())
        {
            var cart = await Ordering.GetCartAsync();
            if (cart.IsSuccess)
                _cartItems = cart.Value!.Items;
        }
    }

    private async Task SubmitAsync()
    {
        if (string.IsNullOrWhiteSpace(_model.FirstName) || string.IsNullOrWhiteSpace(_model.LastName) ||
            string.IsNullOrWhiteSpace(_model.Street) || string.IsNullOrWhiteSpace(_model.City) ||
            string.IsNullOrWhiteSpace(_model.PostalCode) || string.IsNullOrWhiteSpace(_model.Email))
        {
            Snackbar.Add(L["Checkout.RequiredFields"], Severity.Warning);
            return;
        }

        _submitting = true;
        try
        {
            // Identity fields (CustomerId, CustomerEmail, CustomerName) are derived
            // from the JWT token server-side and not included in the request body.
            var request = new CheckoutRequest(
                new CheckoutAddress(_model.FirstName, _model.LastName, _model.Street,
                    _model.City, _model.PostalCode, _model.Country),
                _model.PaymentMethod,
                _appliedCoupon);

            var result = await Ordering.CheckoutAsync(request, _idempotencyKey);
            if (!result.IsSuccess)
            {
                Snackbar.Add(result.Error!.Message, Severity.Error);
                return;
            }

            await CartState.RefreshAsync();
            var total = Subtotal - _discount;
            Navigation.NavigateTo(
                $"/checkout/success?correlationId={result.Value}&total={total.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture)}");
        }
        finally
        {
            _submitting = false;
        }
    }
}

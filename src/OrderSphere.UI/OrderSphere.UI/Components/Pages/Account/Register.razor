@page "/account/register"

<PageTitle>Registrieren – OrderSphere</PageTitle>

<section class="section-gray" style="min-height: 100vh; display: flex; align-items: center;">
    <MudContainer MaxWidth="MaxWidth.Small">
        <MudPaper Elevation="0" Class="pa-8" Style="border-radius: 20px; border: 1px solid var(--mud-palette-divider);">

            <!-- Header -->
            <MudStack AlignItems="AlignItems.Center" Class="mb-6">
                <MudLink Href="/" Underline="Underline.None">
                    <MudText Typo="Typo.h6" Style="font-weight: 700;">OrderSphere</MudText>
                </MudLink>
                <MudText Typo="Typo.h5" Style="font-weight: 700;" Class="mt-2">
                    Konto erstellen
                </MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    Erstelle dein kostenloses Konto
                </MudText>
            </MudStack>

            <!-- Form -->
            <MudStack Spacing="3">

                <MudStack Row="true" Spacing="3">
                    <MudTextField @bind-Value="_model.FirstName"
                                  Label="Vorname"
                                  Variant="Variant.Outlined"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Outlined.Person"
                                  FullWidth="true" />

                    <MudTextField @bind-Value="_model.LastName"
                                  Label="Nachname"
                                  Variant="Variant.Outlined"
                                  FullWidth="true" />
                </MudStack>

                <MudTextField @bind-Value="_model.Email"
                              Label="E-Mail"
                              Variant="Variant.Outlined"
                              InputType="InputType.Email"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Outlined.Email"
                              FullWidth="true" />

                <MudTextField @bind-Value="_model.Password"
                              Label="Passwort"
                              Variant="Variant.Outlined"
                              InputType="@PasswordInputType"
                              Adornment="Adornment.End"
                              AdornmentIcon="@PasswordIcon"
                              OnAdornmentClick="TogglePasswordVisibility"
                              FullWidth="true" />

                <MudTextField @bind-Value="_model.ConfirmPassword"
                              Label="Passwort bestätigen"
                              Variant="Variant.Outlined"
                              InputType="@ConfirmPasswordInputType"
                              Adornment="Adornment.End"
                              AdornmentIcon="@ConfirmPasswordIcon"
                              OnAdornmentClick="ToggleConfirmPasswordVisibility"
                              FullWidth="true" />

                @if (_errors.Any())
                {
                    <MudAlert Severity="Severity.Error" Dense="true">
                        <MudStack Spacing="1">
                            @foreach (var error in _errors)
                            {
                                <MudText Typo="Typo.body2">• @error</MudText>
                            }
                        </MudStack>
                    </MudAlert>
                }

                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           FullWidth="true"
                           Size="Size.Large"
                           Class="btn-pill mt-2"
                           OnClick="HandleRegister"
                           Disabled="_isLoading">
                    @if (_isLoading)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    }
                    Konto erstellen
                </MudButton>

                <MudDivider />

                <MudText Typo="Typo.body2" Align="Align.Center" Color="Color.Secondary">
                    Bereits ein Konto?
                    <MudLink Href="/account/login" Color="Color.Primary">Jetzt anmelden</MudLink>
                </MudText>

            </MudStack>
        </MudPaper>
    </MudContainer>
</section>
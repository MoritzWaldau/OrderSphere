@inject IJSRuntime JS
@inject NavigationManager Navigation
@inject IStringLocalizer<AppStrings> L

<MudMenu Icon="@Icons.Material.Outlined.Language"
         Color="Color.Default"
         AnchorOrigin="Origin.BottomRight"
         TransformOrigin="Origin.TopRight"
         aria-label="@L["Language.Label"]"
         Dense="true">
    @foreach (var culture in SupportedCultures.All)
    {
        <MudMenuItem OnClick="@(() => SelectCultureAsync(culture.Code))">
            <div class="d-flex align-center gap-3" style="min-width: 160px;">
                <span>@culture.Name</span>
                @if (culture.Code == _current)
                {
                    <MudIcon Icon="@Icons.Material.Filled.Check"
                             Size="Size.Small"
                             Color="Color.Primary"
                             Class="ml-auto" />
                }
            </div>
        </MudMenuItem>
    }
</MudMenu>

@code {
    private string _current = SupportedCultures.Default;

    protected override void OnInitialized()
        => _current = System.Globalization.CultureInfo.CurrentUICulture.Name;

    private async Task SelectCultureAsync(string code)
    {
        if (code == _current) return;

        try { await JS.InvokeVoidAsync("localStorage.setItem", SupportedCultures.StorageKey, code); }
        catch { /* localStorage unavailable (e.g. private mode) */ }

        // The active culture is bound at startup; a full reload re-resolves every localized string.
        Navigation.NavigateTo(Navigation.Uri, forceLoad: true);
    }
}

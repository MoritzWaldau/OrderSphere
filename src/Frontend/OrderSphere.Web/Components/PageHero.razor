@if (Variant == HeroVariant.TwoColumn)
{
    <div class="section-hero">
        <MudContainer MaxWidth="MaxWidth.Large">
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:center;">
                <div>
                    @if (!string.IsNullOrWhiteSpace(Eyebrow))
                    {
                        <span class="os-eyebrow" style="color:rgba(255,255,255,0.75);">@Eyebrow</span>
                    }
                    <MudText Typo="Typo.h2" Class="hero-title-lg mt-3">@Title</MudText>
                    @if (!string.IsNullOrWhiteSpace(Subtitle))
                    {
                        <MudText Typo="Typo.h6" Class="hero-subtitle mt-3" Style="font-weight:400;">@Subtitle</MudText>
                    }
                    @LeadingContent
                </div>
                <div>@ChildContent</div>
            </div>
        </MudContainer>
    </div>
}
else
{
    <div class="section-hero-sm">
        <MudContainer MaxWidth="MaxWidth.Large">
            @if (!string.IsNullOrWhiteSpace(Eyebrow))
            {
                <span class="os-eyebrow" style="color:rgba(255,255,255,0.75);">@Eyebrow</span>
            }
            <MudText Typo="Typo.h3" Class="hero-title mt-2">@Title</MudText>
            @if (!string.IsNullOrWhiteSpace(Subtitle))
            {
                <MudText Typo="Typo.body1" Class="hero-subtitle mt-2">@Subtitle</MudText>
            }
            @if (LeadingContent is not null)
            {
                <div class="mt-4">@LeadingContent</div>
            }
        </MudContainer>
    </div>
}

@code {
    public enum HeroVariant { Compact, TwoColumn }

    [Parameter] public HeroVariant Variant { get; set; } = HeroVariant.Compact;
    [Parameter] public string? Eyebrow { get; set; }
    [Parameter] public string Title { get; set; } = string.Empty;
    [Parameter] public string? Subtitle { get; set; }
    [Parameter] public RenderFragment? LeadingContent { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
}

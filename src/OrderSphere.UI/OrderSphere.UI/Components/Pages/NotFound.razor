@page "/not-found"
@layout EmptyLayout

<PageTitle>Seite nicht gefunden — OrderSphere</PageTitle>

<section class="section-hero">
    <MudContainer MaxWidth="MaxWidth.Medium">
        <MudStack AlignItems="AlignItems.Center" Spacing="6" Class="text-center">
            <MudIcon Icon="@Icons.Material.Outlined.TravelExplore"
                     Class="hero-icon-light"
                     Style="font-size: 120px;" />

            <MudText Typo="Typo.h1" Class="hero-title-lg"
                     Style="font-size: 8rem; line-height: 1;">
                404
            </MudText>

            <MudText Typo="Typo.h4" Class="text-on-dark" Style="font-weight: 600;">
                Diese Seite konnten wir leider nicht finden.
            </MudText>

            <MudText Typo="Typo.body1" Class="text-on-dark-muted"
                     Style="max-width: 560px;">
                Vielleicht wurde sie verschoben, umbenannt oder hat nie existiert.
                Lass uns dich wieder auf den richtigen Weg bringen.
            </MudText>

            <MudStack Row="true" Spacing="3" Wrap="Wrap.Wrap" Justify="Justify.Center" Class="mt-4">
                <MudButton Variant="Variant.Filled"
                           Size="Size.Large"
                           Href="/"
                           StartIcon="@Icons.Material.Outlined.Home"
                           Class="btn-pill-white">
                    Zur Startseite
                </MudButton>
                <MudButton Variant="Variant.Outlined"
                           Size="Size.Large"
                           Href="/shop"
                           StartIcon="@Icons.Material.Outlined.ShoppingBag"
                           Class="btn-pill-outline-white">
                    Zum Shop
                </MudButton>
            </MudStack>
        </MudStack>
    </MudContainer>
</section>

<section class="section-gray">
    <MudContainer MaxWidth="MaxWidth.Large">
        <MudStack AlignItems="AlignItems.Center" Spacing="6">
            <MudText Typo="Typo.h5" Style="font-weight: 600;">
                Oder entdecke etwas anderes
            </MudText>

            <MudGrid Spacing="4" Justify="Justify.Center">
                <MudItem xs="12" sm="6" md="4">
                    <MudPaper Elevation="0" Class="category-card pa-6 text-center"
                              Style="height: 100%;"
                              @onclick="@(() => Navigation.NavigateTo("/"))">
                        <MudIcon Icon="@Icons.Material.Outlined.Home"
                                 Color="Color.Primary"
                                 Style="font-size: 48px;" Class="mb-3" />
                        <MudText Typo="Typo.h6" Style="font-weight: 600;">Startseite</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-2">
                            Zurück zur Übersicht
                        </MudText>
                    </MudPaper>
                </MudItem>

                <MudItem xs="12" sm="6" md="4">
                    <MudPaper Elevation="0" Class="category-card pa-6 text-center"
                              Style="height: 100%;"
                              @onclick="@(() => Navigation.NavigateTo("/shop"))">
                        <MudIcon Icon="@Icons.Material.Outlined.ShoppingBag"
                                 Color="Color.Primary"
                                 Style="font-size: 48px;" Class="mb-3" />
                        <MudText Typo="Typo.h6" Style="font-weight: 600;">Produkte</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-2">
                            Alle Artikel durchstöbern
                        </MudText>
                    </MudPaper>
                </MudItem>

                <MudItem xs="12" sm="6" md="4">
                    <MudPaper Elevation="0" Class="category-card pa-6 text-center"
                              Style="height: 100%;"
                              @onclick="@(() => Navigation.NavigateTo("/categories"))">
                        <MudIcon Icon="@Icons.Material.Outlined.Category"
                                 Color="Color.Primary"
                                 Style="font-size: 48px;" Class="mb-3" />
                        <MudText Typo="Typo.h6" Style="font-weight: 600;">Kategorien</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-2">
                            Nach Themen entdecken
                        </MudText>
                    </MudPaper>
                </MudItem>
            </MudGrid>
        </MudStack>
    </MudContainer>
</section>

@code {
    [Inject] private NavigationManager Navigation { get; set; } = default!;
}

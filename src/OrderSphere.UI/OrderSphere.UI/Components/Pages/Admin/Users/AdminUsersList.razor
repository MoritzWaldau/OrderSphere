@page "/admin/users"
@layout AdminLayout
@using Microsoft.AspNetCore.Authorization
@inherits OrderSphereComponentBase
@rendermode InteractiveServer

@attribute [Authorize(Roles = "Administrator")]

<PageTitle>Benutzer — Admin</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="py-8">
    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-6">
        <MudStack Spacing="0">
            <MudText Typo="Typo.h4" Style="font-weight: 700;">Benutzer</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                @_users.Count Benutzer im System
            </MudText>
        </MudStack>
    </MudStack>

    @if (IsLoading)
    {
        <MudStack AlignItems="AlignItems.Center" Class="py-12">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
        </MudStack>
    }
    else if (_users.Count == 0)
    {
        <MudPaper Elevation="0" Class="pa-12 text-center"
                  Style="border-radius: 16px; border: 1px solid var(--mud-palette-divider);">
            <MudIcon Icon="@Icons.Material.Outlined.People" Color="Color.Secondary"
                     Style="font-size: 64px;" Class="mb-3" />
            <MudText Typo="Typo.h6">Keine Benutzer gefunden</MudText>
        </MudPaper>
    }
    else
    {
        <MudPaper Elevation="0" Style="border-radius: 16px; border: 1px solid var(--mud-palette-divider); overflow: hidden;">
            <MudTable Items="_users" Hover="true">
                <HeaderContent>
                    <MudTh>Name</MudTh>
                    <MudTh>Email</MudTh>
                    <MudTh>Bestätigt</MudTh>
                    <MudTh>Rollen</MudTh>
                    <MudTh Style="text-align:right;">Aktion</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Name">
                        <MudText Typo="Typo.body2" Style="font-weight: 500;">
                            @context.FirstName @context.LastName
                        </MudText>
                    </MudTd>
                    <MudTd DataLabel="Email">
                        <MudText Typo="Typo.body2">@context.Email</MudText>
                    </MudTd>
                    <MudTd DataLabel="Bestätigt">
                        @if (context.EmailConfirmed)
                        {
                            <MudIcon Icon="@Icons.Material.Outlined.CheckCircle" Color="Color.Success" Size="Size.Small" />
                        }
                        else
                        {
                            <MudIcon Icon="@Icons.Material.Outlined.HourglassEmpty" Color="Color.Warning" Size="Size.Small" />
                        }
                    </MudTd>
                    <MudTd DataLabel="Rollen">
                        <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap">
                            @foreach (var role in context.Roles)
                            {
                                <MudChip T="string"
                                         Size="Size.Small"
                                         Color="@(role == "Administrator" ? Color.Primary : Color.Default)"
                                         Variant="Variant.Filled"
                                         OnClose="@(() => RemoveRoleAsync(context.Id, role))"
                                         Style="border-radius: 100px;">
                                    @role
                                </MudChip>
                            }
                        </MudStack>
                    </MudTd>
                    <MudTd DataLabel="Aktion" Style="text-align:right;">
                        <MudMenu Icon="@Icons.Material.Outlined.MoreVert" Size="Size.Small">
                            @foreach (var role in _availableRoles.Where(r => !context.Roles.Contains(r)))
                            {
                                <MudMenuItem OnClick="@(() => AssignRoleAsync(context.Id, role))">
                                    Rolle '@role' zuweisen
                                </MudMenuItem>
                            }
                        </MudMenu>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        </MudPaper>
    }
</MudContainer>

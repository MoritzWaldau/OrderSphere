@page "/cart"
@attribute [Authorize]
@implements IDisposable
@inject IOrderingClient Ordering
@inject CartState CartState
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject IStringLocalizer<AppStrings> L

<PageTitle>@L["Cart.PageTitle"]</PageTitle>

<PageHero Title="@L["Cart.HeroTitle"]"
          Subtitle="@L["Cart.HeroSubtitle", _items.Count]" />

<section style="padding: 48px 0 80px;">
    <MudContainer MaxWidth="MaxWidth.Large">
        @if (_loading)
        {
            <MudStack AlignItems="AlignItems.Center" Style="min-height:40vh;justify-content:center;">
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
            </MudStack>
        }
        else if (_items.Count == 0)
        {
            <MudPaper Elevation="0" Class="surface-card-lg pa-12 text-center">
                <MudIcon Icon="@Icons.Material.Outlined.ShoppingCart"
                         Color="Color.Primary"
                         Style="font-size: 80px;" Class="mb-4" />
                <MudText Typo="Typo.h5" Class="mb-2" Style="font-weight: 600;">
                    @L["Cart.EmptyHeading"]
                </MudText>
                <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mb-6">
                    @L["Cart.AddProductsHint"]
                </MudText>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large"
                           Href="/shop"
                           StartIcon="@Icons.Material.Outlined.Storefront"
                           Style="border-radius: 100px;">
                    @L["Cart.DiscoverProducts"]
                </MudButton>
            </MudPaper>
        }
        else
        {
            <MudGrid Spacing="4">
                <MudItem xs="12" lg="8">
                    <MudStack Spacing="3">
                        @foreach (var item in _items)
                        {
                            <MudPaper Elevation="0" Class="surface-card pa-4">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="4">
                                    <div style="width:72px;height:72px;display:flex;align-items:center;justify-content:center;background:var(--mud-palette-background-grey);border-radius:12px;flex-shrink:0;">
                                        <MudIcon Icon="@Icons.Material.Outlined.Inventory2"
                                                 Style="font-size:32px;color:var(--mud-palette-divider);" />
                                    </div>

                                    <MudStack Spacing="1" Style="flex: 1;">
                                        <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">
                                            @item.ProductName
                                        </MudText>
                                        <MudText Typo="Typo.caption" Style="font-weight: 600; color: var(--mud-palette-primary);">
                                            @Formatting.Currency(item.Price) @L["Cart.PerUnitSuffix"]
                                        </MudText>

                                        <div class="mt-2" style="display: inline-block;">
                                            <QuantityStepper Value="item.Quantity"
                                                             ValueChanged="newValue => HandleQuantityChange(item, newValue)"
                                                             Min="1"
                                                             Disabled="_busy" />
                                        </div>
                                    </MudStack>

                                    <MudStack AlignItems="AlignItems.End" Spacing="2">
                                        <MudText Typo="Typo.h6" Style="font-weight: 700;">
                                            @Formatting.Currency(item.Price * item.Quantity)
                                        </MudText>
                                        <MudIconButton Icon="@Icons.Material.Outlined.DeleteOutline"
                                                       Size="Size.Small"
                                                       Color="Color.Error"
                                                       aria-label="@L["Cart.RemoveAria", item.ProductName]"
                                                       Disabled="_busy"
                                                       OnClick="@(() => RemoveItemAsync(item))" />
                                    </MudStack>
                                </MudStack>
                            </MudPaper>
                        }
                    </MudStack>
                </MudItem>

                <MudItem xs="12" lg="4">
                    <OrderSummary Title="@L["Cart.Summary"]" Subtotal="Subtotal">
                        <Actions>
                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       Size="Size.Large"
                                       FullWidth="true"
                                       Href="/checkout"
                                       EndIcon="@Icons.Material.Outlined.ArrowForward"
                                       Class="mt-2"
                                       Style="border-radius: 100px;">
                                @L["Cart.ToCheckout"]
                            </MudButton>

                            <MudButton Variant="Variant.Text"
                                       FullWidth="true"
                                       Href="/shop"
                                       Color="Color.Default"
                                       Style="border-radius: 100px;">
                                @L["Cart.ContinueShopping"]
                            </MudButton>
                        </Actions>
                    </OrderSummary>
                </MudItem>
            </MudGrid>
        }
    </MudContainer>
</section>

@code {
    private List<CartItemDto> _items = [];
    private bool _loading = true;
    private bool _busy;

    private decimal Subtotal => _items.Sum(x => x.Price * x.Quantity);

    protected override void OnInitialized()
    {
        CartState.OnChange += OnCartChanged;
        SyncFromCartState();
        _loading = false;
    }

    private void OnCartChanged()
    {
        SyncFromCartState();
        InvokeAsync(StateHasChanged);
    }

    private void SyncFromCartState()
    {
        _items = CartState.Cart?.Items?.ToList() ?? [];
    }

    private async Task HandleQuantityChange(CartItemDto item, int newValue)
    {
        if (_busy) return;
        _busy = true;
        try
        {
            var result = newValue > item.Quantity
                ? await Ordering.AddToCartAsync(item.ProductId, 1)
                : await Ordering.DecreaseCartItemAsync(item.ProductId);

            if (result.IsSuccess)
                await CartState.RefreshAsync();
            else
                Snackbar.Add(result.Error!.Message, Severity.Error);
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task RemoveItemAsync(CartItemDto item)
    {
        if (_busy) return;
        _busy = true;
        try
        {
            var result = await Ordering.RemoveFromCartAsync(item.ProductId);
            if (result.IsSuccess)
            {
                await CartState.RefreshAsync();
                Snackbar.Add(L["Cart.ItemRemoved", item.ProductName], Severity.Info);
            }
            else
            {
                Snackbar.Add(result.Error!.Message, Severity.Error);
            }
        }
        finally
        {
            _busy = false;
        }
    }

    public void Dispose()
    {
        CartState.OnChange -= OnCartChanged;
    }
}

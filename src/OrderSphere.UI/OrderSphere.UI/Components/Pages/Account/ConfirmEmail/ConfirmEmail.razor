@page "/confirm/email"
@using OrderSphere.UI.Components.Pages.Account

<PageTitle>E-Mail bestätigen</PageTitle>

<div class="d-flex justify-content-center align-items-center" style="min-height: 100vh;">
    <MudPaper Elevation="3" Class="pa-8" Style="width: 100%; max-width: 500px;">
        
        @if (!IsSuccess && Message.Contains("wird bestätigt"))
        {
            <!-- Lade-Animation -->
            <div class="text-center">
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" Style="margin: 0 auto; margin-bottom: 20px;"></MudProgressCircular>
                <MudText Typo="Typo.h6">@Message</MudText>
            </div>
        }
        else if (IsSuccess)
        {
            <!-- Erfolgreiche Bestätigung -->
            <div class="text-center">
                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Style="font-size: 80px; margin-bottom: 20px;"></MudIcon>
                
                <MudText Typo="Typo.h5" Class="mb-4" Color="Color.Success">
                    Erfolg!
                </MudText>
                
                <MudText Typo="Typo.body1" Class="mb-6">
                    @Message
                </MudText>
                
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" Href="/login" FullWidth="true">
                    Zur Anmeldung
                </MudButton>
            </div>
        }
        else
        {
            <!-- Fehlerfall -->
            <div class="text-center">
                <MudIcon Icon="@Icons.Material.Filled.Error" Color="Color.Error" Style="font-size: 80px; margin-bottom: 20px;"></MudIcon>
                
                <MudText Typo="Typo.h5" Class="mb-4" Color="Color.Error">
                    Bestätigung fehlgeschlagen
                </MudText>
                
                <MudText Typo="Typo.body1" Class="mb-6">
                    @Message
                </MudText>
                
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" Href="/register" FullWidth="true">
                    Zur Registrierung
                </MudButton>
            </div>
        }
        
    </MudPaper>
</div>

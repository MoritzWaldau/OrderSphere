@* Shipping-address section of the checkout page. Binds directly to the shared CheckoutFormModel. *@
@inject IStringLocalizer<AppStrings> L

<MudPaper Elevation="0" Class="surface-card-lg pa-6">
    <MudText Typo="Typo.h5" Class="mb-4">@L["Address.Title"]</MudText>
    <MudGrid Spacing="3">
        <MudItem xs="12" md="6">
            <MudTextField T="string" Label="@L["Address.FirstName"]" Variant="Variant.Outlined"
                          FullWidth="true" Required="true"
                          @bind-Value="Model.FirstName" />
        </MudItem>
        <MudItem xs="12" md="6">
            <MudTextField T="string" Label="@L["Address.LastName"]" Variant="Variant.Outlined"
                          FullWidth="true" Required="true"
                          @bind-Value="Model.LastName" />
        </MudItem>
        <MudItem xs="12">
            <MudTextField T="string" Label="@L["Address.Street"]" Variant="Variant.Outlined"
                          FullWidth="true" Required="true"
                          @bind-Value="Model.Street" />
        </MudItem>
        <MudItem xs="12" md="4">
            <MudTextField T="string" Label="@L["Address.PostalCode"]" Variant="Variant.Outlined"
                          FullWidth="true" Required="true"
                          @bind-Value="Model.PostalCode" />
        </MudItem>
        <MudItem xs="12" md="5">
            <MudTextField T="string" Label="@L["Address.City"]" Variant="Variant.Outlined"
                          FullWidth="true" Required="true"
                          @bind-Value="Model.City" />
        </MudItem>
        <MudItem xs="12" md="3">
            <MudSelect T="string" Label="@L["Address.Country"]" Variant="Variant.Outlined"
                       FullWidth="true" @bind-Value="Model.Country">
                <MudSelectItem T="string" Value="@("Deutschland")">Deutschland</MudSelectItem>
                <MudSelectItem T="string" Value="@("Österreich")">Österreich</MudSelectItem>
                <MudSelectItem T="string" Value="@("Schweiz")">Schweiz</MudSelectItem>
            </MudSelect>
        </MudItem>
        <MudItem xs="12" md="6">
            <MudTextField T="string" Label="@L["Address.Email"]" Variant="Variant.Outlined"
                          FullWidth="true" Required="true" InputType="InputType.Email"
                          @bind-Value="Model.Email" />
        </MudItem>
    </MudGrid>
</MudPaper>

@code {
    [Parameter, EditorRequired] public CheckoutFormModel Model { get; set; } = default!;
}

{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Information",
      "Yarp": "Debug"
    }
  },
  "ReverseProxy": {
    "Clusters": {
      "catalog": {
        "Destinations": {
          "catalog-default": {
            "Address": "http://ordersphere-catalog"
          }
        }
      },
      "ordering": {
        "Destinations": {
          "ordering-default": {
            "Address": "http://ordersphere-ordering"
          }
        }
      },
      "basket": {
        "Destinations": {
          "basket-default": {
            "Address": "http://ordersphere-basket"
          }
        }
      },
      "userprofile": {
        "Destinations": {
          "userprofile-default": {
            "Address": "http://ordersphere-userprofile"
          }
        }
      },
      "payment": {
        "Destinations": {
          "payment-default": {
            "Address": "http://ordersphere-payment"
          }
        }
      },
      "webhooks": {
        "Destinations": {
          "webhooks-default": {
            "Address": "http://ordersphere-webhooks"
          }
        }
      }
    }
  }
}

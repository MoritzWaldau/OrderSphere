@page "/admin/categories"
@inject IAdminCatalogClient AdminCatalog
@inject ISnackbar Snackbar

<PageTitle>Kategorien — Admin</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="py-8">
    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-6">
        <MudStack Spacing="0">
            <MudText Typo="Typo.h4" Style="font-weight: 700;">Kategorien</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">Verwalte die Produkt-Kategorien</MudText>
        </MudStack>
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Outlined.Add"
                   Href="/admin/categories/new"
                   Style="border-radius:100px;">
            Neue Kategorie
        </MudButton>
    </MudStack>

    @if (_loading)
    {
        <MudStack AlignItems="AlignItems.Center" Class="py-12">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
        </MudStack>
    }
    else if (_categories.Count == 0)
    {
        <MudPaper Elevation="0" Class="pa-12 text-center" Style="border-radius:16px;border:1px solid var(--mud-palette-divider);">
            <MudIcon Icon="@Icons.Material.Outlined.Category" Color="Color.Secondary" Style="font-size:64px;" Class="mb-3" />
            <MudText Typo="Typo.h6">Keine Kategorien vorhanden</MudText>
        </MudPaper>
    }
    else
    {
        <MudPaper Elevation="0" Style="border-radius:16px;border:1px solid var(--mud-palette-divider);overflow:hidden;">
            <MudTable Items="_categories" Hover="true">
                <HeaderContent>
                    <MudTh>Name</MudTh>
                    <MudTh>Beschreibung</MudTh>
                    <MudTh Style="text-align:center;">Produkte</MudTh>
                    <MudTh>Status</MudTh>
                    <MudTh Style="text-align:right;">Aktion</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Name">
                        <MudText Typo="Typo.body2" Style="font-weight:500;">@context.Name</MudText>
                    </MudTd>
                    <MudTd DataLabel="Beschreibung">
                        <MudText Typo="Typo.body2" Color="Color.Secondary">@context.Description</MudText>
                    </MudTd>
                    <MudTd DataLabel="Produkte" Style="text-align:center;">
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@context.ProductCount</MudChip>
                    </MudTd>
                    <MudTd DataLabel="Status">
                        <MudChip T="string"
                                 Color="@(context.IsActive ? Color.Success : Color.Default)"
                                 Size="Size.Small" Variant="Variant.Filled"
                                 Style="border-radius:100px;">
                            @(context.IsActive ? "Aktiv" : "Inaktiv")
                        </MudChip>
                    </MudTd>
                    <MudTd DataLabel="Aktion" Style="text-align:right;">
                        <MudIconButton Icon="@Icons.Material.Outlined.Edit"
                                       Color="Color.Primary" Size="Size.Small"
                                       Href="@($"/admin/categories/{context.Id}")" />
                        <MudIconButton Icon="@Icons.Material.Outlined.Delete"
                                       Color="Color.Error" Size="Size.Small"
                                       Disabled="@(context.ProductCount > 0)"
                                       OnClick="@(() => DeleteAsync(context.Id, context.Name))" />
                    </MudTd>
                </RowTemplate>
            </MudTable>
        </MudPaper>
    }
<MudMessageBox @ref="_msgBox" Title="Kategorie löschen" CancelText="Abbrechen">
    <MessageContent>@_pendingDeleteName wirklich löschen?</MessageContent>
    <YesButton>
        <MudButton Variant="Variant.Filled" Color="Color.Error">Löschen</MudButton>
    </YesButton>
</MudMessageBox>

</MudContainer>

@code {
    private List<AdminCategoryDto> _categories = [];
    private bool _loading = true;
    private MudMessageBox? _msgBox;
    private string _pendingDeleteName = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        try { _categories = await AdminCatalog.GetCategoriesAsync(); }
        catch (Exception ex) { Snackbar.Add($"Fehler: {ex.Message}", Severity.Error); }
        finally { _loading = false; }
    }

    private async Task DeleteAsync(Guid id, string name)
    {
        _pendingDeleteName = name;
        var confirmed = await _msgBox!.ShowAsync();
        if (confirmed != true) return;

        var ok = await AdminCatalog.DeleteCategoryAsync(id);
        if (ok) { _categories.RemoveAll(c => c.Id == id); Snackbar.Add("Kategorie gelöscht.", Severity.Success); }
        else Snackbar.Add("Löschen fehlgeschlagen.", Severity.Error);
    }
}

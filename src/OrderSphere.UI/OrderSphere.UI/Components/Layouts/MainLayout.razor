@inherits LayoutComponentBase
@using OrderSphere.UI.Configuration

<MudThemeProvider Theme="ThemeConfiguration.ApplicationTheme()" IsDarkMode="false" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>

    <Header IsCartOpen="_cartOpen"
            OnCartToggle="ToggleCart"
            CartItemCount="_cartItemCount" />

    <CartDrawer IsOpen="_cartOpen"
                IsOpenChanged="val => _cartOpen = val"
                OnItemCountChanged="count => _cartItemCount = count" />

    <MudMainContent>
        @Body
    </MudMainContent>

   <Footer/>


</MudLayout>

@code {
    private bool _cartOpen = false;
    private int _cartItemCount = 0;

    private void ToggleCart() => _cartOpen = !_cartOpen;
}
<footer style="padding: 48px 0; border-top: 1px solid var(--mud-palette-divider); margin-top: auto;">
    <MudContainer MaxWidth="MaxWidth.Large">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap" Spacing="4">
            <MudStack Spacing="1">
                <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">OrderSphere</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">
                    © @DateTime.UtcNow.Year OrderSphere. Alle Rechte vorbehalten.
                </MudText>
            </MudStack>
            <MudStack Row="true" Spacing="4">
                <MudLink Href="/legal/privacy" Typo="Typo.caption" Color="Color.Secondary">Datenschutz</MudLink>
                <MudLink Href="/legal/imprint" Typo="Typo.caption" Color="Color.Secondary">Impressum</MudLink>
                <MudLink Href="/support/faq" Typo="Typo.caption" Color="Color.Secondary">FAQ</MudLink>
            </MudStack>
        </MudStack>
    </MudContainer>
</footer>

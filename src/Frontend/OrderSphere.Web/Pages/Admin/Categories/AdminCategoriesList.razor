@page "/admin/categories"
@inject IAdminCatalogClient AdminCatalog
@inject ISnackbar Snackbar
@inject IStringLocalizer<AppStrings> L

<PageTitle>@L["Admin.Categories.PageTitle"]</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="py-8">
    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-6">
        <MudStack Spacing="0">
            <MudText Typo="Typo.h4" Style="font-weight: 700;">@L["Admin.Categories.Title"]</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">@L["Admin.Categories.Subtitle"]</MudText>
        </MudStack>
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Outlined.Add"
                   Href="/admin/categories/new"
                   Style="border-radius:100px;">
            @L["Admin.Categories.New"]
        </MudButton>
    </MudStack>

    @if (_loading)
    {
        <MudStack AlignItems="AlignItems.Center" Class="py-12">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
        </MudStack>
    }
    else if (_categories.Count == 0)
    {
        <MudPaper Elevation="0" Class="pa-12 text-center" Style="border-radius:16px;border:1px solid var(--mud-palette-divider);">
            <MudIcon Icon="@Icons.Material.Outlined.Category" Color="Color.Secondary" Style="font-size:64px;" Class="mb-3" />
            <MudText Typo="Typo.h6">@L["Admin.Categories.None"]</MudText>
        </MudPaper>
    }
    else
    {
        <MudPaper Elevation="0" Style="border-radius:16px;border:1px solid var(--mud-palette-divider);overflow:hidden;">
            <MudTable Items="_categories" Hover="true">
                <HeaderContent>
                    <MudTh>@L["Admin.Categories.ColName"]</MudTh>
                    <MudTh>@L["Admin.Categories.ColDescription"]</MudTh>
                    <MudTh Style="text-align:center;">@L["Admin.Categories.ColProducts"]</MudTh>
                    <MudTh>@L["Admin.Categories.ColStatus"]</MudTh>
                    <MudTh Style="text-align:right;">@L["Admin.Categories.ColAction"]</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="@L["Admin.Categories.ColName"]">
                        <MudText Typo="Typo.body2" Style="font-weight:500;">@context.Name</MudText>
                    </MudTd>
                    <MudTd DataLabel="@L["Admin.Categories.ColDescription"]">
                        <MudText Typo="Typo.body2" Color="Color.Secondary">@context.Description</MudText>
                    </MudTd>
                    <MudTd DataLabel="@L["Admin.Categories.ColProducts"]" Style="text-align:center;">
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@context.ProductCount</MudChip>
                    </MudTd>
                    <MudTd DataLabel="@L["Admin.Categories.ColStatus"]">
                        <MudChip T="string"
                                 Color="@(context.IsActive ? Color.Success : Color.Default)"
                                 Size="Size.Small" Variant="Variant.Filled"
                                 Style="border-radius:100px;">
                            @(context.IsActive ? L["Common.Active"] : L["Common.Inactive"])
                        </MudChip>
                    </MudTd>
                    <MudTd DataLabel="@L["Admin.Categories.ColAction"]" Style="text-align:right;">
                        <MudIconButton Icon="@Icons.Material.Outlined.Edit"
                                       Color="Color.Primary" Size="Size.Small"
                                       Href="@($"/admin/categories/{context.Id}")" />
                        <MudIconButton Icon="@Icons.Material.Outlined.Delete"
                                       Color="Color.Error" Size="Size.Small"
                                       Disabled="@(context.ProductCount > 0)"
                                       OnClick="@(() => DeleteAsync(context.Id, context.Name))" />
                    </MudTd>
                </RowTemplate>
            </MudTable>
        </MudPaper>
    }
<MudMessageBox @ref="_msgBox" Title="@L["Admin.Categories.DeleteTitle"]" CancelText="@L["Common.Cancel"]">
    <MessageContent>@L["Admin.Categories.DeleteConfirm", _pendingDeleteName]</MessageContent>
    <YesButton>
        <MudButton Variant="Variant.Filled" Color="Color.Error">@L["Common.Delete"]</MudButton>
    </YesButton>
</MudMessageBox>

</MudContainer>

@code {
    private List<AdminCategoryDto> _categories = [];
    private bool _loading = true;
    private MudMessageBox? _msgBox;
    private string _pendingDeleteName = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        try { var r = await AdminCatalog.GetCategoriesAsync(); if (r.IsSuccess) _categories = r.Value!; else Snackbar.Add(r.Error!.Message, Severity.Error); }
        catch (Exception ex) { Snackbar.Add(L["Common.Error", ex.Message], Severity.Error); }
        finally { _loading = false; }
    }

    private async Task DeleteAsync(Guid id, string name)
    {
        _pendingDeleteName = name;
        var confirmed = await _msgBox!.ShowAsync();
        if (confirmed != true) return;

        var result = await AdminCatalog.DeleteCategoryAsync(id);
        if (result.IsSuccess) { _categories.RemoveAll(c => c.Id == id); Snackbar.Add(L["Admin.Categories.Deleted"], Severity.Success); }
        else Snackbar.Add(result.Error!.Message, Severity.Error);
    }
}

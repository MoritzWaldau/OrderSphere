@page "/admin"
@inject IAdminOrderingClient AdminOrdering
@inject IAdminCatalogClient AdminCatalog
@inject ISnackbar Snackbar

<PageTitle>Dashboard — Admin</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="py-8">
    <MudText Typo="Typo.h4" Class="mb-2" Style="font-weight: 700;">Dashboard</MudText>
    <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mb-8">Übersicht über deinen Shop</MudText>

    @if (_loading)
    {
        <MudStack AlignItems="AlignItems.Center" Class="py-12">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
        </MudStack>
    }
    else if (_stats is null)
    {
        <MudAlert Severity="Severity.Error">Stats konnten nicht geladen werden.</MudAlert>
    }
    else
    {
        <MudGrid Class="mb-8">
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Elevation="0" Class="pa-5" Style="border-radius:16px;border:1px solid var(--mud-palette-divider);">
                    <MudStack Spacing="1">
                        <MudIcon Icon="@Icons.Material.Outlined.Receipt" Color="Color.Primary" />
                        <MudText Typo="Typo.h4" Style="font-weight:700;">@_stats.TotalOrders</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Bestellungen gesamt</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">@_stats.OrdersToday heute</MudText>
                    </MudStack>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Elevation="0" Class="pa-5" Style="border-radius:16px;border:1px solid var(--mud-palette-divider);">
                    <MudStack Spacing="1">
                        <MudIcon Icon="@Icons.Material.Outlined.Euro" Color="Color.Success" />
                        <MudText Typo="Typo.h4" Style="font-weight:700;">@Fmt(_stats.TotalRevenue)</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Umsatz gesamt</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">@Fmt(_stats.RevenueToday) heute</MudText>
                    </MudStack>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Elevation="0" Class="pa-5" Style="border-radius:16px;border:1px solid var(--mud-palette-divider);">
                    <MudStack Spacing="1">
                        <MudIcon Icon="@Icons.Material.Outlined.LocalShipping" Color="Color.Warning" />
                        <MudText Typo="Typo.h4" Style="font-weight:700;">@_stats.PendingShipments</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Offene Versände</MudText>
                    </MudStack>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Elevation="0" Class="pa-5" Style="border-radius:16px;border:1px solid var(--mud-palette-divider);">
                    <MudStack Spacing="1">
                        <MudIcon Icon="@Icons.Material.Outlined.Warning" Color="Color.Error" />
                        <MudText Typo="Typo.h4" Style="font-weight:700;">@_lowStockCount</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Niedriger Bestand</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">von @_totalProducts Produkten</MudText>
                    </MudStack>
                </MudPaper>
            </MudItem>
        </MudGrid>

        <MudGrid>
            <MudItem xs="12" md="7">
                <MudPaper Elevation="0" Class="pa-6" Style="border-radius:16px;border:1px solid var(--mud-palette-divider);">
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-4">
                        <MudText Typo="Typo.h6" Style="font-weight:600;">Letzte Bestellungen</MudText>
                        <MudButton Variant="Variant.Text" Size="Size.Small" Href="/admin/orders">Alle ansehen</MudButton>
                    </MudStack>
                    @if (!_stats.RecentOrders.Any())
                    {
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Noch keine Bestellungen</MudText>
                    }
                    else
                    {
                        <MudStack Spacing="3">
                            @foreach (var order in _stats.RecentOrders)
                            {
                                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                    <MudStack Spacing="0">
                                        <MudText Typo="Typo.body2" Style="font-weight:500;">@order.CustomerName</MudText>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                                            #@order.Id.ToString("N")[..8].ToUpperInvariant() · @order.CreatedAt.ToLocalTime().ToString("dd.MM. HH:mm")
                                        </MudText>
                                    </MudStack>
                                    <MudStack Spacing="0" AlignItems="AlignItems.End">
                                        <MudText Typo="Typo.body2" Style="font-weight:600;">@Fmt(order.Total)</MudText>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">@order.Status</MudText>
                                    </MudStack>
                                </MudStack>
                            }
                        </MudStack>
                    }
                </MudPaper>
            </MudItem>

            <MudItem xs="12" md="5">
                <MudPaper Elevation="0" Class="pa-6" Style="border-radius:16px;border:1px solid var(--mud-palette-divider);">
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-4">
                        <MudText Typo="Typo.h6" Style="font-weight:600;">Niedriger Bestand</MudText>
                        <MudButton Variant="Variant.Text" Size="Size.Small" Href="/admin/products">Produkte</MudButton>
                    </MudStack>
                    @if (!_lowStockProducts.Any())
                    {
                        <MudStack AlignItems="AlignItems.Center" Class="py-4">
                            <MudIcon Icon="@Icons.Material.Outlined.CheckCircle" Color="Color.Success" Style="font-size:48px;" />
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Alle Produkte gut bestückt.</MudText>
                        </MudStack>
                    }
                    else
                    {
                        <MudStack Spacing="2">
                            @foreach (var p in _lowStockProducts)
                            {
                                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                    <MudStack Spacing="0">
                                        <MudText Typo="Typo.body2">@p.Name</MudText>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="os-mono">@p.SKU</MudText>
                                    </MudStack>
                                    <MudChip T="string"
                                             Color="@(p.Stock == 0 ? Color.Error : Color.Warning)"
                                             Size="Size.Small" Variant="Variant.Filled"
                                             Style="border-radius:100px;">
                                        @p.Stock
                                    </MudChip>
                                </MudStack>
                            }
                        </MudStack>
                    }
                </MudPaper>
            </MudItem>
        </MudGrid>
    }
</MudContainer>

@code {
    private OrderStatsDto? _stats;
    private List<AdminProductDto> _lowStockProducts = [];
    private int _lowStockCount;
    private int _totalProducts;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var stats = await AdminOrdering.GetStatsAsync();
            _stats = stats.Value;
            if (!stats.IsSuccess) Snackbar.Add(stats.Error!.Message, Severity.Error);

            var products = await AdminCatalog.GetProductsAsync();
            if (products.IsSuccess)
            {
                var items = products.Value!;
                _lowStockProducts = items.Where(p => p.Stock < 10).OrderBy(p => p.Stock).Take(5).ToList();
                _lowStockCount = items.Count(p => p.Stock < 10);
                _totalProducts = items.Count;
            }
            else
            {
                Snackbar.Add(products.Error!.Message, Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Fehler beim Laden: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private static string Fmt(decimal v) =>
        v.ToString("0.00", System.Globalization.CultureInfo.GetCultureInfo("de-DE")) + " €";
}

@using OrderSphere.UI.Configuration

<MudAppBar Elevation="0"
           Fixed="true"
           Style="background: rgba(255,255,255,0.85); backdrop-filter: saturate(180%) blur(20px); -webkit-backdrop-filter: saturate(180%) blur(20px); border-bottom: 1px solid #D2D2D7;">

    <!-- Mobile: Burger -->
    <MudHidden Breakpoint="Breakpoint.MdAndUp">
        <MudIconButton Icon="@Icons.Material.Filled.Menu"
                       OnClick="ToggleDrawer"
                       Style="color: #1D1D1F;" />
    </MudHidden>

    <!-- Logo -->
    <MudLink Href="/" Underline="Underline.None">
        <MudText Typo="Typo.h5" Style="color: #1D1D1F; font-weight: 700; letter-spacing: -0.01em;">
            OrderSphere
        </MudText>
    </MudLink>

    <MudSpacer />

    <!-- Desktop Navigation -->
    <MudHidden Breakpoint="Breakpoint.SmAndDown">
        <MudButton Variant="Variant.Text"
                   Href="/products"
                   Style="color: #1D1D1F; font-weight: 400; font-size: 0.9375rem;">
            Produkte
        </MudButton>
        <MudButton Variant="Variant.Text"
                   Href="/categories"
                   Style="color: #1D1D1F; font-weight: 400; font-size: 0.9375rem;">
            Kategorien
        </MudButton>
        <MudButton Variant="Variant.Text"
                   Href="/offers"
                   Style="color: #1D1D1F; font-weight: 400; font-size: 0.9375rem;">
            Angebote
        </MudButton>
    </MudHidden>

    <MudSpacer />

    <!-- Actions -->
    <MudIconButton Icon="@Icons.Material.Outlined.Search"
                   Href="/search"
                   Style="color: #1D1D1F;" />

    <MudBadge Content="@CartItemCount"
              Color="Color.Error"
              Overlap="true"
              Visible="@(CartItemCount > 0)">
        <MudIconButton Icon="@Icons.Material.Outlined.ShoppingCart"
                       OnClick="OnCartToggle"
                       Style="color: #1D1D1F;" />
    </MudBadge>

    <MudIconButton Icon="@Icons.Material.Outlined.AccountCircle"
                   Href="/account"
                   Style="color: #1D1D1F;" />

</MudAppBar>

<MobileDrawer IsOpen="_drawerOpen" IsOpenChanged="val => _drawerOpen = val" />

@code {
    [Parameter] public bool IsCartOpen { get; set; }
    [Parameter] public EventCallback OnCartToggle { get; set; }
    [Parameter] public int CartItemCount { get; set; }

    private bool _drawerOpen = false;
    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;
}
@* Sticky order-summary card shared by the cart and checkout pages.
   Set ShowLineItems to render the itemised list above the totals.
   Place page-specific buttons/notes into the Actions fragment. *@

@inject IStringLocalizer<AppStrings> L

<MudPaper Elevation="0" Class="surface-card-lg pa-6" Style="@($"position:sticky;top:{StickyTop};")">
    <MudText Typo="Typo.h5" Class="mb-4" Style="font-weight:600;">@Title</MudText>
    <MudStack Spacing="3">
        @if (ShowLineItems)
        {
            @foreach (var item in Items)
            {
                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.subtitle2">@item.ProductName</MudText>
                        <MudText Typo="Typo.caption" Class="text-muted">@L["OrderSummary.Quantity", item.Quantity]</MudText>
                    </MudStack>
                    <MudText Typo="Typo.body2">@Formatting.Currency(item.Price * item.Quantity)</MudText>
                </MudStack>
            }
            <MudDivider />
        }

        @CouponSlot

        <MudStack Row="true" Justify="Justify.SpaceBetween">
            <MudText Typo="Typo.body2" Class="text-muted">@L["OrderSummary.Subtotal"]</MudText>
            <MudText Typo="Typo.body2">@Formatting.Currency(Subtotal)</MudText>
        </MudStack>
        @if (Discount > 0)
        {
            <MudStack Row="true" Justify="Justify.SpaceBetween">
                <MudText Typo="Typo.body2" Class="text-muted">@(DiscountLabel ?? L["OrderSummary.Discount"])</MudText>
                <MudText Typo="Typo.body2" Color="Color.Success">−@Formatting.Currency(Discount)</MudText>
            </MudStack>
        }
        <MudStack Row="true" Justify="Justify.SpaceBetween">
            <MudText Typo="Typo.body2" Class="text-muted">@L["OrderSummary.Shipping"]</MudText>
            @if (ShippingCost > 0)
            {
                <MudText Typo="Typo.body2">@Formatting.Currency(ShippingCost)</MudText>
            }
            else
            {
                <MudText Typo="Typo.body2" Class="shipping-free">@L["OrderSummary.Free"]</MudText>
            }
        </MudStack>

        <MudDivider />

        <MudStack Row="true" Justify="Justify.SpaceBetween">
            <MudText Typo="Typo.h6" Style="font-weight:700;">@L["OrderSummary.Total"]</MudText>
            <MudText Typo="Typo.h6" Style="font-weight:700;color:var(--mud-palette-primary);">
                @Formatting.Currency(Subtotal - Discount + ShippingCost)
            </MudText>
        </MudStack>

        @Actions
    </MudStack>
</MudPaper>

@code {
    [Parameter] public string Title { get; set; } = "Zusammenfassung";
    [Parameter] public decimal Subtotal { get; set; }
    [Parameter] public decimal Discount { get; set; }
    [Parameter] public decimal ShippingCost { get; set; }
    [Parameter] public string? DiscountLabel { get; set; }
    [Parameter] public bool ShowLineItems { get; set; }
    [Parameter] public IReadOnlyList<CartItemDto> Items { get; set; } = [];
    [Parameter] public string StickyTop { get; set; } = "24px";
    [Parameter] public RenderFragment? CouponSlot { get; set; }
    [Parameter] public RenderFragment? Actions { get; set; }
}

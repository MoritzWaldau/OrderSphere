@page "/admin/categories/new"
@page "/admin/categories/{CategoryId:guid}"
@inject IAdminCatalogClient AdminCatalog
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject IStringLocalizer<AppStrings> L

<PageTitle>@(IsEdit ? L["Admin.CategoryForm.PageTitleEdit"] : L["Admin.CategoryForm.PageTitleCreate"])</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="py-8">
    <MudButton Variant="Variant.Text" StartIcon="@Icons.Material.Outlined.ArrowBack"
               Href="/admin/categories" Class="mb-4">
        @L["Admin.CategoryForm.BackToList"]
    </MudButton>

    <MudText Typo="Typo.h4" Class="mb-6" Style="font-weight: 700;">
        @(IsEdit ? L["Admin.CategoryForm.TitleEdit"] : L["Admin.CategoryForm.TitleCreate"])
    </MudText>

    @if (_loading)
    {
        <MudStack AlignItems="AlignItems.Center" Class="py-12">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
        </MudStack>
    }
    else
    {
        <MudPaper Elevation="0" Class="pa-6" Style="border-radius:16px;border:1px solid var(--mud-palette-divider);">
            <MudStack Spacing="4">
                <MudTextField @bind-Value="_name" Label="@L["Admin.CategoryForm.Name"]"
                              Variant="Variant.Outlined" Required="true"
                              RequiredError="@L["Admin.CategoryForm.NameRequired"]" />

                <MudTextField @bind-Value="_description" Label="@L["Admin.CategoryForm.Description"]"
                              Variant="Variant.Outlined" Lines="3" />

                @if (IsEdit)
                {
                    <MudSwitch T="bool" @bind-Value="_isActive"
                               Label="@L["Admin.CategoryForm.ActiveLabel"]" Color="Color.Primary" />
                }

                <MudStack Row="true" Justify="Justify.FlexEnd" Spacing="2" Class="mt-2">
                    <MudButton Variant="Variant.Outlined" Href="/admin/categories">@L["Common.Cancel"]</MudButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               StartIcon="@Icons.Material.Outlined.Save"
                               Disabled="_saving" OnClick="SaveAsync">
                        @(IsEdit ? L["Common.Save"] : L["Common.Create"])
                    </MudButton>
                </MudStack>
            </MudStack>
        </MudPaper>
    }
</MudContainer>

@code {
    [Parameter] public Guid? CategoryId { get; set; }

    private bool IsEdit => CategoryId.HasValue;
    private bool _loading = true;
    private bool _saving;
    private string _name = string.Empty;
    private string _description = string.Empty;
    private bool _isActive = true;

    protected override async Task OnInitializedAsync()
    {
        if (IsEdit)
        {
            try
            {
                var cats = await AdminCatalog.GetCategoriesAsync();
                if (!cats.IsSuccess) Snackbar.Add(cats.Error!.Message, Severity.Error);
                var cat = cats.Value?.FirstOrDefault(c => c.Id == CategoryId!.Value);
                if (cat is not null) { _name = cat.Name; _description = cat.Description; _isActive = cat.IsActive; }
            }
            catch (Exception ex) { Snackbar.Add(L["Common.Error", ex.Message], Severity.Error); }
        }
        _loading = false;
    }

    private async Task SaveAsync()
    {
        _saving = true;
        try
        {
            var input = new AdminCategoryInput(_name, _description, _isActive);
            if (IsEdit)
            {
                var result = await AdminCatalog.UpdateCategoryAsync(CategoryId!.Value, input);
                if (result.IsSuccess) { Snackbar.Add(L["Admin.CategoryForm.Saved"], Severity.Success); Navigation.NavigateTo("/admin/categories"); }
                else Snackbar.Add(result.Error!.Message, Severity.Error);
            }
            else
            {
                var result = await AdminCatalog.CreateCategoryAsync(input);
                if (result.IsSuccess) { Snackbar.Add(L["Admin.CategoryForm.Created"], Severity.Success); Navigation.NavigateTo("/admin/categories"); }
                else Snackbar.Add(result.Error!.Message, Severity.Error);
            }
        }
        finally { _saving = false; }
    }
}

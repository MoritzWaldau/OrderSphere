@inherits LayoutComponentBase

<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />


<MudLayout>
    <MudAppBar Elevation="1">
        <MudGrid>
            <MudItem md="3">
                <MudText Typo="Typo.h6" Align="Align.Start">OrderSphere</MudText>
            </MudItem>

            <MudItem md="6">
                <MudLink Href="/Products">Products</MudLink>
            </MudItem>

<div class="mud-container mud-container-maxwidth-xl" style="padding-top: 24px;">
    <MudSkeleton Width="220px" Height="20px" Class="mb-4" />
</div>

<section style="padding-top: 32px; padding-bottom: 80px;">
    <MudContainer MaxWidth="MaxWidth.ExtraLarge">
        <MudGrid Spacing="6">

            <MudItem xs="12" md="7">
                <MudSkeleton SkeletonType="SkeletonType.Rectangle"
                             Width="100%" Height="460px"
                             Style="border-radius:16px;" />
                <div class="d-flex gap-2 mt-3">
                    @for (int i = 0; i < 4; i++)
                    {
                        <MudSkeleton SkeletonType="SkeletonType.Rectangle"
                                     Width="80px" Height="80px"
                                     Style="border-radius:10px; flex-shrink:0;" />
                    }
                </div>
            </MudItem>

            <MudItem xs="12" md="5">
                <div class="d-flex flex-column gap-3">
                    <MudSkeleton Width="90px" Height="24px" Style="border-radius:100px;" />
                    <MudSkeleton Width="85%" Height="40px" />
                    <MudSkeleton Width="60%" Height="36px" />
                    <div class="d-flex gap-2 align-center">
                        <MudSkeleton Width="140px" Height="36px" />
                        <MudSkeleton Width="80px" Height="28px" Style="border-radius:100px;" />
                    </div>

                    <MudDivider Class="my-1" />

                    <MudSkeleton Width="140px" Height="20px" />

                    <div class="d-flex gap-3">
                        <MudSkeleton Width="120px" Height="48px" Style="border-radius:100px;" />
                        <MudSkeleton Width="100%" Height="48px" Style="border-radius:100px;" />
                    </div>
                    <MudSkeleton Width="100%" Height="48px" Style="border-radius:100px;" />

                    <MudDivider Class="my-1" />

                    <MudGrid Spacing="2">
                        @for (int i = 0; i < 3; i++)
                        {
                            <MudItem xs="4">
                                <div class="d-flex flex-column align-center gap-1">
                                    <MudSkeleton SkeletonType="SkeletonType.Circle" Width="28px" Height="28px" />
                                    <MudSkeleton Width="60px" Height="14px" />
                                    <MudSkeleton Width="50px" Height="14px" />
                                </div>
                            </MudItem>
                        }
                    </MudGrid>
                </div>
            </MudItem>
        </MudGrid>

        <MudPaper Elevation="0" Class="mt-8"
                  Style="border:1px solid var(--mud-palette-divider); border-radius:16px; padding:24px;">
            <div class="d-flex gap-4 mb-6">
                <MudSkeleton Width="120px" Height="28px" />
                <MudSkeleton Width="140px" Height="28px" />
            </div>
            <MudSkeleton Width="100%" Height="16px" Class="mb-2" />
            <MudSkeleton Width="95%" Height="16px" Class="mb-2" />
            <MudSkeleton Width="88%" Height="16px" Class="mb-2" />
            <MudSkeleton Width="92%" Height="16px" Class="mb-2" />
            <MudSkeleton Width="70%" Height="16px" />
        </MudPaper>
    </MudContainer>
</section>

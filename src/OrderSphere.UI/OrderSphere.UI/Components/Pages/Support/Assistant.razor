@page "/assistant"
@layout MainLayout

<PageTitle>AI Assistant — OrderSphere</PageTitle>

<section class="section-hero">
    <MudContainer MaxWidth="MaxWidth.Medium">
        <MudStack AlignItems="AlignItems.Center" Spacing="4" Class="text-center">
            <MudIcon Icon="@Icons.Material.Outlined.AutoAwesome"
                     Style="font-size: 100px; color: rgba(255,255,255,0.95);" />
            <MudText Typo="Typo.h1"
                     Style="color: #FFFFFF; font-weight: 700; letter-spacing: -0.04em;">
                AI Assistant
            </MudText>
            <MudText Typo="Typo.h5"
                     Style="color: rgba(255,255,255,0.85); font-weight: 400; max-width: 600px;">
                Dein persönlicher Einkaufs-Helfer — bald hier verfügbar.
            </MudText>
        </MudStack>
    </MudContainer>
</section>

<section style="background: #F5F5F7; padding: 60px 0; min-height: 50vh;">
    <MudContainer MaxWidth="MaxWidth.Medium">
        <MudPaper Elevation="0" Class="pa-8"
                  Style="border-radius: 20px; border: 1px solid var(--mud-palette-divider); background: #FFFFFF;">

            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mb-6">
                Der AI Assistant ist aktuell in Entwicklung und steht in Kürze zur Verfügung.
            </MudAlert>

            <MudText Typo="Typo.h5" Class="mb-4" Style="font-weight: 600;">
                Was er für dich tun wird
            </MudText>

            <MudStack Spacing="4">
                <MudStack Row="true" Spacing="3" AlignItems="AlignItems.Start">
                    <MudIcon Icon="@Icons.Material.Outlined.Search"
                             Color="Color.Primary" Style="font-size: 28px;" />
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">
                            Produkte finden
                        </MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">
                            Beschreibe was du brauchst — der Assistent schlägt passende Produkte aus unserem Sortiment vor.
                        </MudText>
                    </MudStack>
                </MudStack>

                <MudStack Row="true" Spacing="3" AlignItems="AlignItems.Start">
                    <MudIcon Icon="@Icons.Material.Outlined.Compare"
                             Color="Color.Primary" Style="font-size: 28px;" />
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">
                            Vergleiche treffen
                        </MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">
                            Mehrere Modelle gegenüberstellen — ohne mühsames Lesen langer Spec-Listen.
                        </MudText>
                    </MudStack>
                </MudStack>

                <MudStack Row="true" Spacing="3" AlignItems="AlignItems.Start">
                    <MudIcon Icon="@Icons.Material.Outlined.QuestionAnswer"
                             Color="Color.Primary" Style="font-size: 28px;" />
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">
                            Fragen beantworten
                        </MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">
                            Versand, Rückgabe, Kompatibilität — schnell und in natürlicher Sprache.
                        </MudText>
                    </MudStack>
                </MudStack>
            </MudStack>

            <MudDivider Class="my-6" />

            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
                Bis dahin helfen wir dir gerne persönlich weiter.
            </MudText>
            <MudStack Row="true" Spacing="3" Wrap="Wrap.Wrap">
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           Href="/contact" StartIcon="@Icons.Material.Outlined.SupportAgent"
                           Class="btn-pill">
                    Zum Kontakt
                </MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                           Href="/faq" StartIcon="@Icons.Material.Outlined.Help"
                           Class="btn-pill">
                    Zur FAQ
                </MudButton>
            </MudStack>
        </MudPaper>
    </MudContainer>
</section>

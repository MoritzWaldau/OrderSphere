@inherits LayoutComponentBase
@using OrderSphere.UI.Configuration
@using OrderSphere.UI.Services.Theme
@inject IThemeService ThemeService
@implements IDisposable

<MudThemeProvider Theme="ThemeConfiguration.ApplicationTheme()" IsDarkMode="@ThemeService.IsDarkMode" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>

    <Header IsCartOpen="_cartOpen"
            OnCartToggle="ToggleCart"
            CartItemCount="_cartItemCount" />

    <CartDrawer IsOpen="_cartOpen"
                IsOpenChanged="OnCartOpenChanged"
                OnItemCountChanged="count => _cartItemCount = count"/>

    <MudMainContent>
        @Body
    </MudMainContent>

   <Footer/>

</MudLayout>

@code {
    private bool _cartOpen = false;
    private int _cartItemCount = 0;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await ThemeService.InitializeAsync();
            StateHasChanged();
        }
    }

    protected override void OnInitialized()
    {
        ThemeService.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        ThemeService.OnChange -= StateHasChanged;
    }

    private void ToggleCart() => _cartOpen = !_cartOpen;

    private Task OnCartOpenChanged(bool value)
    {
        _cartOpen = value;
        return Task.CompletedTask;
    }
}

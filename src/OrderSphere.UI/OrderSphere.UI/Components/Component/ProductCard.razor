@*
    Product card used on Shop and Search pages. Whole card navigates to detail
    page; the AddToCart button stops propagation so it does not double-fire.
*@

<MudPaper Elevation="0"
          Class="product-card"
          @onclick="HandleOpen"
          role="button"
          tabindex="0">

    <ProductImage ImageUrl="@Product.ImageUrl"
                  Alt="@Product.Name"
                  Size="@(Compact ? ProductImage.ImageSize.SearchCard : ProductImage.ImageSize.Card)" />

    <div class="product-card-content">
        @if (ShowCategory && !string.IsNullOrWhiteSpace(Product.CategoryName))
        {
            <MudText Typo="Typo.caption" Color="Color.Secondary">
                @Product.CategoryName
            </MudText>
        }

        <MudText Typo="Typo.h6" Style="font-weight: 600; margin-top: 4px;">
            @Product.Name
        </MudText>

        @if (ShowDescription && !string.IsNullOrWhiteSpace(Product.Description))
        {
            <MudText Typo="Typo.body2" Color="Color.Secondary" Style="margin-top: 6px; flex: 1;">
                @Product.Description
            </MudText>
        }

        @if (ShowAddToCart)
        {
            <MudDivider Class="my-3" />

            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                <MudStack Spacing="0">
                    <MudText Typo="Typo.h6" Class="product-price">
                        @Product.Price.ToString("C")
                    </MudText>
                    <StockBadge Stock="Product.Stock" TextTypo="Typo.caption" IconSize="14px" />
                </MudStack>

                <span @onclick:stopPropagation="true">
                    <MudIconButton Icon="@Icons.Material.Filled.AddShoppingCart"
                                   aria-label="@($"{Product.Name} in den Warenkorb")"
                                   Disabled="@(Product.Stock == 0)"
                                   OnClick="HandleAdd"
                                   Color="Color.Primary"
                                   Variant="Variant.Filled"
                                   Size="Size.Medium"
                                   Style="border-radius: 50%;" />
                </span>
            </MudStack>
        }
        else
        {
            <MudText Typo="Typo.h6" Class="product-price" Style="margin-top: 12px;">
                @Product.Price.ToString("C")
            </MudText>
        }
    </div>
</MudPaper>

@code {
    [Parameter, EditorRequired] public ProductDto Product { get; set; } = default!;
    [Parameter] public EventCallback<ProductDto> OnOpen { get; set; }
    [Parameter] public EventCallback<ProductDto> OnAdd { get; set; }
    [Parameter] public bool ShowAddToCart { get; set; } = true;
    [Parameter] public bool ShowCategory { get; set; }
    [Parameter] public bool ShowDescription { get; set; } = true;
    [Parameter] public bool Compact { get; set; }

    private Task HandleOpen() => OnOpen.InvokeAsync(Product);
    private Task HandleAdd() => OnAdd.InvokeAsync(Product);
}

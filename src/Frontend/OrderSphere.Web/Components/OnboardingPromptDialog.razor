@inject IUserProfileClient UserProfile
@inject NavigationManager Nav
@inject IStringLocalizer<AppStrings> L

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">@L["OnboardingPrompt.Title"]</MudText>
    </TitleContent>
    <DialogContent>
        <MudText Typo="Typo.body2">@L["OnboardingPrompt.Message"]</MudText>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Text"
                   Disabled="_busy"
                   OnClick="SkipAsync">
            @L["OnboardingPrompt.Skip"]
        </MudButton>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   Class="btn-pill"
                   Disabled="_busy"
                   OnClick="Complete">
            @L["OnboardingPrompt.Complete"]
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    private bool _busy;

    private void Complete()
    {
        MudDialog.Close(DialogResult.Ok(true));
        Nav.NavigateTo("/onboarding");
    }

    private async Task SkipAsync()
    {
        _busy = true;
        try
        {
            await UserProfile.SkipOnboardingAsync();
        }
        finally
        {
            _busy = false;
        }
        MudDialog.Close(DialogResult.Ok(false));
    }
}

@using OrderSphere.UI.Configuration
@using OrderSphere.UI.Services
@using Microsoft.AspNetCore.Components.Authorization
@inject IThemeService ThemeService
@implements IDisposable

<MudAppBar Elevation="0" Fixed="true" Class="header-appbar">

    <MudHidden Breakpoint="Breakpoint.MdAndUp">
        <MudIconButton Icon="@Icons.Material.Filled.Menu"
                       OnClick="ToggleDrawer"
                       aria-label="Menü öffnen"
                       Color="Color.Default" />
    </MudHidden>

    <MudLink Href="/" Underline="Underline.None">
        <MudText Typo="Typo.h6" Style="color: var(--mud-palette-text-primary); font-weight: 700;">
            OrderSphere
        </MudText>
    </MudLink>

    <MudSpacer />

    <MudHidden Breakpoint="Breakpoint.SmAndDown">
        <MudButton Variant="Variant.Text" Href="/shop" Color="Color.Default">Shop</MudButton>
        <MudButton Variant="Variant.Text" Href="/categories" Color="Color.Default">Kategorien</MudButton>
        <MudButton Variant="Variant.Text" Href="/offers" Color="Color.Default">Angebote</MudButton>
    </MudHidden>

    <MudSpacer />

    <MudTooltip Text="@(ThemeService.IsDarkMode ? "Helles Design" : "Dunkles Design")">
        <MudIconButton Icon="@(ThemeService.IsDarkMode ? Icons.Material.Outlined.LightMode : Icons.Material.Outlined.DarkMode)"
                       Color="Color.Default"
                       Class="theme-toggle"
                       aria-label="@(ThemeService.IsDarkMode ? "Helles Design aktivieren" : "Dunkles Design aktivieren")"
                       OnClick="ToggleThemeAsync" />
    </MudTooltip>

    <MudIconButton Icon="@Icons.Material.Outlined.Search"
                   Href="/search"
                   aria-label="Suche öffnen"
                   Color="Color.Default" />

    <MudBadge Content="@CartItemCount" Color="Color.Error" Overlap="true" Visible="@(CartItemCount > 0)">
        <MudIconButton Icon="@Icons.Material.Outlined.ShoppingCart"
                       OnClick="OnCartToggle"
                       aria-label="@($"Warenkorb mit {CartItemCount} Artikeln öffnen")"
                       Color="Color.Default" />
    </MudBadge>

    <AuthorizeView>
        <Authorized>
            <MudMenu Icon="@Icons.Material.Outlined.AccountCircle"
                     Color="Color.Default"
                     Variant="Variant.Text"
                     AnchorOrigin="Origin.BottomRight"
                     TransformOrigin="Origin.TopRight"
                     aria-label="Konto-Menü"
                     Dense="true">

                <div class="pa-4" style="border-bottom: 1px solid var(--mud-palette-divider); min-width: 220px;">
                    <MudText Typo="Typo.body1" Style="font-weight: 600;">
                        @context.User.FindFirst("FirstName")?.Value @context.User.FindFirst("LastName")?.Value
                    </MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        @context.User.Identity?.Name
                    </MudText>
                </div>

                <MudMenuItem Icon="@Icons.Material.Outlined.Person" Href="/account/profile">
                    Mein Profil
                </MudMenuItem>
                <MudMenuItem Icon="@Icons.Material.Outlined.ShoppingBag" Href="/account/orders">
                    Meine Bestellungen
                </MudMenuItem>
                <MudMenuItem Icon="@Icons.Material.Outlined.Settings" Href="/account/settings">
                    Einstellungen
                </MudMenuItem>

                <MudDivider />

                <MudMenuItem Icon="@Icons.Material.Outlined.Logout"
                             IconColor="Color.Error"
                             OnClick="HandleLogout">
                    <MudText Color="Color.Error">Abmelden</MudText>
                </MudMenuItem>

            </MudMenu>
        </Authorized>
        <NotAuthorized>
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Primary"
                       Href="/account/login"
                       Class="btn-pill ml-2"
                       Style="padding: 6px 20px !important;">
                Anmelden
            </MudButton>
        </NotAuthorized>
    </AuthorizeView>

</MudAppBar>

<MobileDrawer IsOpen="_drawerOpen" IsOpenChanged="val => _drawerOpen = val" />

@code {
    protected override void OnInitialized()
    {
        ThemeService.OnChange += OnThemeChanged;
    }

    private void OnThemeChanged() => InvokeAsync(StateHasChanged);

    private Task ToggleThemeAsync() => ThemeService.ToggleAsync();

    public void Dispose()
    {
        ThemeService.OnChange -= OnThemeChanged;
    }
}

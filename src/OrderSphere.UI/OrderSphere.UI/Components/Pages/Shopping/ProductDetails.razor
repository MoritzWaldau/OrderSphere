@page "/shop/{CategoryName}/{Slug}"
@attribute [Authorize]
@inherits OrderSphereComponentBase
@rendermode InteractiveServer

@using OrderSphere.UI.Components.Component.Loading

<PageTitle>@(_product?.Name ?? "Produkt") – OrderSphere</PageTitle>

<LoadingWrapper IsLoading="IsLoading">
    <Loading>
        <ProductDetailSkeleton />
    </Loading>
    <ChildContent>
        @if (_product is not null)
        {
            <section class="section-white" style="padding-top: 32px; padding-bottom: 80px;">
                <MudContainer>
                    <MudGrid Spacing="6">

                        <MudItem xs="12" md="7">
                            <ProductImage ImageUrl="@_product.ImageUrl"
                                          Alt="@_product.Name"
                                          Size="ProductImage.ImageSize.Detail" />
                        </MudItem>

                        <MudItem xs="12" md="5">
                            <div>

                                @if (!string.IsNullOrEmpty(_product.CategoryName))
                                {
                                    <MudChip T="string" Color="Color.Primary" Size="Size.Small"
                                             Variant="Variant.Text" Class="mb-2 px-0"
                                             Style="font-size:13px; font-weight:600; letter-spacing:0.02em;">
                                        @_product.CategoryName
                                    </MudChip>
                                }

                                <MudText Typo="Typo.h4" Style="font-weight:700; line-height:1.2; margin-bottom:12px;">
                                    @_product.Name
                                </MudText>

                                <div class="d-flex align-center gap-2 mb-4">
                                    <MudRating ReadOnly="true" SelectedValue="4" Size="Size.Small" />
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                                        4.0 (128 Bewertungen)
                                    </MudText>
                                </div>

                                <MudText Typo="Typo.h4" Class="text-primary-color" Style="font-weight:700;">
                                    @_product.Price.ToString("C")
                                </MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                    inkl. MwSt., zzgl. Versand
                                </MudText>

                                <MudDivider Class="my-4" />

                                <div class="mb-4">
                                    <StockBadge Stock="_product.Stock" />
                                </div>

                                <div class="d-flex align-center gap-3 mb-3">
                                    <QuantityStepper Value="_quantity"
                                                     ValueChanged="value => _quantity = value"
                                                     Min="1"
                                                     Max="@_product.Stock" />

                                    <MudButton Variant="Variant.Filled"
                                               Color="Color.Primary"
                                               Class="btn-pill flex-grow-1"
                                               Style="height:48px; font-size:15px;"
                                               StartIcon="@Icons.Material.Filled.ShoppingCart"
                                               Disabled="@(_product.Stock == 0)"
                                               OnClick="AddToCartAsync">
                                        In den Warenkorb
                                    </MudButton>
                                </div>

                                <MudButton Variant="Variant.Outlined"
                                           Color="Color.Default"
                                           Class="btn-pill"
                                           FullWidth="true"
                                           Style="height:48px; font-size:15px; border-color:var(--mud-palette-divider);"
                                           StartIcon="@(_wishlisted ? Icons.Material.Filled.Favorite : Icons.Material.Outlined.FavoriteBorder)"
                                           OnClick="ToggleWishlist">
                                    @(_wishlisted ? "Auf Wunschliste" : "Zur Wunschliste")
                                </MudButton>

                                <MudDivider Class="my-4" />

                                <MudGrid Spacing="2">
                                    <MudItem xs="4">
                                        <div class="d-flex flex-column align-center text-center gap-1">
                                            <MudIcon Icon="@Icons.Material.Outlined.LocalShipping"
                                                     Color="Color.Primary" />
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                Kostenloser<br />Versand
                                            </MudText>
                                        </div>
                                    </MudItem>
                                    <MudItem xs="4">
                                        <div class="d-flex flex-column align-center text-center gap-1">
                                            <MudIcon Icon="@Icons.Material.Outlined.Replay"
                                                     Color="Color.Primary" />
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                30 Tage<br />Rückgabe
                                            </MudText>
                                        </div>
                                    </MudItem>
                                    <MudItem xs="4">
                                        <div class="d-flex flex-column align-center text-center gap-1">
                                            <MudIcon Icon="@Icons.Material.Outlined.Shield"
                                                     Color="Color.Primary" />
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                2 Jahre<br />Garantie
                                            </MudText>
                                        </div>
                                    </MudItem>
                                </MudGrid>
                            </div>
                        </MudItem>
                    </MudGrid>
                </MudContainer>
            </section>
        }
        else
        {
            <div class="d-flex flex-column align-center justify-center" style="height:60vh; gap:16px;">
                <MudIcon Icon="@Icons.Material.Filled.SearchOff"
                         Color="Color.Secondary"
                         Style="font-size:64px;" />
                <MudText Typo="Typo.h5" Style="font-weight:600;">
                    Produkt nicht gefunden
                </MudText>
                <MudText Color="Color.Secondary">
                    Das Produkt existiert nicht oder wurde entfernt.
                </MudText>
                <MudButton Href="/shop" Variant="Variant.Filled" Color="Color.Primary" Class="btn-pill mt-2">
                    Zurück zu Produkten
                </MudButton>
            </div>
        }
    </ChildContent>
</LoadingWrapper>

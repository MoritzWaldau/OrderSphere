{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*",
  "Keycloak": {
    "Authority": "http://localhost:8080/realms/ordersphere",
    "ClientId": "web-bff",
    "ClientSecret": "web-bff-dev-secret-change-in-prod"
  },
  "ReverseProxy": {
    "Routes": {
      "to-gateway": {
        "ClusterId": "api-gateway",
        "Match": {
          "Path": "/api/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "api-gateway": {
        "Destinations": {
          "gateway-default": {
            "Address": "http://ordersphere-apigateway"
          }
        }
      }
    }
  }
}

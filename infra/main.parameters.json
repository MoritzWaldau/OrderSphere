{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
      "principalId": {
        "value": "${AZURE_PRINCIPAL_ID}"
      },
      "bff_client_secret": {
        "value": "${AZURE_BFF_CLIENT_SECRET}"
      },
      "keycloak_admin_password": {
        "value": "${AZURE_KEYCLOAK_ADMIN_PASSWORD}"
      },
      "keycloak_realm_authority": {
        "value": "${AZURE_KEYCLOAK_REALM_AUTHORITY}"
      },
      "notification_worker_secret": {
        "value": "${AZURE_NOTIFICATION_WORKER_SECRET}"
      },
      "ordering_worker_secret": {
        "value": "${AZURE_ORDERING_WORKER_SECRET}"
      },
      "payment_bypass_providers": {
        "value": "${AZURE_PAYMENT_BYPASS_PROVIDERS}"
      },
      "payment_worker_secret": {
        "value": "${AZURE_PAYMENT_WORKER_SECRET}"
      },
      "environmentName": {
        "value": "${AZURE_ENV_NAME}"
      },
      "location": {
        "value": "${AZURE_LOCATION}"
      }
    }
  }
  
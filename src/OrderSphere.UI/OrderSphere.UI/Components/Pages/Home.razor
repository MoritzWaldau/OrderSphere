@page "/"

<!-- HERO -->
<section class="section-hero">
    <MudContainer>
        <MudStack AlignItems="AlignItems.Center" Spacing="4">
            <MudText Typo="Typo.h1" Align="Align.Center" Style="color: #FFFFFF;">
                Die beste Tech.<br />Zum besten Preis.
            </MudText>
            <MudText Typo="Typo.h5" Align="Align.Center"
                     Style="color: rgba(255,255,255,0.85); font-weight: 400; max-width: 600px;">
                Laptops, Tablets und Zubehör – schnell, zuverlässig und smart geliefert.
            </MudText>
            <MudStack Row="true" Spacing="3" Class="mt-4">
                <MudButton Variant="Variant.Filled"
                           Size="Size.Large"
                           Href="/products"
                           Class="btn-pill-white">
                    Jetzt entdecken
                </MudButton>
                <MudButton Variant="Variant.Outlined"
                           Size="Size.Large"
                           Href="/products"
                           Class="btn-pill-outline-white">
                    Mehr erfahren
                </MudButton>
            </MudStack>
        </MudStack>
    </MudContainer>
</section>

<!-- KATEGORIEN -->
<section class="section-gray">
    <MudContainer>
        <MudText Typo="Typo.h3" Align="Align.Center" GutterBottom="true">
            Kategorien
        </MudText>
        <MudText Typo="Typo.body1" Align="Align.Center" Color="Color.Secondary" Class="mb-8">
            Finde genau das Gerät das du suchst
        </MudText>
        <MudGrid Justify="Justify.Center">
            @foreach (var category in _categories)
            {
                <MudItem xs="6" sm="3">
                    <MudPaper Class="pa-6 text-center category-card" Elevation="0">
                        <MudText Style="font-size: 2.5rem;">@category.Icon</MudText>
                        <MudText Typo="Typo.subtitle1" Class="mt-2" Style="font-weight: 600;">
                            @category.Name
                        </MudText>
                    </MudPaper>
                </MudItem>
            }
        </MudGrid>
    </MudContainer>
</section>

<!-- BENEFITS -->
<section class="section-white">
    <MudContainer>
        <MudText Typo="Typo.h3" Align="Align.Center" GutterBottom="true">
            Warum OrderSphere?
        </MudText>
        <MudText Typo="Typo.body1" Align="Align.Center" Color="Color.Secondary" Class="mb-8">
            Wir machen Shopping einfach und sicher
        </MudText>
        <MudGrid>
            @foreach (var benefit in _benefits)
            {
                <MudItem xs="6" sm="3">
                    <MudPaper Class="pa-6 text-center category-card" Elevation="0">
                        <MudText Style="font-size: 2.5rem;">@benefit.Icon</MudText>
                        <MudText Typo="Typo.h6" Class="mt-3">@benefit.Title</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-1">
                            @benefit.Description
                        </MudText>
                    </MudPaper>
                </MudItem>
            }
        </MudGrid>
    </MudContainer>
</section>

<!-- AI SECTION -->
<section class="section-dark">
    <MudContainer>
        <MudStack AlignItems="AlignItems.Center" Spacing="3">
            <MudText Style="font-size: 2.5rem;">🤖</MudText>
            <MudText Typo="Typo.h3" Align="Align.Center" Style="color: #F5F5F7;">
                Dein persönlicher AI Assistant
            </MudText>
            <MudText Typo="Typo.body1" Align="Align.Center" Style="color: #98989D; max-width: 500px;">
                Nicht sicher welches Gerät zu dir passt? Unser AI Assistant berät dich in Echtzeit.
            </MudText>
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       Size="Size.Large"
                       Class="btn-pill mt-2">
                Chat starten
            </MudButton>
        </MudStack>
    </MudContainer>
</section>

<!-- CTA -->
<section class="section-cta">
    <MudContainer>
        <MudStack AlignItems="AlignItems.Center" Spacing="3">
            <MudText Typo="Typo.h2" Align="Align.Center" Style="color: #FFFFFF;">
                Bereit zu shoppen?
            </MudText>
            <MudText Typo="Typo.body1" Align="Align.Center" Style="color: rgba(255,255,255,0.8);">
                Entdecke hunderte von IT-Geräten zu unschlagbaren Preisen.
            </MudText>
            <MudButton Variant="Variant.Filled"
                       Size="Size.Large"
                       Href="/products"
                       Class="btn-pill-white mt-2">
                Jetzt starten
            </MudButton>
        </MudStack>
    </MudContainer>
</section>

@code {
    private readonly List<CategoryItem> _categories =
    [
        new("💻", "Laptops"),
        new("📱", "Smartphones"),
        new("📟", "Tablets"),
        new("🎧", "Zubehör"),
    ];

    private readonly List<BenefitItem> _benefits =
    [
        new("🚚", "Schneller Versand", "Lieferung in 1-2 Werktagen direkt zu dir."),
        new("🔒", "Sichere Zahlung", "SSL-verschlüsselt und DSGVO-konform."),
        new("⭐", "Top Qualität", "Nur geprüfte Markenprodukte im Sortiment."),
        new("🤖", "AI Support", "24/7 Beratung durch unseren AI Assistant."),
    ];

    private record CategoryItem(string Icon, string Name);
    private record BenefitItem(string Icon, string Title, string Description);
}
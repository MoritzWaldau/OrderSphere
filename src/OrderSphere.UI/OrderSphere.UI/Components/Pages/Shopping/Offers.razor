@page "/offers"
@layout MainLayout

<PageTitle>Angebote — OrderSphere</PageTitle>

<section class="section-hero">
    <MudContainer MaxWidth="MaxWidth.Medium">
        <MudStack AlignItems="AlignItems.Center" Spacing="4" Class="text-center">
            <MudIcon Icon="@Icons.Material.Outlined.LocalOffer"
                     Style="font-size: 100px; color: rgba(255,255,255,0.95);" />
            <MudText Typo="Typo.h1"
                     Style="color: #FFFFFF; font-weight: 700; letter-spacing: -0.04em;">
                Aktuelle Angebote
            </MudText>
            <MudText Typo="Typo.h5"
                     Style="color: rgba(255,255,255,0.85); font-weight: 400; max-width: 600px;">
                Spare bei ausgewählten Produkten — limitiert verfügbar.
            </MudText>
            <MudButton Variant="Variant.Filled"
                       Size="Size.Large"
                       Href="/shop"
                       StartIcon="@Icons.Material.Outlined.Storefront"
                       Class="btn-pill-white mt-4">
                Zum Shop
            </MudButton>
        </MudStack>
    </MudContainer>
</section>

<section style="background: #F5F5F7; padding: 60px 0;">
    <MudContainer>
        <MudText Typo="Typo.h4" Align="Align.Center" Class="mb-2" Style="font-weight: 600;">
            Bald hier verfügbar
        </MudText>
        <MudText Typo="Typo.body1" Align="Align.Center" Color="Color.Secondary" Class="mb-8">
            Wir arbeiten an unseren Aktionen. Bis dahin lohnt sich ein Blick in den Shop.
        </MudText>

        <MudGrid Spacing="4" Justify="Justify.Center">
            <MudItem xs="12" sm="6" md="4">
                <MudPaper Elevation="0" Class="pa-6 text-center"
                          Style="border-radius: 16px; border: 1px solid var(--mud-palette-divider); background: #FFFFFF; height: 100%;">
                    <MudIcon Icon="@Icons.Material.Outlined.Bolt"
                             Color="Color.Primary"
                             Style="font-size: 56px;" Class="mb-3" />
                    <MudText Typo="Typo.h6" Style="font-weight: 600;">Blitz-Deals</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-2">
                        Reduzierte Produkte für nur 24 Stunden.
                    </MudText>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" sm="6" md="4">
                <MudPaper Elevation="0" Class="pa-6 text-center"
                          Style="border-radius: 16px; border: 1px solid var(--mud-palette-divider); background: #FFFFFF; height: 100%;">
                    <MudIcon Icon="@Icons.Material.Outlined.CardGiftcard"
                             Color="Color.Primary"
                             Style="font-size: 56px;" Class="mb-3" />
                    <MudText Typo="Typo.h6" Style="font-weight: 600;">Bundle-Rabatte</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-2">
                        Spare beim Kauf mehrerer passender Produkte.
                    </MudText>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" sm="6" md="4">
                <MudPaper Elevation="0" Class="pa-6 text-center"
                          Style="border-radius: 16px; border: 1px solid var(--mud-palette-divider); background: #FFFFFF; height: 100%;">
                    <MudIcon Icon="@Icons.Material.Outlined.Loyalty"
                             Color="Color.Primary"
                             Style="font-size: 56px;" Class="mb-3" />
                    <MudText Typo="Typo.h6" Style="font-weight: 600;">Treue-Vorteile</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-2">
                        Exklusive Rabatte für registrierte Kunden.
                    </MudText>
                </MudPaper>
            </MudItem>
        </MudGrid>
    </MudContainer>
</section>

@page "/"
@using Microsoft.AspNetCore.Components.Authorization

<PageTitle>OrderSphere</PageTitle>

<!-- HERO -->
<PageHero Variant="PageHero.PageHeroVariant.Hero"
          Title="Die beste Tech. Zum besten Preis."
          Subtitle="Laptops, Tablets und Zubehör – schnell, zuverlässig und smart geliefert.">
    <ChildContent>
        <MudStack Row="true" Spacing="3" Justify="Justify.Center" Wrap="Wrap.Wrap">
            <MudButton Variant="Variant.Filled"
                       Size="Size.Large"
                       Href="/shop"
                       Class="btn-pill-white">
                Jetzt entdecken
            </MudButton>
            <MudButton Variant="Variant.Outlined"
                       Size="Size.Large"
                       Href="/categories"
                       Class="btn-pill-outline-white">
                Kategorien ansehen
            </MudButton>
        </MudStack>
    </ChildContent>
</PageHero>

<!-- KATEGORIEN -->
<section class="section-gray">
    <MudContainer>
        <MudText Typo="Typo.h3" Align="Align.Center" GutterBottom="true">
            Kategorien
        </MudText>
        <MudText Typo="Typo.body1" Align="Align.Center" Color="Color.Secondary" Class="mb-8">
            Finde genau das Gerät, das du suchst.
        </MudText>
        <MudGrid Justify="Justify.Center">
            @foreach (var category in _categories)
            {
                <MudItem xs="6" sm="3">
                    <MudPaper Class="pa-6 text-center category-card" Elevation="0">
                        <MudIcon Icon="@category.Icon"
                                 Color="Color.Primary"
                                 Style="font-size: 48px;" />
                        <MudText Typo="Typo.subtitle1" Class="mt-2" Style="font-weight: 600;">
                            @category.Name
                        </MudText>
                    </MudPaper>
                </MudItem>
            }
        </MudGrid>
    </MudContainer>
</section>

<!-- BENEFITS -->
<section class="section-white">
    <MudContainer>
        <MudText Typo="Typo.h3" Align="Align.Center" GutterBottom="true">
            Warum OrderSphere?
        </MudText>
        <MudText Typo="Typo.body1" Align="Align.Center" Color="Color.Secondary" Class="mb-8">
            Wir machen Shopping einfach und sicher.
        </MudText>
        <MudGrid>
            @foreach (var benefit in _benefits)
            {
                <MudItem xs="6" sm="3">
                    <MudPaper Class="pa-6 text-center category-card" Elevation="0">
                        <MudIcon Icon="@benefit.Icon"
                                 Color="Color.Primary"
                                 Style="font-size: 48px;" />
                        <MudText Typo="Typo.h6" Class="mt-3">@benefit.Title</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-1">
                            @benefit.Description
                        </MudText>
                    </MudPaper>
                </MudItem>
            }
        </MudGrid>
    </MudContainer>
</section>

<!-- AI SECTION -->
<section class="section-dark">
    <MudContainer>
        <MudStack AlignItems="AlignItems.Center" Spacing="3">
            <MudIcon Icon="@Icons.Material.Outlined.AutoAwesome"
                     Style="font-size: 56px; color: var(--mud-palette-secondary-contrast-text);" />
            <MudText Typo="Typo.h3" Align="Align.Center"
                     Style="color: var(--mud-palette-secondary-contrast-text);">
                Dein persönlicher AI Assistant
            </MudText>
            <MudText Typo="Typo.body1" Align="Align.Center"
                     Style="color: var(--mud-palette-secondary-contrast-text); opacity: 0.7; max-width: 500px;">
                Nicht sicher, welches Gerät zu dir passt? Unser AI Assistant berät dich in Echtzeit.
            </MudText>
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       Size="Size.Large"
                       Href="/assistant"
                       Class="btn-pill mt-2">
                Chat starten
            </MudButton>
        </MudStack>
    </MudContainer>
</section>

<!-- CTA -->
<section class="section-cta">
    <MudContainer>
        <MudStack AlignItems="AlignItems.Center" Spacing="3">
            <MudText Typo="Typo.h2" Align="Align.Center" Class="hero-title">
                Bereit zu shoppen?
            </MudText>
            <MudText Typo="Typo.body1" Align="Align.Center" Class="hero-subtitle-muted">
                Entdecke hunderte von IT-Geräten zu unschlagbaren Preisen.
            </MudText>
            <MudButton Variant="Variant.Filled"
                       Size="Size.Large"
                       Href="/shop"
                       Class="btn-pill-white mt-2">
                Jetzt starten
            </MudButton>
        </MudStack>
    </MudContainer>
</section>

@code {
    private readonly List<CategoryItem> _categories =
    [
        new(Icons.Material.Outlined.Laptop, "Laptops"),
        new(Icons.Material.Outlined.PhoneIphone, "Smartphones"),
        new(Icons.Material.Outlined.Tablet, "Tablets"),
        new(Icons.Material.Outlined.Headphones, "Zubehör"),
    ];

    private readonly List<BenefitItem> _benefits =
    [
        new(Icons.Material.Outlined.LocalShipping, "Schneller Versand", "Lieferung in 1–2 Werktagen direkt zu dir."),
        new(Icons.Material.Outlined.Lock, "Sichere Zahlung", "SSL-verschlüsselt und DSGVO-konform."),
        new(Icons.Material.Outlined.Verified, "Top Qualität", "Nur geprüfte Markenprodukte im Sortiment."),
        new(Icons.Material.Outlined.AutoAwesome, "AI Support", "24/7 Beratung durch unseren AI Assistant."),
    ];

    private record CategoryItem(string Icon, string Name);
    private record BenefitItem(string Icon, string Title, string Description);
}

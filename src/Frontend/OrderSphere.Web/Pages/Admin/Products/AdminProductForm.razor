@page "/admin/products/new"
@page "/admin/products/{ProductId:guid}"
@inject IAdminCatalogClient AdminCatalog
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject IStringLocalizer<AppStrings> L

<PageTitle>@(IsEdit ? L["Admin.ProductForm.PageTitleEdit"] : L["Admin.ProductForm.PageTitleCreate"])</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="py-8">
    <MudButton Variant="Variant.Text" StartIcon="@Icons.Material.Outlined.ArrowBack"
               Href="/admin/products" Class="mb-4">
        @L["Admin.ProductForm.BackToList"]
    </MudButton>

    <MudText Typo="Typo.h4" Class="mb-6" Style="font-weight: 700;">
        @(IsEdit ? L["Admin.ProductForm.TitleEdit"] : L["Admin.ProductForm.TitleCreate"])
    </MudText>

    @if (_loading)
    {
        <MudStack AlignItems="AlignItems.Center" Class="py-12">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
        </MudStack>
    }
    else
    {
        <MudPaper Elevation="0" Class="pa-6" Style="border-radius:16px;border:1px solid var(--mud-palette-divider);">
            <MudStack Spacing="4">
                <MudTextField @bind-Value="_model.Name" Label="@L["Admin.ProductForm.Name"]"
                              Variant="Variant.Outlined" Required="true"
                              RequiredError="@L["Admin.ProductForm.NameRequired"]" />

                <MudTextField @bind-Value="_model.SKU" Label="@L["Admin.ProductForm.SKU"]"
                              Variant="Variant.Outlined" Required="true"
                              RequiredError="@L["Admin.ProductForm.SKURequired"]" />

                <MudTextField @bind-Value="_model.Description" Label="@L["Admin.ProductForm.Description"]"
                              Variant="Variant.Outlined" Lines="3" />

                <MudGrid>
                    <MudItem xs="12" sm="6">
                        <MudNumericField @bind-Value="_model.Price" Label="@L["Admin.ProductForm.Price"]"
                                         Variant="Variant.Outlined" Min="0.01m" Step="0.01m" Format="F2"
                                         Culture="@System.Globalization.CultureInfo.CurrentCulture" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudNumericField @bind-Value="_model.Stock" Label="@L["Admin.ProductForm.Stock"]"
                                         Variant="Variant.Outlined" Min="0" />
                    </MudItem>
                </MudGrid>

                <MudSelect T="Guid" @bind-Value="_model.CategoryId" Label="@L["Admin.ProductForm.Category"]"
                           Variant="Variant.Outlined" Required="true" RequiredError="@L["Admin.ProductForm.CategoryRequired"]">
                    @foreach (var cat in _categories)
                    {
                        <MudSelectItem T="Guid" Value="@cat.Id">@cat.Name</MudSelectItem>
                    }
                </MudSelect>

                @if (IsEdit)
                {
                    <MudSwitch T="bool" @bind-Value="_model.IsActive"
                               Label="@L["Admin.ProductForm.ActiveLabel"]" Color="Color.Primary" />
                }

                <MudStack Row="true" Justify="Justify.FlexEnd" Spacing="2" Class="mt-2">
                    <MudButton Variant="Variant.Outlined" Href="/admin/products">@L["Common.Cancel"]</MudButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               StartIcon="@Icons.Material.Outlined.Save"
                               Disabled="_saving" OnClick="SaveAsync">
                        @(IsEdit ? L["Common.Save"] : L["Common.Create"])
                    </MudButton>
                </MudStack>
            </MudStack>
        </MudPaper>
    }
</MudContainer>

@code {
    [Parameter] public Guid? ProductId { get; set; }

    private bool IsEdit => ProductId.HasValue;
    private bool _loading = true;
    private bool _saving;
    private List<AdminCategoryDto> _categories = [];
    private ProductModel _model = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var cats = await AdminCatalog.GetCategoriesAsync();
            if (cats.IsSuccess) _categories = cats.Value!;
            else Snackbar.Add(cats.Error!.Message, Severity.Error);
            if (IsEdit)
            {
                var p = (await AdminCatalog.GetProductByIdAsync(ProductId!.Value)).Value;
                if (p is not null)
                    _model = new ProductModel { Name = p.Name, SKU = p.SKU, Description = p.Description, Price = p.Price, Stock = p.Stock, CategoryId = p.CategoryId, IsActive = p.IsActive };
            }
        }
        catch (Exception ex) { Snackbar.Add(L["Common.Error", ex.Message], Severity.Error); }
        finally { _loading = false; }
    }

    private async Task SaveAsync()
    {
        _saving = true;
        try
        {
            var input = new AdminProductInput(_model.Name, _model.Description, _model.Price, _model.Stock, _model.CategoryId, _model.SKU, _model.IsActive);
            if (IsEdit)
            {
                var result = await AdminCatalog.UpdateProductAsync(ProductId!.Value, input);
                if (result.IsSuccess) { Snackbar.Add(L["Admin.ProductForm.Saved"], Severity.Success); Navigation.NavigateTo("/admin/products"); }
                else Snackbar.Add(result.Error!.Message, Severity.Error);
            }
            else
            {
                var result = await AdminCatalog.CreateProductAsync(input);
                if (result.IsSuccess) { Snackbar.Add(L["Admin.ProductForm.Created"], Severity.Success); Navigation.NavigateTo("/admin/products"); }
                else Snackbar.Add(result.Error!.Message, Severity.Error);
            }
        }
        finally { _saving = false; }
    }

    private sealed class ProductModel
    {
        public string Name { get; set; } = string.Empty;
        public string SKU { get; set; } = string.Empty;
        public string Description { get; set; } = string.Empty;
        public decimal Price { get; set; } = 0.01m;
        public int Stock { get; set; }
        public Guid CategoryId { get; set; }
        public bool IsActive { get; set; } = true;
    }
}

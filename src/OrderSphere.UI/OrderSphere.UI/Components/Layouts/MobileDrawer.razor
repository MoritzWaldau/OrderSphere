<MudDrawer @bind-Open="IsOpen"
           Anchor="Anchor.Left"
           Elevation="0"
           Variant="DrawerVariant.Temporary"
           CloseOnEscapeKey="true">

    <div class="pa-6 d-flex align-center justify-space-between" style="border-bottom: 1px solid var(--mud-palette-divider);">
        <MudLink Href="/" Underline="Underline.None">
            <MudText Typo="Typo.h6" Style="font-weight: 700;">OrderSphere</MudText>
        </MudLink>
        <MudIconButton Icon="@Icons.Material.Filled.Close"
                       OnClick="@(() => IsOpenChanged.InvokeAsync(false))"
                       aria-label="Menü schließen"
                       Class="mud-background-gray rounded-circle" />
    </div>

    <div class="pa-3 flex-grow-1">
        <MudText Typo="Typo.overline" Color="Color.Secondary" Class="px-3 pb-2">
            Menü
        </MudText>

        @foreach (var item in _navItems)
        {
            <MudLink Href="@item.Href" Underline="Underline.None" Class="mobile-nav-item">
                <MudIcon Icon="@item.Icon" Color="Color.Primary" Class="mr-3" />
                <MudText Typo="Typo.body1" Style="font-weight: 500; color: var(--mud-palette-text-primary);">
                    @item.Label
                </MudText>
            </MudLink>
        }

        <MudDivider Class="my-3" />

        <MudText Typo="Typo.overline" Color="Color.Secondary" Class="px-3 pb-2">
            Konto
        </MudText>

        @foreach (var item in _accountItems)
        {
            <MudLink Href="@item.Href" Underline="Underline.None" Class="mobile-nav-item">
                <MudIcon Icon="@item.Icon" Color="Color.Secondary" Class="mr-3" />
                <MudText Typo="Typo.body1" Style="font-weight: 500; color: var(--mud-palette-text-primary);">
                    @item.Label
                </MudText>
            </MudLink>
        }
    </div>

    <div class="pa-4" style="border-top: 1px solid var(--mud-palette-divider);">
        <MudText Typo="Typo.caption" Color="Color.Secondary">
            © @DateTime.Now.Year OrderSphere
        </MudText>
    </div>

</MudDrawer>

@code {
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public EventCallback<bool> IsOpenChanged { get; set; }

    private readonly List<NavItem> _navItems =
    [
        new(Icons.Material.Filled.Home, "Startseite", "/"),
        new(Icons.Material.Filled.Devices, "Shop", "/shop"),
        new(Icons.Material.Filled.Category, "Kategorien", "/categories"),
        new(Icons.Material.Filled.LocalOffer, "Angebote", "/offers"),
    ];

    private readonly List<NavItem> _accountItems =
    [
        new(Icons.Material.Filled.ShoppingCart, "Warenkorb", "/cart"),
        new(Icons.Material.Filled.AccountCircle, "Mein Konto", "/account"),
    ];

    private record NavItem(string Icon, string Label, string Href);
}
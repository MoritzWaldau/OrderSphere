<MudPopover Open="IsOpen"
            AnchorOrigin="Origin.BottomCenter"
            TransformOrigin="Origin.TopCenter"
            Paper="true"
            Class="pa-4"
            Style="width: 220px;">

    <MudText Typo="Typo.subtitle1" Class="mb-3">Anzahl wählen</MudText>

    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.Center" Spacing="2">
        <MudIconButton Icon="@Icons.Material.Filled.Remove"
                       Size="Size.Small"
                       Variant="Variant.Outlined"
                       OnClick="Decrease" />
        <MudText Typo="Typo.h6" Style="min-width: 32px; text-align: center;">
            @Quantity
        </MudText>
        <MudIconButton Icon="@Icons.Material.Filled.Add"
                       Size="Size.Small"
                       Variant="Variant.Outlined"
                       OnClick="Increase" />
    </MudStack>

    <MudStack Row="true" Class="mt-4" Spacing="2">
        <MudButton Variant="Variant.Text"
                   Color="Color.Default"
                   FullWidth="true"
                   OnClick="OnCancelAsync">
            Abbrechen
        </MudButton>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   FullWidth="true"
                   OnClick="OnConfirmAsync">
            Hinzufügen
        </MudButton>
    </MudStack>

</MudPopover>

@code {
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public int MaxQuantity { get; set; } = 99;
    [Parameter] public EventCallback OnCancel { get; set; }
    [Parameter] public EventCallback<int> OnConfirm { get; set; }

    private int Quantity { get; set; } = 1;

    private void Increase()
    {
        if (Quantity < MaxQuantity) Quantity++;
    }

    private void Decrease()
    {
        if (Quantity > 1) Quantity--;
    }

    private async Task OnConfirmAsync()
    {
        await OnConfirm.InvokeAsync(Quantity);
        Quantity = 1;
    }

    private async Task OnCancelAsync()
    {
        Quantity = 1;
        await OnCancel.InvokeAsync();
    }
}
@implements IDisposable
@using System.Text.Json
@inject IAdvisorClient Advisor
@inject ILogger<AdvisorDrawer> Logger
@inject NavigationManager Nav
@inject IJSRuntime JS

<MudDrawer @bind-Open="IsOpen"
           Anchor="Anchor.Right"
           Elevation="2"
           Variant="DrawerVariant.Temporary"
           Width="420px"
           ClipMode="DrawerClipMode.Never">

    <div style="padding:24px;height:100%;display:flex;flex-direction:column;gap:16px;">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
            <MudText Typo="Typo.h6" Style="font-weight:600;">Berater</MudText>
            <MudStack Row="true" Spacing="0" AlignItems="AlignItems.Center">
                <MudIconButton Icon="@Icons.Material.Outlined.Add"
                               OnClick="NewChat" Size="Size.Small" title="Neue Unterhaltung" />
                <MudIconButton Icon="@(_showHistory ? Icons.Material.Filled.History : Icons.Material.Outlined.History)"
                               OnClick="ToggleHistoryAsync" Size="Size.Small" title="Verlauf" />
                <MudIconButton Icon="@Icons.Material.Outlined.Close"
                               OnClick="Close" Size="Size.Small" />
            </MudStack>
        </MudStack>

        @if (_showHistory)
        {
            <div style="flex:1;overflow-y:auto;display:flex;flex-direction:column;gap:8px;">
                @if (_loadingHistory)
                {
                    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
                }
                else if (_conversations.Count == 0)
                {
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Center" Class="mt-4">
                        Noch keine gespeicherten Unterhaltungen.
                    </MudText>
                }
                else
                {
                    @foreach (var c in _conversations)
                    {
                        <MudPaper Elevation="0"
                                  Class="surface-card pa-3"
                                  Style="@($"cursor:pointer;{(c.ConversationId == _conversationId ? "border:1px solid var(--mud-palette-primary);" : string.Empty)}")"
                                  @onclick="@(() => SelectConversationAsync(c.ConversationId))">
                            <MudText Typo="Typo.body2" Style="font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">
                                @(string.IsNullOrWhiteSpace(c.LastMessage) ? "(leer)" : c.LastMessage)
                            </MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                @c.UpdatedAt.ToLocalTime().ToString("g") · @c.MessageCount Nachrichten
                            </MudText>
                        </MudPaper>
                    }
                }
            </div>
        }
        else
        {
            <div style="flex:1;min-height:0;overflow-y:auto;display:flex;flex-direction:column;">
                @if (_messages.Count == 0)
                {
                    <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Style="flex:1;padding:40px 0;">
                        <MudIcon Icon="@Icons.Material.Outlined.SupportAgent"
                                 Style="font-size:64px;color:var(--mud-palette-divider);" />
                        <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mt-3" Align="Align.Center">
                            Frag mich nach Produkten, deinen Bestellungen oder deinem Konto.
                        </MudText>
                    </MudStack>
                }
                else
                {
                    <div style="margin-top:auto;display:flex;flex-direction:column;gap:12px;">
                        @foreach (var m in _messages)
                        {
                            <MudPaper Elevation="0"
                                      Class="surface-card pa-3"
                                      Style="@(m.IsUser ? "align-self:flex-end;max-width:85%;background:var(--mud-palette-primary);color:#fff;" : "align-self:flex-start;max-width:85%;")">
                                <MudText Typo="Typo.body2" Style="white-space:pre-wrap;overflow-wrap:anywhere;">@m.Text</MudText>
                                @if (!m.IsUser && !string.IsNullOrEmpty(m.Text))
                                {
                                    <MudIconButton Icon="@Icons.Material.Outlined.VolumeUp"
                                                   Size="Size.Small"
                                                   Color="Color.Default"
                                                   title="Vorlesen"
                                                   Style="margin-top:2px;padding:2px;"
                                                   OnClick="@(() => SpeakAsync(m.Text))" />
                                }
                                @if (!m.IsUser && m.Citations is { Count: > 0 })
                                {
                                    <div style="margin-top:8px;display:flex;flex-wrap:wrap;gap:4px;">
                                        @foreach (var c in m.Citations)
                                        {
                                            <MudChip T="string"
                                                     Size="Size.Small"
                                                     Variant="Variant.Outlined"
                                                     Color="Color.Primary"
                                                     OnClick="@(() => NavigateToProduct(c.Slug))"
                                                     Style="cursor:pointer;">
                                                @c.Name
                                            </MudChip>
                                        }
                                    </div>
                                }
                            </MudPaper>
                        }
                        @if (_toolActivity is not null)
                        {
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Style="align-self:flex-start;">
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Primary" />
                                <MudText Typo="Typo.caption" Color="Color.Secondary">@_toolActivity…</MudText>
                            </MudStack>
                        }
                        @if (_pendingConfirm is not null)
                        {
                            <MudPaper Elevation="1" Class="pa-3 mt-1"
                                      Style="align-self:flex-start;max-width:100%;border-left:3px solid var(--mud-palette-primary);">
                                <MudText Typo="Typo.subtitle2" Style="font-weight:600;">In den Warenkorb legen?</MudText>
                                <MudText Typo="Typo.body2" Class="mt-1">@_pendingConfirm.Summary</MudText>
                                <MudStack Row="true" Spacing="2" Class="mt-3">
                                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                                               Disabled="_busy" OnClick="ConfirmAddToCartAsync">Bestätigen</MudButton>
                                    <MudButton Variant="Variant.Outlined" Size="Size.Small"
                                               Disabled="_busy" OnClick="CancelAddToCartAsync">Abbrechen</MudButton>
                                </MudStack>
                            </MudPaper>
                        }
                    </div>
                }
            </div>

            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                <MudTextField @bind-Value="_input"
                              Placeholder="Nachricht…"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Immediate="true"
                              OnKeyDown="OnKeyDown"
                              Disabled="_busy"
                              Style="flex:1;" />
                <MudIconButton Icon="@(_recording ? Icons.Material.Filled.MicOff : Icons.Material.Filled.Mic)"
                               Color="@(_recording ? Color.Error : Color.Default)"
                               OnClick="ToggleRecordingAsync"
                               Disabled="_busy && !_recording"
                               title="@(_recording ? "Aufnahme beenden" : "Spracheingabe")"
                               Style="@(_recording ? "animation:pulse 1s ease-in-out infinite;" : string.Empty)" />
                <MudIconButton Icon="@Icons.Material.Filled.Send"
                               Color="Color.Primary"
                               OnClick="SendAsync"
                               Disabled="@(_busy || string.IsNullOrWhiteSpace(_input))" />
            </MudStack>
        }
    </div>
</MudDrawer>

@code {
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public EventCallback<bool> IsOpenChanged { get; set; }

    private sealed class ChatMessage
    {
        public bool IsUser { get; init; }
        public string Text { get; set; } = string.Empty;
        public List<AdvisorCitationItem>? Citations { get; set; }
    }

    private readonly List<ChatMessage> _messages = [];
    private List<AdvisorConversation> _conversations = [];
    private string _conversationId = Guid.NewGuid().ToString("n");
    private string _input = string.Empty;
    private string? _toolActivity;
    private AdvisorConfirmPayload? _pendingConfirm;
    private bool _busy;
    private bool _showHistory;
    private bool _loadingHistory;
    private bool _recording;
    private CancellationTokenSource? _cts;

    private static readonly JsonSerializerOptions JsonOpts = new(JsonSerializerDefaults.Web);

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
        {
            await SendAsync();
        }
    }

    private async Task SendAsync()
    {
        var text = _input?.Trim();
        if (string.IsNullOrEmpty(text) || _busy)
        {
            return;
        }

        _busy = true;
        _pendingConfirm = null;
        _input = string.Empty;
        _messages.Add(new ChatMessage { IsUser = true, Text = text });

        var reply = new ChatMessage { IsUser = false, Text = string.Empty };
        _messages.Add(reply);
        StateHasChanged();

        _cts = new CancellationTokenSource();
        try
        {
            await foreach (var item in Advisor.StreamAsync(_conversationId, text, _cts.Token))
            {
                if (item.Kind == AdvisorStreamItemKind.Tool)
                {
                    _toolActivity = item.Text;
                }
                else if (item.Kind == AdvisorStreamItemKind.Confirm)
                {
                    _toolActivity = null;
                    try
                    {
                        _pendingConfirm = JsonSerializer.Deserialize<AdvisorConfirmPayload>(item.Text, JsonOpts);
                    }
                    catch
                    {
                        // Malformed payload; fall back to showing raw text
                        reply.Text = item.Text;
                    }
                    if (_pendingConfirm is not null)
                        _messages.Remove(reply); // Remove empty assistant bubble
                }
                else if (item.Kind == AdvisorStreamItemKind.Citation)
                {
                    try
                    {
                        reply.Citations = JsonSerializer.Deserialize<List<AdvisorCitationItem>>(item.Text, JsonOpts);
                    }
                    catch
                    {
                        // Malformed citation payload — omit silently.
                    }
                }
                else
                {
                    _toolActivity = null;
                    reply.Text += item.Text;
                }
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            Logger.LogCritical(ex.Message);
            reply.Text = "Entschuldigung, der Berater ist gerade nicht erreichbar.";
        }
        finally
        {
            _toolActivity = null;
            _busy = false;
            StateHasChanged();
        }
    }

    private async Task ToggleHistoryAsync()
    {
        _showHistory = !_showHistory;
        if (_showHistory)
        {
            _loadingHistory = true;
            StateHasChanged();
            try
            {
                _conversations = [.. await Advisor.GetConversationsAsync()];
            }
            catch (Exception)
            {
                _conversations = [];
            }
            finally
            {
                _loadingHistory = false;
            }
        }
    }

    private async Task SelectConversationAsync(string conversationId)
    {
        _showHistory = false;
        _conversationId = conversationId;
        _messages.Clear();
        StateHasChanged();
        try
        {
            var history = await Advisor.GetMessagesAsync(conversationId);
            foreach (var m in history)
            {
                _messages.Add(new ChatMessage
                {
                    IsUser = string.Equals(m.Role, "user", StringComparison.OrdinalIgnoreCase),
                    Text = m.Text
                });
            }
        }
        catch (Exception)
        {
            // Leave the conversation empty if it can't be loaded.
        }
        StateHasChanged();
    }

    private void NewChat()
    {
        _showHistory = false;
        _conversationId = Guid.NewGuid().ToString("n");
        _messages.Clear();
        _input = string.Empty;
    }

    private async Task ConfirmAddToCartAsync()
    {
        if (_pendingConfirm is null) return;
        var confirm = _pendingConfirm;
        _pendingConfirm = null;
        _input = $"Bestätigt: {confirm.ProductName} (Menge: {confirm.Quantity}, slug={confirm.Slug})";
        await SendAsync();
    }

    private async Task CancelAddToCartAsync()
    {
        _pendingConfirm = null;
        _input = "Abbrechen, bitte nicht in den Warenkorb legen.";
        await SendAsync();
    }

    private void NavigateToProduct(string slug)
    {
        IsOpenChanged.InvokeAsync(false);
        Nav.NavigateTo($"/products/{slug}");
    }

    private async Task ToggleRecordingAsync()
    {
        if (_recording)
        {
            _recording = false;
            StateHasChanged();
            try
            {
                var wavBytes = await JS.InvokeAsync<byte[]>("advisorVoice.stopRecording");
                if (wavBytes is { Length: > 44 })
                {
                    var text = await Advisor.TranscribeAsync(wavBytes);
                    if (!string.IsNullOrWhiteSpace(text))
                    {
                        _input = text;
                        StateHasChanged();
                    }
                }
            }
            catch (Exception ex)
            {
                Logger.LogWarning(ex, "Voice transcription failed");
            }
        }
        else
        {
            try
            {
                await JS.InvokeVoidAsync("advisorVoice.startRecording");
                _recording = true;
            }
            catch (Exception ex)
            {
                Logger.LogWarning(ex, "Could not start recording — microphone access denied");
            }
        }
    }

    private async Task SpeakAsync(string text)
    {
        try
        {
            var audio = await Advisor.SynthesizeAsync(text);
            if (audio is { Length: > 0 })
            {
                var base64 = Convert.ToBase64String(audio);
                await JS.InvokeVoidAsync("advisorVoice.playAudio", base64);
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Voice synthesis failed");
        }
    }

    private void Close() => IsOpenChanged.InvokeAsync(false);

    public void Dispose() => _cts?.Cancel();
}

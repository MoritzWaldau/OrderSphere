@page "/shop"
@page "/shop/category/{category}"
@attribute [Authorize]
@rendermode InteractiveServer

@using Microsoft.AspNetCore.Authorization
@using OrderSphere.UI.Components.Component.Loading
@inherits OrderSphereComponentBase

<PageTitle>Produkte – OrderSphere</PageTitle>

<PageHero Title="Unsere Produkte"
          Subtitle="Entdecke unsere Auswahl an hochwertigen IT-Geräten." />

<section class="page-section">
    <MudContainer>

        <LoadingWrapper IsLoading="IsLoading">

            <Loading>
                <ProductsSkeleton />
            </Loading>

            <ChildContent>
                @if (!_products.Any())
                {
                    <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Style="min-height: 40vh;">
                        <MudIcon Icon="@Icons.Material.Outlined.Inventory2"
                                 Color="Color.Primary"
                                 Style="font-size: 80px;" />
                        <MudText Typo="Typo.h5">Keine Produkte vorhanden</MudText>
                        <MudText Typo="Typo.body1" Color="Color.Secondary">
                            Schau später nochmal vorbei.
                        </MudText>
                    </MudStack>
                }
                else
                {
                    <MudGrid>
                        @foreach (var product in _products)
                        {
                            <MudItem xs="12" sm="6" md="4">
                                <ProductCard Product="product"
                                             OnOpen="OpenDetails"
                                             OnAdd="OpenQuantityPopup" />
                            </MudItem>
                        }
                    </MudGrid>

                    <QuantityPopup IsOpen="_popupOpen"
                                   MaxQuantity="@(_selectedProduct?.Stock ?? 1)"
                                   OnCancel="ClosePopup"
                                   OnConfirm="ConfirmAddToCartAsync" />
                }
            </ChildContent>

        </LoadingWrapper>

    </MudContainer>
</section>

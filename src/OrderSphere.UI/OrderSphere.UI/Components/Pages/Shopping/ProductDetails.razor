@page "/shop/{CategoryName}/{Slug}"
@attribute [Authorize]
@inherits OrderSphereComponentBase
@rendermode InteractiveServer

@using OrderSphere.UI.Components.Component.Loading

<PageTitle>@(_product?.Name ?? "Produkt") – OrderSphere</PageTitle>

<LoadingWrapper IsLoading="IsLoading">
    <Loading>
        <ProductDetailSkeleton />
    </Loading>
    <ChildContent>
        @if (_product is not null)
        {
            <section style="padding: 48px 0 80px; background: var(--mud-palette-background);">
                <MudContainer MaxWidth="MaxWidth.Large">
                    <div style="display: grid; grid-template-columns: 1.2fr 1fr; gap: 64px; align-items: start;">

                        <!-- Image column -->
                        <div>
                            <MudPaper Elevation="0" Style="border-radius: 20px; overflow: hidden; background: var(--mud-palette-background-grey); height: 520px; display: flex; align-items: center; justify-content: center;">
                                <ProductImage ImageUrl="@_product.ImageUrl"
                                              Alt="@_product.Name"
                                              Size="ProductImage.ImageSize.Detail" />
                            </MudPaper>
                        </div>

                        <!-- Info column -->
                        <div style="position: sticky; top: 88px;">

                            @if (!string.IsNullOrEmpty(_product.CategoryName))
                            {
                                <MudChip T="string" Color="Color.Primary" Size="Size.Small"
                                         Variant="Variant.Outlined" Class="mb-3"
                                         Style="font-size: 0.75rem; font-weight: 600; letter-spacing: 0.02em; border-radius: 100px;">
                                    @_product.CategoryName
                                </MudChip>
                            }

                            <MudText Typo="Typo.h3" Style="font-weight: 700; line-height: 1.15; letter-spacing: -0.015em; margin-bottom: 16px;">
                                @_product.Name
                            </MudText>

                            @if (!string.IsNullOrWhiteSpace(_product.Description))
                            {
                                <MudText Typo="Typo.body1" Class="text-muted" Style="line-height: 1.7; margin-bottom: 24px;">
                                    @_product.Description
                                </MudText>
                            }

                            <div style="margin-bottom: 6px;">
                                <span class="os-mono" style="font-size: 2.25rem; font-weight: 700; color: var(--mud-palette-text-primary); letter-spacing: -0.02em;">
                                    @_product.Price.ToString("C")
                                </span>
                            </div>
                            <MudText Typo="Typo.caption" Class="text-muted" Style="margin-bottom: 20px; display: block;">
                                inkl. MwSt. · Kostenloser Versand
                            </MudText>

                            <div style="margin-bottom: 20px;">
                                <StockBadge Stock="_product.Stock" />
                            </div>

                            <MudDivider Class="mb-4" />

                            <div style="display: flex; gap: 12px; margin-bottom: 12px; align-items: center;">
                                <QuantityStepper Value="_quantity"
                                                 ValueChanged="value => _quantity = value"
                                                 Min="1"
                                                 Max="@_product.Stock" />

                                <MudButton Variant="Variant.Filled"
                                           Color="Color.Primary"
                                           Class="btn-pill"
                                           Style="height: 48px; font-size: 0.9375rem; flex: 1;"
                                           StartIcon="@Icons.Material.Outlined.ShoppingCart"
                                           Disabled="@(_product.Stock == 0)"
                                           OnClick="AddToCartAsync">
                                    In den Warenkorb
                                </MudButton>
                            </div>

                            <MudButton Variant="Variant.Outlined"
                                       Class="btn-pill-outline"
                                       FullWidth="true"
                                       Style="height: 48px; font-size: 0.9375rem;"
                                       StartIcon="@(_wishlisted ? Icons.Material.Filled.Favorite : Icons.Material.Outlined.FavoriteBorder)"
                                       OnClick="ToggleWishlist">
                                @(_wishlisted ? "Auf Wunschliste" : "Zur Wunschliste")
                            </MudButton>

                            <MudDivider Class="my-4" />

                            <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px;">
                                <div class="trust-col">
                                    <MudIcon Icon="@Icons.Material.Outlined.LocalShipping" Color="Color.Primary" Size="Size.Small" />
                                    <div>
                                        <div style="font-size: 0.75rem; font-weight: 600; color: var(--mud-palette-text-primary);">Versand</div>
                                        <div style="font-size: 0.6875rem; color: var(--mud-palette-text-secondary);">Kostenlos</div>
                                    </div>
                                </div>
                                <div class="trust-col">
                                    <MudIcon Icon="@Icons.Material.Outlined.Replay" Color="Color.Primary" Size="Size.Small" />
                                    <div>
                                        <div style="font-size: 0.75rem; font-weight: 600; color: var(--mud-palette-text-primary);">Rückgabe</div>
                                        <div style="font-size: 0.6875rem; color: var(--mud-palette-text-secondary);">30 Tage</div>
                                    </div>
                                </div>
                                <div class="trust-col">
                                    <MudIcon Icon="@Icons.Material.Outlined.Shield" Color="Color.Primary" Size="Size.Small" />
                                    <div>
                                        <div style="font-size: 0.75rem; font-weight: 600; color: var(--mud-palette-text-primary);">Garantie</div>
                                        <div style="font-size: 0.6875rem; color: var(--mud-palette-text-secondary);">2 Jahre</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </MudContainer>
            </section>
        }
        else
        {
            <div style="display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 60vh; gap: 16px;">
                <MudIcon Icon="@Icons.Material.Filled.SearchOff"
                         Style="font-size: 64px; color: var(--mud-palette-divider);" />
                <MudText Typo="Typo.h5" Style="font-weight: 600;">
                    Produkt nicht gefunden
                </MudText>
                <MudText Typo="Typo.body2" Class="text-muted">
                    Das Produkt existiert nicht oder wurde entfernt.
                </MudText>
                <MudButton Href="/shop" Variant="Variant.Filled" Color="Color.Primary" Class="btn-pill mt-2">
                    Zurück zu Produkten
                </MudButton>
            </div>
        }
    </ChildContent>
</LoadingWrapper>

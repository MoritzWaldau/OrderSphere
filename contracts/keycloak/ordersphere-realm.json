    {
      "id": "f6a7b8c9-d0e1-2345-fabc-567890123456",
      "clientId": "ordering-worker",
      "name": "Ordering Worker",
      "description": "Service account for Ordering.Worker and Ordering.Api M2M calls — client_credentials grant; assigned svc.ordering role",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,

@page "/admin"
@layout AdminLayout
@using Microsoft.AspNetCore.Authorization
@using OrderSphere.Application.Features.Admin.GetDashboardStats
@using OrderSphere.Application.Models.Admin
@inherits OrderSphereComponentBase
@rendermode InteractiveServer

@attribute [Authorize(Roles = "Administrator")]

<PageTitle>Admin Dashboard — OrderSphere</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="py-8">
    <MudText Typo="Typo.h4" Class="mb-2" Style="font-weight: 700;">Dashboard</MudText>
    <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mb-8">
        Übersicht über deinen Shop
    </MudText>

    @if (IsLoading)
    {
        <MudStack AlignItems="AlignItems.Center" Class="py-12">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
        </MudStack>
    }
    else if (_stats is null)
    {
        <MudAlert Severity="Severity.Error">Stats konnten nicht geladen werden.</MudAlert>
    }
    else
    {
        <MudGrid Class="mb-8">
            <MudItem xs="12" sm="6" md="3">
                <StatCard Icon="@Icons.Material.Outlined.Receipt"
                          Color="Color.Primary"
                          Label="Bestellungen gesamt"
                          Value="@_stats.TotalOrders.ToString()"
                          SubText="@($"{_stats.OrdersToday} heute")" />
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <StatCard Icon="@Icons.Material.Outlined.Euro"
                          Color="Color.Success"
                          Label="Umsatz gesamt"
                          Value="@FormatCurrency(_stats.TotalRevenue)"
                          SubText="@($"{FormatCurrency(_stats.RevenueToday)} heute")" />
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <StatCard Icon="@Icons.Material.Outlined.LocalShipping"
                          Color="Color.Warning"
                          Label="Offene Versände"
                          Value="@_stats.PendingShipments.ToString()"
                          SubText="zu versenden" />
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <StatCard Icon="@Icons.Material.Outlined.Warning"
                          Color="Color.Error"
                          Label="Niedriger Bestand"
                          Value="@_stats.LowStockProductsCount.ToString()"
                          SubText="@($"von {_stats.TotalProducts} Produkten")" />
            </MudItem>
        </MudGrid>

        <MudGrid>
            <MudItem xs="12" md="7">
                <MudPaper Elevation="0" Class="pa-6"
                          Style="border-radius: 16px; border: 1px solid var(--mud-palette-divider);">
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-4">
                        <MudText Typo="Typo.h6" Style="font-weight: 600;">Letzte Bestellungen</MudText>
                        <MudButton Variant="Variant.Text" Size="Size.Small" Href="/admin/orders">Alle ansehen</MudButton>
                    </MudStack>
                    @if (_stats.RecentOrders.Count == 0)
                    {
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Noch keine Bestellungen</MudText>
                    }
                    else
                    {
                        <MudStack Spacing="3">
                            @foreach (var order in _stats.RecentOrders)
                            {
                                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                    <MudStack Spacing="0">
                                        <MudText Typo="Typo.body2" Style="font-weight: 500;">@order.CustomerName</MudText>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                                            #@order.OrderId.ToString("N")[..8].ToUpperInvariant() · @order.CreatedAt.ToLocalTime().ToString("dd.MM. HH:mm")
                                        </MudText>
                                    </MudStack>
                                    <MudStack Spacing="0" AlignItems="AlignItems.End">
                                        <MudText Typo="Typo.body2" Style="font-weight: 600;">@FormatCurrency(order.Total)</MudText>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">@order.Status</MudText>
                                    </MudStack>
                                </MudStack>
                            }
                        </MudStack>
                    }
                </MudPaper>
            </MudItem>

            <MudItem xs="12" md="5">
                <MudPaper Elevation="0" Class="pa-6"
                          Style="border-radius: 16px; border: 1px solid var(--mud-palette-divider);">
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-4">
                        <MudText Typo="Typo.h6" Style="font-weight: 600;">Niedriger Bestand</MudText>
                        <MudButton Variant="Variant.Text" Size="Size.Small" Href="/admin/products">Produkte</MudButton>
                    </MudStack>
                    @if (_stats.LowStockProducts.Count == 0)
                    {
                        <MudStack AlignItems="AlignItems.Center" Class="py-4">
                            <MudIcon Icon="@Icons.Material.Outlined.CheckCircle" Color="Color.Success" Style="font-size: 48px;" />
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Alle Produkte gut bestückt.</MudText>
                        </MudStack>
                    }
                    else
                    {
                        <MudStack Spacing="2">
                            @foreach (var p in _stats.LowStockProducts)
                            {
                                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                    <MudStack Spacing="0">
                                        <MudText Typo="Typo.body2">@p.Name</MudText>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary" Style="font-family: monospace;">@p.SKU</MudText>
                                    </MudStack>
                                    <MudChip T="string"
                                             Color="@(p.Stock == 0 ? Color.Error : Color.Warning)"
                                             Size="Size.Small"
                                             Variant="Variant.Filled"
                                             Style="border-radius: 100px;">
                                        @p.Stock
                                    </MudChip>
                                </MudStack>
                            }
                        </MudStack>
                    }
                </MudPaper>
            </MudItem>
        </MudGrid>
    }
</MudContainer>

@code {
    private AdminDashboardDto? _stats;

    protected override async Task LoadDataAsync()
    {
        var result = await Sender.Send(new GetDashboardStatsQuery());
        if (result.IsSuccess) _stats = result.Value;
        else Snackbar.Add(result.Error.Description, Severity.Error);
    }

    private static string FormatCurrency(decimal value) =>
        value.ToString("0.00", System.Globalization.CultureInfo.GetCultureInfo("de-DE")) + " €";
}

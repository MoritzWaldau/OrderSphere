@page "/admin/coupons"
@inject IAdminOrderingClient AdminOrdering
@inject ISnackbar Snackbar
@inject IStringLocalizer<AppStrings> L

<PageTitle>@L["Admin.Coupons.PageTitle"]</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="py-8">
    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-6">
        <MudStack Spacing="0">
            <MudText Typo="Typo.h4" Style="font-weight: 700;">@L["Admin.Coupons.Title"]</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">@L["Admin.Coupons.Subtitle"]</MudText>
        </MudStack>
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Outlined.Add"
                   OnClick="OpenCreate"
                   Style="border-radius:100px;">
            @L["Admin.Coupons.New"]
        </MudButton>
    </MudStack>

    @if (_loading)
    {
        <MudStack AlignItems="AlignItems.Center" Class="py-12">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
        </MudStack>
    }
    else if (_coupons.Count == 0)
    {
        <MudPaper Elevation="0" Class="pa-12 text-center" Style="border-radius:16px;border:1px solid var(--mud-palette-divider);">
            <MudIcon Icon="@Icons.Material.Outlined.LocalOffer" Color="Color.Secondary" Style="font-size:64px;" Class="mb-3" />
            <MudText Typo="Typo.h6">@L["Admin.Coupons.None"]</MudText>
        </MudPaper>
    }
    else
    {
        <MudPaper Elevation="0" Style="border-radius:16px;border:1px solid var(--mud-palette-divider);overflow:hidden;">
            <MudTable Items="_coupons" Hover="true">
                <HeaderContent>
                    <MudTh>@L["Admin.Coupons.ColCode"]</MudTh>
                    <MudTh>@L["Admin.Coupons.ColDiscount"]</MudTh>
                    <MudTh>@L["Admin.Coupons.ColMinSubtotal"]</MudTh>
                    <MudTh>@L["Admin.Coupons.ColValidity"]</MudTh>
                    <MudTh Style="text-align:center;">@L["Admin.Coupons.ColUsage"]</MudTh>
                    <MudTh>@L["Admin.Coupons.ColStatus"]</MudTh>
                    <MudTh Style="text-align:right;">@L["Admin.Coupons.ColAction"]</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="@L["Admin.Coupons.ColCode"]">
                        <MudText Typo="Typo.body2" Class="os-mono" Style="font-weight:600;">@context.Code</MudText>
                    </MudTd>
                    <MudTd DataLabel="@L["Admin.Coupons.ColDiscount"]">@DiscountLabel(context)</MudTd>
                    <MudTd DataLabel="@L["Admin.Coupons.ColMinSubtotal"]">
                        @(context.MinSubtotal is { } min ? Formatting.Currency(min) : "—")
                    </MudTd>
                    <MudTd DataLabel="@L["Admin.Coupons.ColValidity"]">@ValidityLabel(context)</MudTd>
                    <MudTd DataLabel="@L["Admin.Coupons.ColUsage"]" Style="text-align:center;">
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@UsageLabel(context)</MudChip>
                    </MudTd>
                    <MudTd DataLabel="@L["Admin.Coupons.ColStatus"]">
                        <MudChip T="string"
                                 Color="@(context.IsActive ? Color.Success : Color.Default)"
                                 Size="Size.Small" Variant="Variant.Filled"
                                 Style="border-radius:100px;">
                            @(context.IsActive ? L["Common.Active"] : L["Common.Inactive"])
                        </MudChip>
                    </MudTd>
                    <MudTd DataLabel="@L["Admin.Coupons.ColAction"]" Style="text-align:right;">
                        <MudIconButton Icon="@Icons.Material.Outlined.Edit"
                                       Color="Color.Primary" Size="Size.Small"
                                       OnClick="@(() => OpenEdit(context))" />
                        <MudIconButton Icon="@Icons.Material.Outlined.Block"
                                       Color="Color.Error" Size="Size.Small"
                                       Disabled="@(!context.IsActive)"
                                       OnClick="@(() => DeactivateAsync(context))" />
                    </MudTd>
                </RowTemplate>
            </MudTable>
        </MudPaper>
    }

    <MudDialog @bind-Visible="_dialogOpen">
        <TitleContent>
            <MudText Typo="Typo.h6">@(_editingId is null ? L["Admin.Coupons.CreateTitle"] : L["Admin.Coupons.EditTitle"])</MudText>
        </TitleContent>
        <DialogContent>
            <MudStack Spacing="3">
                <MudTextField T="string" @bind-Value="_code" Label="@L["Admin.Coupons.FieldCode"]"
                              Variant="Variant.Outlined" Disabled="@(_editingId is not null)" />
                <MudSelect T="int" @bind-Value="_discountType" Label="@L["Admin.Coupons.FieldType"]"
                           Variant="Variant.Outlined">
                    <MudSelectItem Value="0">@L["Admin.Coupons.TypeFlat"]</MudSelectItem>
                    <MudSelectItem Value="1">@L["Admin.Coupons.TypePercentage"]</MudSelectItem>
                </MudSelect>
                <MudNumericField T="decimal" @bind-Value="_value" Label="@L["Admin.Coupons.FieldValue"]"
                                 Variant="Variant.Outlined" Min="0" />
                <MudNumericField T="decimal?" @bind-Value="_minSubtotal" Label="@L["Admin.Coupons.FieldMinSubtotal"]"
                                 Variant="Variant.Outlined" Min="0" />
                <MudStack Row="true" Spacing="2">
                    <MudDatePicker @bind-Date="_validFrom" Label="@L["Admin.Coupons.FieldValidFrom"]"
                                   Variant="Variant.Outlined" Clearable="true" />
                    <MudDatePicker @bind-Date="_validUntil" Label="@L["Admin.Coupons.FieldValidUntil"]"
                                   Variant="Variant.Outlined" Clearable="true" />
                </MudStack>
                <MudNumericField T="int?" @bind-Value="_maxRedemptions" Label="@L["Admin.Coupons.FieldMaxRedemptions"]"
                                 Variant="Variant.Outlined" Min="1" />
                <MudSwitch T="bool" @bind-Value="_isActive" Color="Color.Primary" Label="@L["Admin.Coupons.FieldActive"]" />
            </MudStack>
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="@(() => _dialogOpen = false)">@L["Common.Cancel"]</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveAsync" Disabled="_saving">
                @if (_saving)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                }
                @L["Common.Save"]
            </MudButton>
        </DialogActions>
    </MudDialog>
</MudContainer>

@code {
    private List<AdminCouponDto> _coupons = [];
    private bool _loading = true;

    private bool _dialogOpen;
    private bool _saving;
    private Guid? _editingId;
    private string _code = string.Empty;
    private int _discountType;
    private decimal _value;
    private decimal? _minSubtotal;
    private DateTime? _validFrom;
    private DateTime? _validUntil;
    private int? _maxRedemptions;
    private bool _isActive = true;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        try
        {
            var r = await AdminOrdering.GetCouponsAsync();
            if (r.IsSuccess) _coupons = r.Value!;
            else Snackbar.Add(r.Error!.Message, Severity.Error);
        }
        catch (Exception ex) { Snackbar.Add(L["Common.Error", ex.Message], Severity.Error); }
        finally { _loading = false; }
    }

    private void OpenCreate()
    {
        _editingId = null;
        _code = string.Empty;
        _discountType = 0;
        _value = 0;
        _minSubtotal = null;
        _validFrom = null;
        _validUntil = null;
        _maxRedemptions = null;
        _isActive = true;
        _dialogOpen = true;
    }

    private void OpenEdit(AdminCouponDto c)
    {
        _editingId = c.Id;
        _code = c.Code;
        _discountType = c.DiscountType;
        _value = c.Value;
        _minSubtotal = c.MinSubtotal;
        _validFrom = c.ValidFrom;
        _validUntil = c.ValidUntil;
        _maxRedemptions = c.MaxRedemptions;
        _isActive = c.IsActive;
        _dialogOpen = true;
    }

    private async Task SaveAsync()
    {
        _saving = true;
        try
        {
            var input = new AdminCouponInput(_code, _discountType, _value, _minSubtotal,
                _validFrom, _validUntil, _maxRedemptions, _isActive);

            ApiError? error;
            if (_editingId is { } id)
            {
                var result = await AdminOrdering.UpdateCouponAsync(id, input);
                error = result.IsSuccess ? null : result.Error;
            }
            else
            {
                var result = await AdminOrdering.CreateCouponAsync(input);
                error = result.IsSuccess ? null : result.Error;
            }

            if (error is null)
            {
                Snackbar.Add(L["Admin.Coupons.Saved"], Severity.Success);
                _dialogOpen = false;
                await LoadAsync();
            }
            else
            {
                Snackbar.Add(error.Message, Severity.Error);
            }
        }
        finally { _saving = false; }
    }

    private async Task DeactivateAsync(AdminCouponDto c)
    {
        var result = await AdminOrdering.DeactivateCouponAsync(c.Id);
        if (result.IsSuccess)
        {
            Snackbar.Add(L["Admin.Coupons.Deactivated"], Severity.Success);
            await LoadAsync();
        }
        else
        {
            Snackbar.Add(result.Error!.Message, Severity.Error);
        }
    }

    private string DiscountLabel(AdminCouponDto c)
        => c.DiscountType == 1 ? $"{c.Value:0.#}%" : Formatting.Currency(c.Value);

    private string ValidityLabel(AdminCouponDto c)
    {
        var from = c.ValidFrom is { } f ? Formatting.Date(f) : "—";
        var until = c.ValidUntil is { } u ? Formatting.Date(u) : "—";
        return c.ValidFrom is null && c.ValidUntil is null ? "—" : $"{from} – {until}";
    }

    private string UsageLabel(AdminCouponDto c)
        => c.MaxRedemptions is { } max ? $"{c.RedeemedCount} / {max}" : $"{c.RedeemedCount} / ∞";
}

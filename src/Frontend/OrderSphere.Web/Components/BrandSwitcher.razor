@implements IDisposable
@inject ThemeState ThemeState
@inject IJSRuntime JS

<MudMenu Icon="@Icons.Material.Outlined.Palette"
         Color="Color.Default"
         AnchorOrigin="Origin.BottomRight"
         TransformOrigin="Origin.TopRight"
         aria-label="Design wählen"
         Dense="true">
    @foreach (var brand in ThemeState.AvailableBrands)
    {
        <MudMenuItem OnClick="@(() => SelectBrandAsync(brand.Id))">
            <div class="d-flex align-center gap-3" style="min-width: 160px;">
                <span class="brand-swatch" style="background:@brand.Primary;"></span>
                <span>@brand.Name</span>
                @if (brand.Id == ThemeState.CurrentBrand.Id)
                {
                    <MudIcon Icon="@Icons.Material.Filled.Check"
                             Size="Size.Small"
                             Color="Color.Primary"
                             Class="ml-auto" />
                }
            </div>
        </MudMenuItem>
    }
</MudMenu>

@code {
    protected override void OnInitialized() => ThemeState.OnChange += OnThemeChanged;

    private async Task SelectBrandAsync(string brandId)
    {
        ThemeState.SetBrand(brandId);
        try { await JS.InvokeVoidAsync("localStorage.setItem", "os-brand", brandId); }
        catch { /* localStorage unavailable (e.g. private mode) */ }
    }

    private void OnThemeChanged() => InvokeAsync(StateHasChanged);

    public void Dispose() => ThemeState.OnChange -= OnThemeChanged;
}

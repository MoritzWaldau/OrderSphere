@using OrderSphere.UI.Configuration
@using Microsoft.AspNetCore.Components.Authorization

<MudAppBar Elevation="0" Fixed="true" Class="header-appbar">

    <MudHidden Breakpoint="Breakpoint.MdAndUp">
        <MudIconButton Icon="@Icons.Material.Filled.Menu"
                       OnClick="ToggleDrawer"
                       Color="Color.Dark" />
    </MudHidden>

    <MudLink Href="/" Underline="Underline.None">
        <MudText Typo="Typo.h6" Style="color: var(--mud-palette-text-primary); font-weight: 700;">
            OrderSphere
        </MudText>
    </MudLink>

    <MudSpacer />

    <MudHidden Breakpoint="Breakpoint.SmAndDown">
        <MudButton Variant="Variant.Text" Href="/shop" Color="Color.Dark">Shop</MudButton>
        <MudButton Variant="Variant.Text" Href="/categories" Color="Color.Dark">Kategorien</MudButton>
        <MudButton Variant="Variant.Text" Href="/offers" Color="Color.Dark">Angebote</MudButton>
    </MudHidden>

    <MudSpacer />

    <MudIconButton Icon="@Icons.Material.Outlined.Search" Href="/search" Color="Color.Dark" />

    <MudBadge Content="@CartItemCount" Color="Color.Error" Overlap="true" Visible="@(CartItemCount > 0)">
        <MudIconButton Icon="@Icons.Material.Outlined.ShoppingCart"
                       OnClick="OnCartToggle"
                       Color="Color.Dark" />
    </MudBadge>

    <!-- Account Button -->
    <AuthorizeView>
        <Authorized>
            <MudMenu Icon="@Icons.Material.Outlined.AccountCircle"
                     Color="Color.Dark"
                     Variant="Variant.Text"
                     AnchorOrigin="Origin.BottomRight"
                     TransformOrigin="Origin.TopRight"
                     Dense="true">

                <!-- User Info -->
                <div class="pa-4" style="border-bottom: 1px solid var(--mud-palette-divider); min-width: 220px;">
                    <MudText Typo="Typo.body1" Style="font-weight: 600;">
                        @context.User.FindFirst("FirstName")?.Value @context.User.FindFirst("LastName")?.Value
                    </MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        @context.User.Identity?.Name
                    </MudText>
                </div>

                <MudMenuItem Icon="@Icons.Material.Outlined.Person" Href="/account/profile">
                    Mein Profil
                </MudMenuItem>
                <MudMenuItem Icon="@Icons.Material.Outlined.ShoppingBag" Href="/account/orders">
                    Meine Bestellungen
                </MudMenuItem>
                <MudMenuItem Icon="@Icons.Material.Outlined.Settings" Href="/account/settings">
                    Einstellungen
                </MudMenuItem>

                <MudDivider />

                <MudMenuItem Icon="@Icons.Material.Outlined.Logout"
                             IconColor="Color.Error"
                             OnClick="HandleLogout">
                    <MudText Color="Color.Error">Abmelden</MudText>
                </MudMenuItem>

            </MudMenu>
        </Authorized>
        <NotAuthorized>
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Primary"
                       Href="/account/login"
                       Class="btn-pill ml-2"
                       Style="padding: 6px 20px !important;">
                Anmelden
            </MudButton>
        </NotAuthorized>
    </AuthorizeView>

</MudAppBar>

<MobileDrawer IsOpen="_drawerOpen" IsOpenChanged="val => _drawerOpen = val" />
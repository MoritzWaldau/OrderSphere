#!/bin/sh
# OrderSphere pre-commit gate.
# Verifies formatting of staged C# files before a commit is created. Versioned so it
# protects every commit (not just Claude Code sessions). Enable once per clone with:
#   git config core.hooksPath .githooks
#
# Scope is intentionally narrow (formatting only) to keep commits fast. Heavier gates
# (architecture/circular-dependency checks via the Roslyn tooling, EF migration safety)
# belong in CI or a documented opt-in pre-push hook, not here.

set -e

# Collect staged, non-deleted C# files.
staged_cs=$(git diff --cached --name-only --diff-filter=ACMR -- '*.cs')

if [ -z "$staged_cs" ]; then
    exit 0
fi

if ! command -v dotnet >/dev/null 2>&1; then
    echo "pre-commit: 'dotnet' not found on PATH; skipping format check." >&2
    exit 0
fi

echo "pre-commit: verifying C# formatting (dotnet format --verify-no-changes)..."

if ! dotnet format OrderSphere.slnx --verify-no-changes --no-restore --severity warn --exclude "**/Migrations/**"; then
    echo "" >&2
    echo "pre-commit: formatting issues found." >&2
    echo "Run 'dotnet format OrderSphere.slnx' to fix, then stage and commit again." >&2
    exit 1
fi

echo "pre-commit: formatting OK."
exit 0

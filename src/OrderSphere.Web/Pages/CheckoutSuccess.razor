@page "/checkout/success"
@attribute [Authorize]
@inject IOrderingClient Ordering
@inject NavigationManager Navigation

<PageTitle>Bestellung bestätigt — OrderSphere</PageTitle>

<section style="padding:80px 0;">
    <MudContainer MaxWidth="MaxWidth.Small" Class="text-center">

        <div style="width:80px;height:80px;border-radius:50%;background:var(--mud-palette-primary);display:flex;align-items:center;justify-content:center;margin:0 auto 24px;">
            <MudIcon Icon="@Icons.Material.Outlined.CheckCircle" Style="font-size:48px;color:#fff;" />
        </div>

        <MudText Typo="Typo.h3" Style="font-weight:700;">Bestellung aufgegeben!</MudText>
        <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mt-3">
            Deine Bestellung wird verarbeitet. Du erhältst eine Bestätigungs-E-Mail.
        </MudText>

        @if (_totalAmount.HasValue)
        {
            <MudText Typo="Typo.h5" Class="mt-4" Style="font-weight:600;">
                Gesamtbetrag: @_totalAmount.Value.ToString("0.00") €
            </MudText>
        }

        @if (_order is not null)
        {
            <MudPaper Elevation="0" Class="surface-card pa-6 mt-6 text-left">
                <MudText Typo="Typo.caption" Color="Color.Secondary">Bestellnummer</MudText>
                <MudText Typo="Typo.subtitle1" Class="text-monospace" Style="font-weight:600;">
                    #@_order.Id.ToString("N")[..8].ToUpperInvariant()
                </MudText>
            </MudPaper>
        }

        <MudStack Row="true" Justify="Justify.Center" Spacing="3" Class="mt-8">
            <MudButton Href="/account/orders" Variant="Variant.Filled"
                       Color="Color.Primary" Size="Size.Large" Class="btn-pill">
                Meine Bestellungen
            </MudButton>
            <MudButton Href="/shop" Variant="Variant.Outlined"
                       Color="Color.Primary" Size="Size.Large" Class="btn-pill">
                Weiter einkaufen
            </MudButton>
        </MudStack>

    </MudContainer>
</section>

@code {
    [SupplyParameterFromQuery] private Guid? CorrelationId { get; set; }
    [SupplyParameterFromQuery] private string? Total { get; set; }
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private OrderDto? _order;
    private decimal? _totalAmount;

    protected override async Task OnInitializedAsync()
    {
        if (decimal.TryParse(Total, System.Globalization.NumberStyles.Any,
            System.Globalization.CultureInfo.InvariantCulture, out var parsed))
        {
            _totalAmount = parsed;
        }

        if (CorrelationId is null) return;

        var state = await (AuthState ?? Task.FromResult(new AuthenticationState(new System.Security.Claims.ClaimsPrincipal())));
        var sub = state.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        if (!Guid.TryParse(sub, out var customerId)) return;

        // Poll for the order (Service Bus processing may take a moment)
        for (var i = 0; i < 6; i++)
        {
            _order = await Ordering.GetOrderByCorrelationIdAsync(CorrelationId.Value, customerId);
            if (_order is not null) break;
            await Task.Delay(2000);
        }
    }
}

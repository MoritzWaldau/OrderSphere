@page "/admin/products"
@inject IAdminCatalogClient AdminCatalog
@inject ISnackbar Snackbar

<PageTitle>Produkte — Admin</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="py-8">
    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-6">
        <MudStack Spacing="0">
            <MudText Typo="Typo.h4" Style="font-weight: 700;">Produkte</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">Verwalte den Produktkatalog</MudText>
        </MudStack>
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Outlined.Add"
                   Href="/admin/products/new"
                   Style="border-radius:100px;">
            Neues Produkt
        </MudButton>
    </MudStack>

    @if (_loading)
    {
        <MudStack AlignItems="AlignItems.Center" Class="py-12">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
        </MudStack>
    }
    else if (_products.Count == 0)
    {
        <MudPaper Elevation="0" Class="pa-12 text-center" Style="border-radius:16px;border:1px solid var(--mud-palette-divider);">
            <MudIcon Icon="@Icons.Material.Outlined.Inventory2" Color="Color.Secondary" Style="font-size:64px;" Class="mb-3" />
            <MudText Typo="Typo.h6">Keine Produkte vorhanden</MudText>
        </MudPaper>
    }
    else
    {
        <MudPaper Elevation="0" Style="border-radius:16px;border:1px solid var(--mud-palette-divider);overflow:hidden;">
            <MudTable Items="_products" Hover="true" Dense="false">
                <HeaderContent>
                    <MudTh>SKU</MudTh>
                    <MudTh>Name</MudTh>
                    <MudTh>Kategorie</MudTh>
                    <MudTh Style="text-align:right;">Preis</MudTh>
                    <MudTh Style="text-align:right;">Lager</MudTh>
                    <MudTh>Status</MudTh>
                    <MudTh Style="text-align:right;">Aktion</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="SKU">
                        <MudText Typo="Typo.body2" Class="os-mono">@context.SKU</MudText>
                    </MudTd>
                    <MudTd DataLabel="Name">
                        <MudText Typo="Typo.body2" Style="font-weight:500;">@context.Name</MudText>
                    </MudTd>
                    <MudTd DataLabel="Kategorie">
                        <MudText Typo="Typo.body2">@context.CategoryName</MudText>
                    </MudTd>
                    <MudTd DataLabel="Preis" Style="text-align:right;">
                        <MudText Typo="Typo.body2" Style="font-weight:600;">
                            @context.Price.ToString("0.00", System.Globalization.CultureInfo.GetCultureInfo("de-DE")) €
                        </MudText>
                    </MudTd>
                    <MudTd DataLabel="Lager" Style="text-align:right;">
                        <MudText Typo="Typo.body2"
                                 Style="@(context.Stock < 10 ? "color:var(--mud-palette-warning);font-weight:600;" : "")">
                            @context.Stock
                        </MudText>
                    </MudTd>
                    <MudTd DataLabel="Status">
                        <MudChip T="string"
                                 Color="@(context.IsActive ? Color.Success : Color.Default)"
                                 Size="Size.Small" Variant="Variant.Filled"
                                 Style="border-radius:100px;">
                            @(context.IsActive ? "Aktiv" : "Inaktiv")
                        </MudChip>
                    </MudTd>
                    <MudTd DataLabel="Aktion" Style="text-align:right;">
                        <MudIconButton Icon="@Icons.Material.Outlined.Edit"
                                       Color="Color.Primary" Size="Size.Small"
                                       Href="@($"/admin/products/{context.Id}")" />
                        <MudIconButton Icon="@Icons.Material.Outlined.Delete"
                                       Color="Color.Error" Size="Size.Small"
                                       OnClick="@(() => DeleteAsync(context.Id, context.Name))" />
                    </MudTd>
                </RowTemplate>
            </MudTable>
        </MudPaper>
    }
<MudMessageBox @ref="_msgBox" Title="Produkt löschen" CancelText="Abbrechen">
    <MessageContent>@_pendingDeleteName wirklich löschen?</MessageContent>
    <YesButton>
        <MudButton Variant="Variant.Filled" Color="Color.Error">Löschen</MudButton>
    </YesButton>
</MudMessageBox>

</MudContainer>

@code {
    private List<AdminProductDto> _products = [];
    private bool _loading = true;
    private MudMessageBox? _msgBox;
    private string _pendingDeleteName = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        try { var r = await AdminCatalog.GetProductsAsync(); if (r.IsSuccess) _products = r.Value!; else Snackbar.Add(r.Error!.Message, Severity.Error); }
        catch (Exception ex) { Snackbar.Add($"Fehler: {ex.Message}", Severity.Error); }
        finally { _loading = false; }
    }

    private async Task DeleteAsync(Guid id, string name)
    {
        _pendingDeleteName = name;
        var confirmed = await _msgBox!.ShowAsync();
        if (confirmed != true) return;

        var result = await AdminCatalog.DeleteProductAsync(id);
        if (result.IsSuccess) { _products.RemoveAll(p => p.Id == id); Snackbar.Add("Produkt gelöscht.", Severity.Success); }
        else Snackbar.Add(result.Error!.Message, Severity.Error);
    }
}

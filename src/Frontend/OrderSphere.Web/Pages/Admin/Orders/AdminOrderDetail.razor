@page "/admin/orders/{OrderId:guid}"
@inject IAdminOrderingClient AdminOrdering
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject IStringLocalizer<AppStrings> L

<PageTitle>@L["Admin.OrderDetail.PageTitle"]</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="py-8">
    <MudButton Variant="Variant.Text" StartIcon="@Icons.Material.Outlined.ArrowBack"
               Href="/admin/orders" Class="mb-4">
        @L["Admin.OrderDetail.BackToList"]
    </MudButton>

    @if (_loading)
    {
        <MudStack AlignItems="AlignItems.Center" Class="py-12">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
        </MudStack>
    }
    else if (_order is null)
    {
        <MudPaper Elevation="0" Class="pa-12 text-center" Style="border-radius:16px;border:1px solid var(--mud-palette-divider);">
            <MudIcon Icon="@Icons.Material.Outlined.SearchOff" Color="Color.Secondary" Style="font-size:64px;" Class="mb-3" />
            <MudText Typo="Typo.h6">@L["Admin.OrderDetail.NotFound"]</MudText>
        </MudPaper>
    }
    else
    {
        <MudGrid>
            <MudItem xs="12" md="8">
                <MudStack Spacing="4">
                    <MudPaper Elevation="0" Class="pa-6" Style="border-radius:16px;border:1px solid var(--mud-palette-divider);">
                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-4">
                            <MudStack Spacing="0">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">@L["Admin.OrderDetail.Order"]</MudText>
                                <MudText Typo="Typo.h5" Class="os-mono" Style="font-weight:700;">
                                    #@_order.Id.ToString("N")[..8].ToUpperInvariant()
                                </MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                    @Formatting.DateTime(_order.CreatedAt.ToLocalTime())
                                </MudText>
                            </MudStack>
                            <MudChip T="string" Color="@StatusColor(_order.Status)" Size="Size.Medium"
                                     Variant="Variant.Filled" Style="border-radius:100px;font-weight:600;">
                                @StatusLabel(_order.Status)
                            </MudChip>
                        </MudStack>
                        @if (!string.IsNullOrWhiteSpace(_order.TrackingNumber))
                        {
                            <MudDivider Class="mb-3" />
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                <MudIcon Icon="@Icons.Material.Outlined.LocalShipping" Color="Color.Primary" />
                                <MudText Typo="Typo.body1" Class="os-mono" Style="font-weight:600;">@_order.TrackingNumber</MudText>
                            </MudStack>
                        }
                    </MudPaper>

                    <MudPaper Elevation="0" Class="pa-6" Style="border-radius:16px;border:1px solid var(--mud-palette-divider);">
                        <MudText Typo="Typo.h6" Class="mb-4" Style="font-weight:600;">@L["Admin.OrderDetail.Items"]</MudText>
                        <MudStack Spacing="3">
                            @foreach (var line in _order.Items)
                            {
                                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                    <MudStack Spacing="0">
                                        <MudText Typo="Typo.body1" Style="font-weight:500;">@line.ProductName</MudText>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                                            @line.Quantity × @Formatting.Currency(line.Price)
                                        </MudText>
                                    </MudStack>
                                    <MudText Typo="Typo.body1" Style="font-weight:600;">
                                        @Formatting.Currency(line.Price * line.Quantity)
                                    </MudText>
                                </MudStack>
                            }
                        </MudStack>
                        <MudDivider Class="my-4" />
                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                            <MudText Typo="Typo.h6" Style="font-weight:600;">@L["Admin.OrderDetail.Total"]</MudText>
                            <MudText Typo="Typo.h5" Style="font-weight:700;color:var(--mud-palette-primary);">
                                @Formatting.Currency(_order.Total)
                            </MudText>
                        </MudStack>
                    </MudPaper>

                    <MudPaper Elevation="0" Class="pa-6" Style="border-radius:16px;border:1px solid var(--mud-palette-divider);">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-3">
                            <MudIcon Icon="@Icons.Material.Outlined.LocationOn" Color="Color.Primary" />
                            <MudText Typo="Typo.h6" Style="font-weight:600;">@L["Admin.OrderDetail.ShippingAddress"]</MudText>
                        </MudStack>
                        <MudText Typo="Typo.body2" Style="line-height:1.6;">
                            @_order.ShippingAddress.FirstName @_order.ShippingAddress.LastName<br />
                            @_order.ShippingAddress.Street<br />
                            @_order.ShippingAddress.PostalCode @_order.ShippingAddress.City<br />
                            @_order.ShippingAddress.Country
                        </MudText>
                    </MudPaper>
                </MudStack>
            </MudItem>

            <MudItem xs="12" md="4">
                <MudPaper Elevation="0" Class="pa-6" Style="border-radius:16px;border:1px solid var(--mud-palette-divider);position:sticky;top:80px;">
                    <MudText Typo="Typo.h6" Class="mb-4" Style="font-weight:600;">@L["Admin.OrderDetail.Actions"]</MudText>
                    <MudStack Spacing="2">
                        <MudButton Variant="Variant.Filled" Color="Color.Warning" FullWidth="true"
                                   StartIcon="@Icons.Material.Outlined.LocalShipping"
                                   Disabled="@(_order.Status != "Paid" || _busy)"
                                   OnClick="MarkShippedAsync">
                            @L["Admin.OrderDetail.MarkShipped"]
                        </MudButton>
                        <MudButton Variant="Variant.Filled" Color="Color.Success" FullWidth="true"
                                   StartIcon="@Icons.Material.Outlined.HomeWork"
                                   Disabled="@(_order.Status != "Shipped" || _busy)"
                                   OnClick="MarkDeliveredAsync">
                            @L["Admin.OrderDetail.MarkDelivered"]
                        </MudButton>
                        <MudDivider Class="my-2" />
                        <MudButton Variant="Variant.Outlined" Color="Color.Error" FullWidth="true"
                                   StartIcon="@Icons.Material.Outlined.Cancel"
                                   Disabled="@(_order.Status is "Delivered" or "Cancelled" || _busy)"
                                   OnClick="CancelAsync">
                            @L["Admin.OrderDetail.Cancel"]
                        </MudButton>
                    </MudStack>

                    @if (_order.Status == "Cancelled")
                    {
                        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mt-4">
                            @L["Admin.OrderDetail.CancelledNote"]
                        </MudAlert>
                    }
                    else if (_order.Status == "Delivered")
                    {
                        <MudAlert Severity="Severity.Success" Variant="Variant.Outlined" Class="mt-4">
                            @L["Admin.OrderDetail.DeliveredNote"]
                        </MudAlert>
                    }
                </MudPaper>
            </MudItem>
        </MudGrid>
    }
</MudContainer>

@code {
    [Parameter] public Guid OrderId { get; set; }

    private OrderDto? _order;
    private bool _loading = true;
    private bool _busy;

    protected override async Task OnInitializedAsync()
    {
        try { var r = await AdminOrdering.GetOrderByIdAsync(OrderId); _order = r.Value; if (!r.IsSuccess) Snackbar.Add(r.Error!.Message, Severity.Error); }
        catch (Exception ex) { Snackbar.Add(L["Common.Error", ex.Message], Severity.Error); }
        finally { _loading = false; }
    }

    private async Task MarkShippedAsync() => await UpdateStatusAsync(2); // Shipped
    private async Task MarkDeliveredAsync() => await UpdateStatusAsync(3); // Delivered

    private async Task UpdateStatusAsync(int status)
    {
        _busy = true;
        try
        {
            var result = await AdminOrdering.UpdateStatusAsync(OrderId, status);
            if (result.IsSuccess) { Snackbar.Add(L["Admin.OrderDetail.StatusUpdated"], Severity.Success); _order = (await AdminOrdering.GetOrderByIdAsync(OrderId)).Value; }
            else Snackbar.Add(result.Error!.Message, Severity.Error);
        }
        finally { _busy = false; }
    }

    private async Task CancelAsync()
    {
        _busy = true;
        try
        {
            var result = await AdminOrdering.CancelOrderAsync(OrderId);
            if (result.IsSuccess) { Snackbar.Add(L["Admin.OrderDetail.OrderCancelled"], Severity.Success); _order = (await AdminOrdering.GetOrderByIdAsync(OrderId)).Value; }
            else Snackbar.Add(result.Error!.Message, Severity.Error);
        }
        finally { _busy = false; }
    }

    private static Color StatusColor(string s) => s switch
    {
        "Paid" => Color.Info, "Shipped" => Color.Warning,
        "Delivered" => Color.Success, "Cancelled" => Color.Error,
        _ => Color.Default
    };

    private string StatusLabel(string s) => s switch
    {
        "Created"   => L["Admin.Orders.StatusCreated"],
        "Paid"      => L["Admin.Orders.StatusPaid"],
        "Shipped"   => L["Admin.Orders.StatusShipped"],
        "Delivered" => L["Admin.Orders.StatusDelivered"],
        "Cancelled" => L["Admin.Orders.StatusCancelled"],
        _ => s
    };
}

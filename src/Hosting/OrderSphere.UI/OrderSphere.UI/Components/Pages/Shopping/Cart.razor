@page "/cart"
@layout MainLayout
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@using OrderSphere.Application.Features.Cart.AddToCart
@using OrderSphere.Application.Features.Cart.DecreaseCartItemQuantity
@using OrderSphere.Application.Features.Cart.RemoveFromCart
@using OrderSphere.UI.Models.Cart.Events
@inject MediatR.ISender Sender
@implements IDisposable

@attribute [Authorize]

<PageTitle>Warenkorb — OrderSphere</PageTitle>

<PageHero Title="Dein Warenkorb"
          Subtitle="@($"{_items.Count} {(_items.Count == 1 ? "Artikel" : "Artikel")} bereit zum Bestellen")" />

<section class="page-section">
    <MudContainer>
        @if (_isLoading)
        {
            <MudStack AlignItems="AlignItems.Center" Class="py-12">
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
            </MudStack>
        }
        else if (_items.Count == 0)
        {
            <MudPaper Elevation="0" Class="surface-card-lg pa-12 text-center">
                <MudIcon Icon="@Icons.Material.Outlined.ShoppingCart"
                         Color="Color.Primary"
                         Style="font-size: 80px;" Class="mb-4" />
                <MudText Typo="Typo.h5" Class="mb-2" Style="font-weight: 600;">
                    Dein Warenkorb ist leer
                </MudText>
                <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mb-6">
                    Füge Produkte hinzu, um loszulegen.
                </MudText>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large"
                           Href="/shop"
                           StartIcon="@Icons.Material.Outlined.Storefront"
                           Class="btn-pill">
                    Produkte entdecken
                </MudButton>
            </MudPaper>
        }
        else
        {
            <MudGrid Spacing="4">
                <MudItem xs="12" lg="8">
                    <MudStack Spacing="3">
                        @foreach (var item in _items)
                        {
                            <MudPaper Elevation="0" Class="surface-card pa-4">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="4">
                                    <ProductImage ImageUrl="@item.ImageUrl"
                                                  Alt="@item.ProductName"
                                                  Size="ProductImage.ImageSize.ThumbMd"
                                                  PlaceholderIconSize="2.25rem" />

                                    <MudStack Spacing="1" Style="flex: 1;">
                                        <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">
                                            @item.ProductName
                                        </MudText>
                                        <MudText Typo="Typo.caption" Class="text-primary-color" Style="font-weight: 600;">
                                            @item.Price.ToString("C") / Stk.
                                        </MudText>

                                        <div class="mt-2" style="display: inline-block;">
                                            <QuantityStepper Value="item.Quantity"
                                                             ValueChanged="newValue => HandleQuantityChange(item, newValue)"
                                                             Min="1" />
                                        </div>
                                    </MudStack>

                                    <MudStack AlignItems="AlignItems.End" Spacing="2">
                                        <MudText Typo="Typo.h6" Style="font-weight: 700;">
                                            @((item.Price * item.Quantity).ToString("C"))
                                        </MudText>
                                        <MudIconButton Icon="@Icons.Material.Outlined.DeleteOutline"
                                                       Size="Size.Small"
                                                       Color="Color.Error"
                                                       aria-label="@($"{item.ProductName} entfernen")"
                                                       OnClick="@(() => RemoveItem(item))" />
                                    </MudStack>
                                </MudStack>
                            </MudPaper>
                        }
                    </MudStack>
                </MudItem>

                <MudItem xs="12" lg="4">
                    <MudPaper Elevation="0" Class="surface-card-lg pa-6"
                              Style="position: sticky; top: 24px;">
                        <MudText Typo="Typo.h5" Class="mb-4" Style="font-weight: 600;">
                            Zusammenfassung
                        </MudText>

                        <MudStack Row="true" Justify="Justify.SpaceBetween" Class="mb-2">
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Zwischensumme</MudText>
                            <MudText Typo="Typo.body2">@Subtotal.ToString("C")</MudText>
                        </MudStack>

                        <MudStack Row="true" Justify="Justify.SpaceBetween" Class="mb-2">
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Versand</MudText>
                            <MudText Typo="Typo.body2" Class="shipping-free">Kostenlos</MudText>
                        </MudStack>

                        <MudDivider Class="my-4" />

                        <MudStack Row="true" Justify="Justify.SpaceBetween" Class="mb-6">
                            <MudText Typo="Typo.h6" Style="font-weight: 700;">Gesamt</MudText>
                            <MudText Typo="Typo.h6" Class="text-primary-color" Style="font-weight: 700;">
                                @Subtotal.ToString("C")
                            </MudText>
                        </MudStack>

                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   Size="Size.Large"
                                   FullWidth="true"
                                   Href="/checkout"
                                   EndIcon="@Icons.Material.Outlined.ArrowForward"
                                   Class="btn-pill">
                            Zur Kasse
                        </MudButton>

                        <MudButton Variant="Variant.Text"
                                   FullWidth="true"
                                   Href="/shop"
                                   Color="Color.Default"
                                   Class="mt-2"
                                   Style="border-radius: 100px;">
                            Weiter shoppen
                        </MudButton>
                    </MudPaper>
                </MudItem>
            </MudGrid>
        }
    </MudContainer>
</section>

@code {
    private List<CartItemViewModel> _items = [];
    private bool _isLoading = true;

    private decimal Subtotal => _items.Sum(x => x.Price * x.Quantity);

    protected override async Task OnInitializedAsync()
    {
        CartService.OnCartUpdated += OnCartUpdated;
        var cart = await CartService.GetCartAsync();
        ApplyCart(cart);
        _isLoading = false;
    }

    private void OnCartUpdated(CartChangedEventArgs args)
    {
        _ = InvokeAsync(async () =>
        {
            var currentCustomerId = await CurrentUserService.GetCustomerIdAsync();
            if (currentCustomerId is null || currentCustomerId.Value != args.CustomerId)
                return;

            ApplyCart(args.Cart);
            StateHasChanged();
        });
    }

    private void ApplyCart(CartDto? cart)
    {
        _items = cart?.Items?
            .Select(CartItemViewModel.FromDto)
            .ToList()
            ?? [];
    }

    private async Task HandleQuantityChange(CartItemViewModel item, int newValue)
    {
        if (newValue > item.Quantity)
        {
            await IncreaseQuantity(item);
        }
        else if (newValue < item.Quantity)
        {
            await DecreaseQuantity(item);
        }
    }

    private async Task IncreaseQuantity(CartItemViewModel item)
    {
        var customerId = await CurrentUserService.GetCustomerIdAsync();
        if (customerId is null) return;

        var result = await Sender.Send(new AddToCartCommand(customerId.Value, item.ProductId, 1));
        if (result.IsSuccess)
            await CartService.RefreshCartAsync();
    }

    private async Task DecreaseQuantity(CartItemViewModel item)
    {
        var customerId = await CurrentUserService.GetCustomerIdAsync();
        if (customerId is null) return;

        var result = await Sender.Send(new DecreaseCartItemQuantityCommand(customerId.Value, item.ProductId));
        if (result.IsSuccess)
            await CartService.RefreshCartAsync();
    }

    private async Task RemoveItem(CartItemViewModel item)
    {
        var customerId = await CurrentUserService.GetCustomerIdAsync();
        if (customerId is null) return;

        var result = await Sender.Send(new RemoveFromCartCommand(customerId.Value, item.ProductId));
        if (result.IsSuccess)
        {
            await CartService.RefreshCartAsync();
            Snackbar.Add($"{item.ProductName} wurde aus dem Warenkorb entfernt.", Severity.Info);
        }
    }

    public void Dispose()
    {
        CartService.OnCartUpdated -= OnCartUpdated;
    }

    private sealed class CartItemViewModel
    {
        public Guid ProductId { get; init; }
        public string ProductName { get; init; } = string.Empty;
        public string? ImageUrl { get; init; }
        public decimal Price { get; init; }
        public int Quantity { get; set; }

        public static CartItemViewModel FromDto(CardItemDto dto) => new()
        {
            ProductId = dto.ProductId,
            ProductName = dto.ProductName,
            Price = dto.Price,
            Quantity = dto.Quantity
        };
    }
}

@using OrderSphere.UI.Client.Configuration
@inherits LayoutComponentBase

<MudThemeProvider Theme="ThemeConfiguration.ApplicationTheme()" IsDarkMode="true" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />


<MudLayout>

    <!-- HEADER -->
    <MudAppBar Elevation="1" Color="Color.Primary" Dense="false" Fixed="true">

        <!-- Logo / Brand -->
        
        <MudText Typo="Typo.h6">
            OrderSphere
        </MudText>
       

        <MudSpacer />

        <!-- Navigation -->
        <MudHidden Breakpoint="Breakpoint.SmAndDown">
            <MudButton 
                Variant="Variant.Text"
                Href="/products"
            >
                Produkte
            </MudButton>

            <MudButton 
                Variant="Variant.Text"
                Href="/categories"
            >
                Kategorien
            </MudButton>

            <MudButton 
                Variant="Variant.Text"
                Href="/offers"
            >
                Angebote
            </MudButton>
        </MudHidden>

        <MudSpacer />

        <!-- Actions -->
        <MudIconButton Icon="@Icons.Material.Filled.Search" />

        <MudIconButton Icon="@Icons.Material.Filled.ShoppingCart"
                       OnClick="@(() => NavManager.NavigateTo("/cart"))" />

        <MudIconButton Icon="@Icons.Material.Filled.AccountCircle" />

    </MudAppBar>

    <!-- CONTENT -->
    <MudMainContent>
        @Body
    </MudMainContent>

    <!-- FOOTER -->
    <MudPaper Class="pa-6 mt-10" Elevation="0" Style="border-top: 1px solid #eee;">

        <MudGrid>

            <!-- Brand -->
            <MudItem xs="12" md="4">
                <MudText Typo="Typo.h6" Color="Color.Primary">
                    OrderSphere
                </MudText>

                <MudText Class="mt-2">
                    Dein Shop für moderne IT-Geräte.
                    Schnell, zuverlässig und smart.
                </MudText>
            </MudItem>

            <!-- Navigation -->
            <MudItem xs="6" md="2">
                <MudText Typo="Typo.subtitle1">Shop</MudText>

                <MudLink Href="/products">Produkte</MudLink><br />
                <MudLink Href="/">Startseite</MudLink><br />
                <MudLink>Deals</MudLink>
            </MudItem>

            <!-- Kategorien -->
            <MudItem xs="6" md="2">
                <MudText Typo="Typo.subtitle1">Kategorien</MudText>

                <MudLink>Laptops</MudLink><br />
                <MudLink>Tablets</MudLink><br />
                <MudLink>Zubehör</MudLink>
            </MudItem>

            <!-- Rechtliches -->
            <MudItem xs="12" md="2">
                <MudText Typo="Typo.subtitle1">Rechtliches</MudText>

                <MudLink>Impressum</MudLink><br />
                <MudLink>Datenschutz</MudLink>
            </MudItem>

            <!-- Social / AI -->
            <MudItem xs="12" md="2">
                <MudText Typo="Typo.subtitle1">Support</MudText>

                <MudText>🤖 AI Assistant</MudText>
                <MudText>📧 support@ordersphere.dev</MudText>
            </MudItem>

        </MudGrid>

        <!-- Bottom Bar -->
        <MudDivider Class="my-4" />

        <MudText Align="Align.Center" Typo="Typo.caption">
            © @DateTime.Now.Year OrderSphere — Alle Rechte vorbehalten
        </MudText>

    </MudPaper>

</MudLayout>

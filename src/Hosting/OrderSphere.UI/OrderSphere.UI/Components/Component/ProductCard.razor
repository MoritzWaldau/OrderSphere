<MudPaper Elevation="0"
          Class="product-card"
          @onclick="HandleOpen"
          role="button"
          tabindex="0">

    <div class="product-card-image">
        <ProductImage ImageUrl="@Product.ImageUrl"
                      Alt="@Product.Name"
                      Size="@(Compact ? ProductImage.ImageSize.SearchCard : ProductImage.ImageSize.Card)" />
        @if (Product.Stock == 0)
        {
            <div style="position: absolute; top: 12px; left: 12px;">
                <MudChip T="string" Size="Size.Small" Color="Color.Error" Style="font-size: 0.6875rem; font-weight: 600;">
                    Nicht verfügbar
                </MudChip>
            </div>
        }
    </div>

    <div class="product-card-content">
        @if (ShowCategory && !string.IsNullOrWhiteSpace(Product.CategoryName))
        {
            <span class="product-card-category">@Product.CategoryName</span>
        }

        <MudText Typo="Typo.body1" Style="font-weight: 600; margin-top: 4px; line-height: 1.3;">
            @Product.Name
        </MudText>

        @if (ShowDescription && !string.IsNullOrWhiteSpace(Product.Description))
        {
            <MudText Typo="Typo.body2" Color="Color.Secondary" Style="margin-top: 4px; flex: 1; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                @Product.Description
            </MudText>
        }

        @if (ShowAddToCart)
        {
            <div style="display: flex; align-items: center; justify-content: space-between; margin-top: 12px;">
                <span class="os-mono" style="font-size: 1rem; font-weight: 600; color: var(--mud-palette-text-primary);">
                    @Product.Price.ToString("C")
                </span>

                <span @onclick:stopPropagation="true">
                    <MudIconButton Icon="@Icons.Material.Outlined.Add"
                                   aria-label="@($"{Product.Name} in den Warenkorb")"
                                   Disabled="@(Product.Stock == 0)"
                                   OnClick="HandleAdd"
                                   Size="Size.Small"
                                   Class="product-add-btn" />
                </span>
            </div>
        }
        else
        {
            <span class="os-mono" style="font-size: 1rem; font-weight: 600; color: var(--mud-palette-text-primary); display: block; margin-top: 12px;">
                @Product.Price.ToString("C")
            </span>
        }
    </div>
</MudPaper>

@code {
    [Parameter, EditorRequired] public ProductDto Product { get; set; } = default!;
    [Parameter] public EventCallback<ProductDto> OnOpen { get; set; }
    [Parameter] public EventCallback<ProductDto> OnAdd { get; set; }
    [Parameter] public bool ShowAddToCart { get; set; } = true;
    [Parameter] public bool ShowCategory { get; set; }
    [Parameter] public bool ShowDescription { get; set; } = true;
    [Parameter] public bool Compact { get; set; }

    private Task HandleOpen() => OnOpen.InvokeAsync(Product);
    private Task HandleAdd() => OnAdd.InvokeAsync(Product);
}

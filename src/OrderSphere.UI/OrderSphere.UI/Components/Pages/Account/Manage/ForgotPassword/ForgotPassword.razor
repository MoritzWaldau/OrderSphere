@page "/account/forgot-password"

<PageTitle>Passwort vergessen – OrderSphere</PageTitle>

<section class="section-gray" style="min-height: 100vh; display: flex; align-items: center;">
    <MudContainer MaxWidth="MaxWidth.Small">
        <MudPaper Elevation="0" Class="pa-8 surface-card-lg">

            @if (!_emailSent)
            {
                <!-- Header -->
                <MudStack AlignItems="AlignItems.Center" Class="mb-6">
                    <MudLink Href="/" Underline="Underline.None">
                        <MudText Typo="Typo.h6" Style="font-weight: 700;">OrderSphere</MudText>
                    </MudLink>
                    <MudText Typo="Typo.h5" Style="font-weight: 700;" Class="mt-2">
                        Passwort vergessen?
                    </MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Center">
                        Gib deine E-Mail ein und wir senden dir einen Reset-Link.
                    </MudText>
                </MudStack>

                <!-- Form -->
                <MudStack Spacing="3">
                    <MudTextField @bind-Value="_email"
                                  Label="E-Mail"
                                  Variant="Variant.Outlined"
                                  InputType="InputType.Email"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Outlined.Email"
                                  FullWidth="true" />

                    @if (_errorMessage is not null)
                    {
                        <MudAlert Severity="Severity.Error" Dense="true">
                            @_errorMessage
                        </MudAlert>
                    }

                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               FullWidth="true"
                               Size="Size.Large"
                               Class="btn-pill mt-2"
                               OnClick="HandleForgotPassword"
                               Disabled="_isLoading">
                        @if (_isLoading)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                        }
                        Reset-Link senden
                    </MudButton>

                    <MudDivider />

                    <MudText Typo="Typo.body2" Align="Align.Center" Color="Color.Secondary">
                        <MudLink Href="/account/login" Color="Color.Primary">
                            Zurück zum Login
                        </MudLink>
                    </MudText>
                </MudStack>
            }
            else
            {
                <!-- Bestätigung -->
                <MudStack AlignItems="AlignItems.Center" Spacing="3">
                    <div class="icon-bubble-success-soft">
                        <MudIcon Icon="@Icons.Material.Outlined.MarkEmailRead"
                                 Style="font-size: 2.5rem; color: var(--mud-palette-success);" />
                    </div>
                    <MudText Typo="Typo.h5" Style="font-weight: 700;">
                        E-Mail gesendet!
                    </MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Center">
                        Wir haben einen Reset-Link an <strong>@_email</strong> gesendet.
                        Bitte überprüfe auch deinen Spam-Ordner.
                    </MudText>
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Primary"
                               Href="/account/login"
                               Class="btn-pill mt-2"
                               FullWidth="true">
                        Zurück zum Login
                    </MudButton>
                </MudStack>
            }

        </MudPaper>
    </MudContainer>
</section>
@page "/shop"
@page "/shop/category/{Category}"
@attribute [Authorize]
@inject ICatalogClient Catalog
@inject IOrderingClient Ordering
@inject CartState CartState
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject IStringLocalizer<AppStrings> L

<PageTitle>@L["Shop.PageTitle"]</PageTitle>

<PageHero Eyebrow="@L["Common.AllProducts"]" Title="@L["Shop.HeroTitle"]"
          Subtitle="@L["Shop.HeroSubtitle"]" />

<section style="padding:48px 0 80px;">
    <MudContainer MaxWidth="MaxWidth.Large">

        <MudPaper Elevation="0" Outlined="true" Class="pa-4 mb-6">
            <MudGrid Spacing="2" Class="align-center">
                <MudItem xs="12" md="4">
                    <MudTextField T="string" @bind-Value="_search"
                                  Placeholder="@L["Shop.SearchPlaceholder"]"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Outlined.Search"
                                  Variant="Variant.Outlined" Margin="Margin.Dense"
                                  OnKeyDown="OnSearchKeyDown" />
                </MudItem>
                <MudItem xs="6" md="3">
                    <MudSelect T="string" @bind-Value="_categoryFilter" @bind-Value:after="ResetAndReloadAsync"
                               Label="@L["Shop.CategoryFilter"]" Clearable="true"
                               Variant="Variant.Outlined" Margin="Margin.Dense">
                        @foreach (var c in _categories)
                        {
                            <MudSelectItem Value="@c.Name">@c.Name</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="6" md="3">
                    <MudSelect T="string" @bind-Value="_sort" @bind-Value:after="ResetAndReloadAsync"
                               Label="@L["Shop.SortLabel"]"
                               Variant="Variant.Outlined" Margin="Margin.Dense">
                        <MudSelectItem Value="@("name_asc")">@L["Shop.SortNameAsc"]</MudSelectItem>
                        <MudSelectItem Value="@("name_desc")">@L["Shop.SortNameDesc"]</MudSelectItem>
                        <MudSelectItem Value="@("price_asc")">@L["Shop.SortPriceAsc"]</MudSelectItem>
                        <MudSelectItem Value="@("price_desc")">@L["Shop.SortPriceDesc"]</MudSelectItem>
                        <MudSelectItem Value="@("newest")">@L["Shop.SortNewest"]</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="2">
                    <MudButton FullWidth="true" Variant="Variant.Filled" Color="Color.Primary"
                               OnClick="ApplyAsync">@L["Shop.ApplyFilter"]</MudButton>
                </MudItem>

                <MudItem xs="6" md="3">
                    <MudNumericField T="decimal?" @bind-Value="_minPrice" Label="@L["Shop.MinPrice"]"
                                     Variant="Variant.Outlined" Margin="Margin.Dense" Min="0" />
                </MudItem>
                <MudItem xs="6" md="3">
                    <MudNumericField T="decimal?" @bind-Value="_maxPrice" Label="@L["Shop.MaxPrice"]"
                                     Variant="Variant.Outlined" Margin="Margin.Dense" Min="0" />
                </MudItem>
                <MudItem xs="12" md="2">
                    <MudButton FullWidth="true" Variant="Variant.Text" Color="Color.Default"
                               OnClick="ResetFiltersAsync">@L["Shop.ResetFilter"]</MudButton>
                </MudItem>
            </MudGrid>
        </MudPaper>

        @if (_loading)
        {
            <MudStack AlignItems="AlignItems.Center" Style="min-height:40vh;justify-content:center;">
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
            </MudStack>
        }
        else if (!_products.Any())
        {
            <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Style="min-height:40vh;padding:64px 0;">
                <MudIcon Icon="@Icons.Material.Outlined.Inventory2"
                         Style="font-size:64px;color:var(--mud-palette-divider);" />
                <MudText Typo="Typo.h5" Style="margin-top:20px;font-weight:600;">@L["Shop.NoProducts"]</MudText>
                <MudText Typo="Typo.body2" Class="text-muted" Style="margin-top:4px;">@L["Shop.NoProductsHint"]</MudText>
            </MudStack>
        }
        else
        {
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:24px;">
                <MudText Typo="Typo.body2" Class="text-muted">
                    <span class="os-mono">@_totalCount</span> @L["Shop.ProductsLabel"]
                </MudText>
            </div>

            <MudGrid Spacing="3">
                @foreach (var product in _products)
                {
                    <MudItem xs="12" sm="6" md="4">
                        <ProductCard Product="product"
                                     ShowCategory="true"
                                     OnOpen="OpenDetails"
                                     OnAdd="OpenQuantityPopup" />
                    </MudItem>
                }
            </MudGrid>

            @if (_totalPages > 1)
            {
                <MudStack AlignItems="AlignItems.Center" Class="mt-8">
                    <MudPagination Color="Color.Primary" Count="_totalPages"
                                   Selected="_page" SelectedChanged="OnPageChangedAsync" />
                </MudStack>
            }

            <!-- Quantity dialog -->
            <MudDialog @bind-Visible="_popupOpen">
                <TitleContent>
                    <MudText Typo="Typo.h6">@_selectedProduct?.Name</MudText>
                </TitleContent>
                <DialogContent>
                    <MudText Typo="Typo.body2" Class="mb-4">@L["Shop.ChooseQuantity", _selectedProduct?.Stock ?? 1]</MudText>
                    <MudNumericField T="int" @bind-Value="_quantity"
                                     Min="1" Max="@(_selectedProduct?.Stock ?? 1)"
                                     Label="@L["Common.Quantity"]" Variant="Variant.Outlined" />
                </DialogContent>
                <DialogActions>
                    <MudButton OnClick="ClosePopup">@L["Common.Cancel"]</MudButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               OnClick="ConfirmAddToCartAsync" Disabled="_addingToCart">
                        @if (_addingToCart)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                        }
                        @L["Common.AddToCart"]
                    </MudButton>
                </DialogActions>
            </MudDialog>
        }
    </MudContainer>
</section>

@code {
    [Parameter] public string? Category { get; set; }

    private List<ProductDto> _products = [];
    private List<CategoryDto> _categories = [];
    private bool _loading = true;
    private bool _popupOpen;
    private bool _addingToCart;
    private ProductDto? _selectedProduct;
    private int _quantity = 1;

    private const int PageSize = 12;
    private int _page = 1;
    private int _totalCount;
    private int _totalPages;

    private string _search = string.Empty;
    private string? _categoryFilter;
    private decimal? _minPrice;
    private decimal? _maxPrice;
    private string _sort = "name_asc";

    private string? _lastCategoryRoute;

    protected override async Task OnInitializedAsync()
    {
        var cats = await Catalog.GetCategoriesAsync();
        if (cats.IsSuccess)
            _categories = cats.Value!.Items.ToList();

        _categoryFilter = Category;
        _lastCategoryRoute = Category;
        await LoadAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        // React to navigation between /shop and /shop/category/{Category}.
        if (_lastCategoryRoute != Category)
        {
            _lastCategoryRoute = Category;
            _categoryFilter = Category;
            _page = 1;
            await LoadAsync();
        }
    }

    private async Task LoadAsync()
    {
        _loading = true;
        try
        {
            var (by, dir) = MapSort();
            var query = new ProductQuery(
                Page: _page,
                PageSize: PageSize,
                Search: string.IsNullOrWhiteSpace(_search) ? null : _search.Trim(),
                Category: string.IsNullOrWhiteSpace(_categoryFilter) ? null : _categoryFilter,
                MinPrice: _minPrice,
                MaxPrice: _maxPrice,
                SortBy: by,
                SortDir: dir);

            var res = await Catalog.GetProductsAsync(query);
            if (res.IsSuccess)
            {
                _products = res.Value!.Items.ToList();
                _totalCount = res.Value.TotalCount;
                _totalPages = res.Value.TotalPages;
            }
            else
            {
                Snackbar.Add(res.Error!.Message, Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add(L["Shop.LoadError", ex.Message], Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private (string by, string dir) MapSort() => _sort switch
    {
        "name_desc" => ("name", "desc"),
        "price_asc" => ("price", "asc"),
        "price_desc" => ("price", "desc"),
        "newest" => ("newest", "desc"),
        _ => ("name", "asc"),
    };

    private async Task ResetAndReloadAsync()
    {
        _page = 1;
        await LoadAsync();
    }

    private Task ApplyAsync() => ResetAndReloadAsync();

    private async Task ResetFiltersAsync()
    {
        _search = string.Empty;
        _categoryFilter = Category;
        _minPrice = null;
        _maxPrice = null;
        _sort = "name_asc";
        _page = 1;
        await LoadAsync();
    }

    private async Task OnPageChangedAsync(int page)
    {
        _page = page;
        await LoadAsync();
    }

    private void OnSearchKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            _ = ApplyAsync();
    }

    private void OpenDetails(ProductDto product)
        => Navigation.NavigateTo($"/shop/{Uri.EscapeDataString(product.CategoryName)}/{Uri.EscapeDataString(product.Slug)}");

    private void OpenQuantityPopup(ProductDto product)
    {
        _selectedProduct = product;
        _quantity = 1;
        _popupOpen = true;
    }

    private void ClosePopup()
    {
        _popupOpen = false;
        _selectedProduct = null;
    }

    private async Task ConfirmAddToCartAsync()
    {
        if (_selectedProduct is null) return;

        _addingToCart = true;
        try
        {
            var result = await Ordering.AddToCartAsync(_selectedProduct.Id, _quantity);
            if (result.IsSuccess)
            {
                Snackbar.Add(L["Common.AddedToCart", _quantity, _selectedProduct.Name], Severity.Success);
                await CartState.RefreshAsync();
                ClosePopup();
            }
            else
            {
                Snackbar.Add(result.Error!.Message, Severity.Error);
            }
        }
        finally
        {
            _addingToCart = false;
        }
    }
}

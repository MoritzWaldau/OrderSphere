@using OrderSphere.Application.Features.Cart.RemoveCart
@using OrderSphere.Application.Models
@using OrderSphere.Application.Features.Cart.AddToCart
@using OrderSphere.Application.Features.Cart.DecreaseCartItemQuantity
@using OrderSphere.Application.Features.Cart.RemoveFromCart
@using OrderSphere.UI.Models.Cart.Events
@using OrderSphere.UI.Services
@inject IJSRuntime JS
@inject ICurrentUserService CurrentUserService
@inject MediatR.ISender Sender
@implements IAsyncDisposable

<MudDrawer Open="IsOpen"
           OpenChanged="IsOpenChanged"
           Anchor="Anchor.Right"
           Elevation="4"
           Variant="DrawerVariant.Temporary"
           Width="420px"
           Style="height: 100vh;">

    <!-- Header -->
    <div style="padding: 20px 24px; display: flex; align-items: center; justify-content: space-between; flex-shrink: 0; border-bottom: 1px solid var(--mud-palette-divider);">
        <MudStack Spacing="0">
            <MudText Typo="Typo.h6" Style="font-weight: 700;">Warenkorb</MudText>
            <MudText Typo="Typo.caption" Class="text-muted">
                @_items.Count Artikel
            </MudText>
        </MudStack>
        <MudIconButton Icon="@Icons.Material.Filled.Close"
                       OnClick="@(() => IsOpenChanged.InvokeAsync(false))"
                       aria-label="Warenkorb schließen"
                       Style="background: var(--mud-palette-background-grey); border-radius: 50%;" />
    </div>

    @if (!_items.Any())
    {
        <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Style="flex: 1; padding: 48px 24px; text-align: center;">
            <div style="background: var(--mud-palette-background-grey); border-radius: 50%; width: 72px; height: 72px; display: flex; align-items: center; justify-content: center;">
                <MudIcon Icon="@Icons.Material.Outlined.ShoppingCart"
                         Style="font-size: 2rem; color: var(--mud-palette-text-secondary);" />
            </div>
            <MudText Typo="Typo.h6" Style="font-weight: 600; margin-top: 20px;">
                Noch nichts im Korb.
            </MudText>
            <MudText Typo="Typo.body2" Align="Align.Center" Class="text-muted" Style="margin-top: 6px; max-width: 260px; line-height: 1.6;">
                Entdecke unsere Produkte und füge sie hier hinzu.
            </MudText>
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Primary"
                       Href="/shop"
                       Class="btn-pill mt-6">
                Shop entdecken
            </MudButton>
        </MudStack>
    }
    else
    {
        <div style="flex: 1; overflow-y: auto; overflow-x: hidden; align-content: start;">
            @foreach (var item in _items)
            {
                <div style="padding: 16px 24px; border-bottom: 1px solid var(--mud-palette-divider-light);">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="0">

                        <ProductImage ImageUrl="@item.ImageUrl"
                                      Alt="@item.ProductName"
                                      Size="ProductImage.ImageSize.Thumb"
                                      PlaceholderIconSize="1.75rem" />

                        <div style="flex: 1; margin: 0 12px;">
                            <MudText Typo="Typo.body1" Style="font-weight: 500;">
                                @item.ProductName
                            </MudText>
                            <MudText Typo="Typo.caption" Class="text-primary-color" Style="font-weight: 600;">
                                @item.Price.ToString("C") / Stk.
                            </MudText>

                            <div class="mt-2" style="display: inline-block;">
                                <QuantityStepper Value="item.Quantity"
                                                 ValueChanged="newValue => HandleQuantityChange(item, newValue)"
                                                 Min="1"
                                                 Variant="QuantityStepper.StepperSize.Compact" />
                            </div>
                        </div>

                        <MudStack AlignItems="AlignItems.End" Spacing="1">
                            <MudText Typo="Typo.body1" Style="font-weight: 700;">
                                @((item.Price * item.Quantity).ToString("C"))
                            </MudText>
                            <MudIconButton Icon="@Icons.Material.Filled.DeleteOutline"
                                           Size="Size.Small"
                                           Color="Color.Error"
                                           aria-label="@($"{item.ProductName} entfernen")"
                                           OnClick="@(() => RemoveItem(item))" />
                        </MudStack>

                    </MudStack>
                </div>
            }
        </div>

        <div style="flex-shrink: 0; padding: 20px 24px; border-top: 1px solid var(--mud-palette-divider);">

            <MudStack Row="true" Justify="Justify.SpaceBetween" Class="mb-2">
                <MudText Typo="Typo.body2" Class="text-muted">Zwischensumme</MudText>
                <MudText Typo="Typo.body2">
                    @_items.Sum(x => x.Price * x.Quantity).ToString("C")
                </MudText>
            </MudStack>

            <MudStack Row="true" Justify="Justify.SpaceBetween" Class="mb-2">
                <MudText Typo="Typo.body2" Class="text-muted">Versand</MudText>
                <MudText Typo="Typo.body2" Style="color: var(--mud-palette-success); font-weight: 500;">Kostenlos</MudText>
            </MudStack>

            <MudDivider Class="my-3" />

            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Baseline" Class="mb-4">
                <MudText Typo="Typo.body1" Style="font-weight: 700;">Gesamt</MudText>
                <span class="os-mono" style="font-size: 1.25rem; font-weight: 700; color: var(--mud-palette-text-primary);">
                    @_items.Sum(x => x.Price * x.Quantity).ToString("C")
                </span>
            </MudStack>

            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       FullWidth="true"
                       Href="/checkout"
                       EndIcon="@Icons.Material.Outlined.ArrowForward"
                       Class="btn-pill">
                Zur Kasse
            </MudButton>

            <MudButton Variant="Variant.Text"
                       FullWidth="true"
                       Href="/shop"
                       Color="Color.Default"
                       Class="mt-2"
                       Style="border-radius: 100px;">
                Weiter shoppen
            </MudButton>

        </div>
    }

</MudDrawer>

@code {
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public EventCallback<bool> IsOpenChanged { get; set; }
    [Parameter] public EventCallback<int> OnItemCountChanged { get; set; }

    private List<CartItemViewModel> _items = [];
    private bool _wasOpen = false;

    protected override async Task OnInitializedAsync()
    {
        CartService.OnCartUpdated += OnCartUpdated;
        var cart = await CartService.GetCartAsync();
        ApplyCart(cart);
        await UpdateItemCount();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (IsOpen && !_wasOpen)
        {
            var cart = await CartService.GetCartAsync();
            ApplyCart(cart);
            await UpdateItemCount();
        }
        _wasOpen = IsOpen;
    }

    private void OnCartUpdated(CartChangedEventArgs args)
    {
        _ = InvokeAsync(async () =>
        {
            var currentCustomerId = await CurrentUserService.GetCustomerIdAsync();

            if (currentCustomerId is null || currentCustomerId.Value != args.CustomerId)
                return;

            ApplyCart(args.Cart);
            await UpdateItemCount();
            StateHasChanged();
        });
    }

    private void ApplyCart(CartDto? cart)
    {
        _items = cart?.Items?
            .Select(CartItemViewModel.FromDto)
            .ToList()
            ?? [];
    }

    private async Task HandleQuantityChange(CartItemViewModel item, int newValue)
    {
        if (newValue > item.Quantity)
        {
            await IncreaseQuantity(item);
        }
        else if (newValue < item.Quantity)
        {
            await DecreaseQuantity(item);
        }
    }

    private async Task IncreaseQuantity(CartItemViewModel item)
    {
        var customerId = await CurrentUserService.GetCustomerIdAsync();

        if (customerId is null)
            return;

        var result = await Sender.Send(new AddToCartCommand(customerId.Value, item.ProductId, 1));

        if (!result.IsSuccess)
            return;

        await CartService.RefreshCartAsync();
    }

    private async Task DecreaseQuantity(CartItemViewModel item)
    {
        var customerId = await CurrentUserService.GetCustomerIdAsync();

        if (customerId is null)
            return;

        var result = await Sender.Send(new DecreaseCartItemQuantityCommand(customerId.Value, item.ProductId));

        if (!result.IsSuccess)
            return;

        await CartService.RefreshCartAsync();
    }

    private async Task RemoveItem(CartItemViewModel item)
    {
        var customerId = await CurrentUserService.GetCustomerIdAsync();

        if (customerId is null)
            return;

        var result = await Sender.Send(new RemoveFromCartCommand(customerId.Value, item.ProductId));

        if (!result.IsSuccess)
            return;

        await CartService.RefreshCartAsync();
    }

    private async Task UpdateItemCount()
    {
        await OnItemCountChanged.InvokeAsync(_items.Sum(x => x.Quantity));
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        var method = IsOpen ? "lock" : "unlock";
        await JS.InvokeVoidAsync(method);
    }

    private sealed class CartItemViewModel
    {
        public Guid ProductId { get; init; }
        public string ProductName { get; init; } = string.Empty;
        public string? ImageUrl { get; init; }
        public decimal Price { get; init; }
        public int Quantity { get; set; }

        public static CartItemViewModel FromDto(CardItemDto dto) => new()
        {
            ProductId = dto.ProductId,
            ProductName = dto.ProductName,
            Price = dto.Price,
            Quantity = dto.Quantity
        };
    }

    public async ValueTask DisposeAsync()
    {
        CartService.OnCartUpdated -= OnCartUpdated;
        await Task.CompletedTask;
    }
}

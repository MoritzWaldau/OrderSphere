@inherits LayoutComponentBase
@implements IDisposable
@inject ThemeState ThemeState
@inject ISnackbar Snackbar
@inject NotificationHubClient NotificationHub
@inject NavigationManager Nav
@inject IDialogService DialogService
@inject AuthenticationStateProvider AuthStateProvider

<MudThemeProvider Theme="ThemeState.Theme" IsDarkMode="ThemeState.IsDarkMode" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <AppHeader OnCartToggle="ToggleCart"
               CartItemCount="@_cartItemCount"
               IsCartOpen="@_cartOpen" />

    <MudMainContent Style="padding-top: 64px;">
        <CascadingValue Value="this">
            <AppErrorBoundary>
                @Body
            </AppErrorBoundary>
        </CascadingValue>
    </MudMainContent>

    <CartDrawer IsOpen="@_cartOpen" IsOpenChanged="val => _cartOpen = val" />

    @* The advisor is an authenticated feature (per-user chat history, MCP calls with the
       caller's bearer token) and is reached through the gateway like every other API, whose
       routes require login. Hide it from anonymous visitors so they never trigger a 401. *@
    <AuthorizeView>
        <Authorized>
            <AdvisorDrawer IsOpen="@_advisorOpen" IsOpenChanged="val => _advisorOpen = val" />

            <MudFab Color="Color.Primary"
                    StartIcon="@Icons.Material.Filled.SupportAgent"
                    Style="position:fixed;bottom:24px;right:24px;z-index:1300;"
                    OnClick="ToggleAdvisor"
                    aria-label="Berater öffnen" />
        </Authorized>
    </AuthorizeView>

    <AppFooter />
</MudLayout>

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }
    [Inject] private CartState CartState { get; set; } = default!;
    [Inject] private IJSRuntime JS { get; set; } = default!;
    [Inject] private ILogger<MainLayout> Logger { get; set; } = default!;

    private bool _cartOpen;
    private bool _advisorOpen;
    private int _cartItemCount;
    private bool _onboardingPromptShown;

    protected override void OnInitialized()
    {
        CartState.OnChange += StateHasChangedSafe;
        ThemeState.OnChange += StateHasChangedSafe;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        // Restore the persisted design brand (applies to anonymous and authenticated users).
        try
        {
            var savedBrand = await JS.InvokeAsync<string?>("localStorage.getItem", "os-brand");
            if (!string.IsNullOrWhiteSpace(savedBrand))
                ThemeState.SetBrand(savedBrand);
        }
        catch { /* localStorage unavailable */ }

        var state = await (AuthState ?? Task.FromResult(new AuthenticationState(new System.Security.Claims.ClaimsPrincipal())));
        if (state.User.Identity?.IsAuthenticated == true)
        {
            var userInfo = state.User.Identity as System.Security.Claims.ClaimsIdentity;
            var onboardingComplete = userInfo?.FindFirst("onboardingComplete")?.Value == "true";

            if (!onboardingComplete && !_onboardingPromptShown)
            {
                _onboardingPromptShown = true;
                var dialog = await DialogService.ShowAsync<OnboardingPromptDialog>(string.Empty,
                    new DialogOptions { CloseOnEscapeKey = false, BackdropClick = false, MaxWidth = MaxWidth.Small, FullWidth = true });
                var result = await dialog.Result;
                // Skip path: SkipOnboardingAsync already called inside the dialog.
                // Fill path: dialog navigated to /onboarding.
                // Either way the onboarding claim needs refreshing.
                ((BffAuthStateProvider)AuthStateProvider).NotifyAuthStateChanged();
            }

            await CartState.InitializeAsync();
            _cartItemCount = CartState.ItemCount;

            NotificationHub.OnNotificationReceived += OnNotificationReceived;
            try { await NotificationHub.StartAsync(); }
            catch (Exception ex) { Logger.LogWarning(ex, "SignalR notification hub connection failed"); }

            StateHasChanged();
        }
    }

    private void StateHasChangedSafe()
    {
        _cartItemCount = CartState.ItemCount;
        InvokeAsync(StateHasChanged);
    }

    private void OnNotificationReceived(NotificationMessage notification)
    {
        InvokeAsync(() =>
        {
            var severity = notification.Type switch
            {
                "OrderConfirmed" => MudBlazor.Severity.Success,
                "OrderCancelled" => MudBlazor.Severity.Error,
                _ => MudBlazor.Severity.Info
            };
            Snackbar.Add($"{notification.Title}: {notification.Message}", severity);
        });
    }

    private void ToggleCart() => _cartOpen = !_cartOpen;

    private void ToggleAdvisor() => _advisorOpen = !_advisorOpen;

    public void Dispose()
    {
        CartState.OnChange -= StateHasChangedSafe;
        ThemeState.OnChange -= StateHasChangedSafe;
        NotificationHub.OnNotificationReceived -= OnNotificationReceived;
    }
}

@page "/checkout"
@attribute [Authorize]
@inject IOrderingClient Ordering
@inject CartState CartState
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<PageTitle>Checkout — OrderSphere</PageTitle>

<PageHero Eyebrow="Warenkorb → Checkout → Bestätigung"
          Title="Checkout"
          Subtitle="Prüfe deine Angaben, wähle Versand und Zahlung." />

<section style="padding:48px 0 80px;">
    <MudContainer>
        <MudForm @ref="_form" @bind-IsValid="_formValid">
        <MudGrid Spacing="4">
            <!-- Left: form -->
            <MudItem xs="12" lg="8">
                <MudStack Spacing="4">
                    <!-- Shipping -->
                    <MudPaper Elevation="0" Class="surface-card-lg pa-6">
                        <MudText Typo="Typo.h5" Class="mb-4">Lieferadresse</MudText>
                        <MudGrid Spacing="3">
                            <MudItem xs="12" md="6">
                                <MudTextField T="string" Label="Vorname" Variant="Variant.Outlined"
                                              FullWidth="true" Required="true" RequiredError="Pflichtfeld"
                                              @bind-Value="_model.FirstName" />
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudTextField T="string" Label="Nachname" Variant="Variant.Outlined"
                                              FullWidth="true" Required="true" RequiredError="Pflichtfeld"
                                              @bind-Value="_model.LastName" />
                            </MudItem>
                            <MudItem xs="12">
                                <MudTextField T="string" Label="Straße und Hausnummer" Variant="Variant.Outlined"
                                              FullWidth="true" Required="true" RequiredError="Pflichtfeld"
                                              @bind-Value="_model.Street" />
                            </MudItem>
                            <MudItem xs="12" md="4">
                                <MudTextField T="string" Label="PLZ" Variant="Variant.Outlined"
                                              FullWidth="true" Required="true" RequiredError="Pflichtfeld"
                                              Validation="@((string v) => System.Text.RegularExpressions.Regex.IsMatch(v ?? "", @"^\d{4,5}$") ? null : "Ungültige PLZ")"
                                              @bind-Value="_model.PostalCode" />
                            </MudItem>
                            <MudItem xs="12" md="5">
                                <MudTextField T="string" Label="Stadt" Variant="Variant.Outlined"
                                              FullWidth="true" Required="true" RequiredError="Pflichtfeld"
                                              @bind-Value="_model.City" />
                            </MudItem>
                            <MudItem xs="12" md="3">
                                <MudSelect T="string" Label="Land" Variant="Variant.Outlined"
                                           FullWidth="true" @bind-Value="_model.Country">
                                    <MudSelectItem T="string" Value="@("Deutschland")">Deutschland</MudSelectItem>
                                    <MudSelectItem T="string" Value="@("Österreich")">Österreich</MudSelectItem>
                                    <MudSelectItem T="string" Value="@("Schweiz")">Schweiz</MudSelectItem>
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudTextField T="string" Label="E-Mail" Variant="Variant.Outlined"
                                              FullWidth="true" Required="true" RequiredError="Pflichtfeld"
                                              InputType="InputType.Email"
                                              Validation="@((string v) => v?.Contains('@') == true ? null : "Ungültige E-Mail-Adresse")"
                                              @bind-Value="_model.Email" />
                            </MudItem>
                        </MudGrid>
                    </MudPaper>

                    <!-- Payment -->
                    <MudPaper Elevation="0" Class="surface-card-lg pa-6">
                        <MudText Typo="Typo.h5" Class="mb-4">Zahlungsart</MudText>
                        <MudRadioGroup T="int" @bind-Value="_model.PaymentMethod">
                            <MudStack Spacing="2">
                                <MudPaper Elevation="0" Class="surface-card pa-4">
                                    <MudRadio T="int" Value="0" Color="Color.Primary">Kreditkarte</MudRadio>
                                </MudPaper>
                                <MudPaper Elevation="0" Class="surface-card pa-4">
                                    <MudRadio T="int" Value="1" Color="Color.Primary">PayPal</MudRadio>
                                </MudPaper>
                                <MudPaper Elevation="0" Class="surface-card pa-4">
                                    <MudRadio T="int" Value="2" Color="Color.Primary">Kauf auf Rechnung</MudRadio>
                                </MudPaper>
                            </MudStack>
                        </MudRadioGroup>
                    </MudPaper>
                </MudStack>
            </MudItem>

            <!-- Right: order summary -->
            <MudItem xs="12" lg="4">
                <MudPaper Elevation="0" Class="surface-card-lg pa-6"
                          Style="position:sticky;top:100px;">
                    <MudText Typo="Typo.h5" Class="mb-4">Bestellübersicht</MudText>
                    <MudStack Spacing="3">
                        @foreach (var item in _cartItems)
                        {
                            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                <MudStack Spacing="0">
                                    <MudText Typo="Typo.subtitle2">@item.ProductName</MudText>
                                    <MudText Typo="Typo.caption" Class="text-muted">Menge: @item.Quantity</MudText>
                                </MudStack>
                                <MudText Typo="Typo.body2">
                                    @((item.Price * item.Quantity).ToString("0.00")) €
                                </MudText>
                            </MudStack>
                        }

                        <MudDivider />

                        <MudStack Row="true" Justify="Justify.SpaceBetween">
                            <MudText Typo="Typo.body1">Zwischensumme</MudText>
                            <MudText Typo="Typo.body1">@Subtotal.ToString("0.00") €</MudText>
                        </MudStack>
                        <MudStack Row="true" Justify="Justify.SpaceBetween">
                            <MudText Typo="Typo.body1">Versand</MudText>
                            <MudText Typo="Typo.body1">Kostenlos</MudText>
                        </MudStack>

                        <!-- Coupon -->
                        <MudDivider />
                        @if (_appliedCoupon is not null)
                        {
                            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                <MudStack Spacing="0">
                                    <MudText Typo="Typo.body2" Color="Color.Success">
                                        Gutschein (@_couponCode.ToUpperInvariant())
                                    </MudText>
                                    <MudText Typo="Typo.caption" Class="text-muted">@_appliedCoupon.Message</MudText>
                                </MudStack>
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                    <MudText Typo="Typo.body2" Color="Color.Success">
                                        -@_appliedCoupon.DiscountAmount.ToString("0.00") €
                                    </MudText>
                                    <MudIconButton Icon="@Icons.Material.Outlined.Close"
                                                   Size="Size.Small" OnClick="RemoveCoupon" />
                                </MudStack>
                            </MudStack>
                        }
                        else
                        {
                            <MudStack Row="true" Spacing="2">
                                <MudTextField T="string" Label="Gutscheincode" Variant="Variant.Outlined"
                                              FullWidth="true" @bind-Value="_couponCode"
                                              @onkeydown="OnCouponKeyDown" />
                                <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                                           OnClick="ApplyCouponAsync" Disabled="_validatingCoupon"
                                           Style="white-space:nowrap;align-self:center;">
                                    @if (_validatingCoupon)
                                    {
                                        <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                                    }
                                    else
                                    {
                                        <span>Einlösen</span>
                                    }
                                </MudButton>
                            </MudStack>
                        }

                        <MudDivider />

                        <MudStack Row="true" Justify="Justify.SpaceBetween">
                            <MudText Typo="Typo.h6">Gesamt</MudText>
                            <MudText Typo="Typo.h6">@Total.ToString("0.00") €</MudText>
                        </MudStack>

                        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                   FullWidth="true" Class="btn-pill my-4" Size="Size.Large"
                                   Disabled="_submitting || !_formValid"
                                   OnClick="SubmitAsync">
                            @if (_submitting)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                            }
                            Bestellung abschließen
                        </MudButton>

                        <MudText Typo="Typo.caption" Class="text-muted">
                            Mit dem Abschluss stimmst du unseren AGB zu.
                        </MudText>
                    </MudStack>
                </MudPaper>
            </MudItem>
        </MudGrid>
        </MudForm>
    </MudContainer>
</section>

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private MudForm _form = default!;
    private bool _formValid;
    private List<CartItemDto> _cartItems = [];
    private bool _submitting;
    private bool _validatingCoupon;
    private string _couponCode = string.Empty;
    private CouponValidationDto? _appliedCoupon;

    private Guid _idempotencyKey = Guid.CreateVersion7();

    private readonly CheckoutFormModel _model = new()
    {
        Country = "Deutschland",
        PaymentMethod = 0
    };

    private decimal Subtotal => _cartItems.Sum(i => i.Quantity * i.Price);
    private decimal Discount => _appliedCoupon?.DiscountAmount ?? 0m;
    private decimal Total => Subtotal - Discount;

    protected override async Task OnInitializedAsync()
    {
        var state = await (AuthState ?? Task.FromResult(new AuthenticationState(new System.Security.Claims.ClaimsPrincipal())));
        var email = state.User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value ?? string.Empty;
        _model.Email = email;

        _cartItems = CartState.Cart?.Items ?? [];
        if (!_cartItems.Any())
        {
            var cart = await Ordering.GetCartAsync();
            _cartItems = cart?.Items ?? [];
        }
    }

    private async Task ApplyCouponAsync()
    {
        var code = _couponCode.Trim();
        if (string.IsNullOrEmpty(code)) return;

        _validatingCoupon = true;
        try
        {
            var result = await Ordering.ValidateCouponAsync(code, Subtotal);
            if (result is null || !result.IsValid)
            {
                Snackbar.Add(result?.Message ?? "Ungültiger Gutscheincode.", Severity.Warning);
                return;
            }
            _appliedCoupon = result;
        }
        finally
        {
            _validatingCoupon = false;
        }
    }

    private void RemoveCoupon()
    {
        _appliedCoupon = null;
        _couponCode = string.Empty;
    }

    private void OnCouponKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") _ = ApplyCouponAsync();
    }

    private async Task SubmitAsync()
    {
        await _form.ValidateAsync();
        if (!_formValid) return;

        _submitting = true;
        try
        {
            var request = new CheckoutRequest(
                new CheckoutAddress(_model.FirstName, _model.LastName, _model.Street,
                    _model.City, _model.PostalCode, _model.Country),
                _model.PaymentMethod);

            var correlationId = await Ordering.CheckoutAsync(request, _idempotencyKey);
            if (correlationId is null)
            {
                Snackbar.Add("Bestellung konnte nicht abgeschlossen werden.", Severity.Error);
                return;
            }

            await CartState.RefreshAsync();
            Navigation.NavigateTo(
                $"/checkout/success?correlationId={correlationId}&total={Total.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture)}");
        }
        finally
        {
            _submitting = false;
        }
    }

    private sealed class CheckoutFormModel
    {
        public string FirstName { get; set; } = string.Empty;
        public string LastName  { get; set; } = string.Empty;
        public string Street    { get; set; } = string.Empty;
        public string PostalCode { get; set; } = string.Empty;
        public string City      { get; set; } = string.Empty;
        public string Country   { get; set; } = string.Empty;
        public string Email     { get; set; } = string.Empty;
        public int PaymentMethod { get; set; }
    }
}

@page "/shop/{category}/{slug}"
@attribute [Authorize]
@inject ICatalogClient Catalog
@inject IOrderingClient Ordering
@inject CartState CartState
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject IStringLocalizer<AppStrings> L

<PageTitle>@(_product?.Name ?? L["ProductDetails.PageFallback"]) – OrderSphere</PageTitle>

@if (_loading)
{
    <div style="display:flex;justify-content:center;align-items:center;min-height:60vh;">
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
    </div>
}
else if (_product is null)
{
    <MudContainer MaxWidth="MaxWidth.Small" Class="text-center" Style="padding:80px 0;">
        <MudText Typo="Typo.h5">@L["ProductDetails.NotFound"]</MudText>
        <MudButton Href="/shop" Variant="Variant.Filled" Color="Color.Primary" Class="btn-pill mt-4">
            @L["ProductDetails.BackToShop"]
        </MudButton>
    </MudContainer>
}
else
{
    <section style="padding:64px 0 80px;">
        <MudContainer MaxWidth="MaxWidth.Large">
            <MudGrid Spacing="6">
                <!-- Image -->
                <MudItem xs="12" md="6">
                    <MudPaper Elevation="0"
                              Style="border-radius:20px;overflow:hidden;background:var(--mud-palette-background-grey);aspect-ratio:4/3;display:flex;align-items:center;justify-content:center;">
                        @if (!string.IsNullOrWhiteSpace(_product.ImageUrl))
                        {
                            <img src="@_product.ImageUrl" alt="@_product.Name"
                                 style="max-height:100%;max-width:100%;object-fit:contain;" />
                        }
                        else
                        {
                            <MudIcon Icon="@Icons.Material.Outlined.Inventory2"
                                     Style="font-size:120px;color:var(--mud-palette-divider);" />
                        }
                    </MudPaper>
                </MudItem>

                <!-- Details -->
                <MudItem xs="12" md="6">
                    <MudStack Spacing="4">
                        <div>
                            <span class="os-eyebrow">@_product.CategoryName</span>
                            <MudText Typo="Typo.h3" Style="margin-top:8px;font-weight:700;">@_product.Name</MudText>
                            @if (_product.ReviewCount > 0)
                            {
                                <div style="margin-top:8px;">
                                    <StarRating Value="_product.AverageRating" Count="_product.ReviewCount" />
                                </div>
                            }
                            <span class="os-mono" style="font-size:1.75rem;font-weight:700;display:block;margin-top:16px;">
                                @Formatting.Currency(_product.Price)
                            </span>
                        </div>

                        <MudText Typo="Typo.body1" Color="Color.Secondary" Style="line-height:1.7;">
                            @_product.Description
                        </MudText>

                        @if (_product.Stock > 0)
                        {
                            <MudText Typo="Typo.caption" Color="Color.Success">
                                ✓ @L["Stock.InStockCount", _product.Stock]
                            </MudText>
                        }
                        else
                        {
                            <MudText Typo="Typo.caption" Color="Color.Error">✕ @L["Common.SoldOut"]</MudText>
                        }

                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                            <MudNumericField T="int" @bind-Value="_quantity"
                                             Min="1" Max="@_product.Stock"
                                             Label="@L["Common.Quantity"]" Variant="Variant.Outlined"
                                             Style="max-width:120px;" />
                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       Size="Size.Large"
                                       Class="btn-pill"
                                       Disabled="@(_product.Stock == 0 || _adding)"
                                       OnClick="AddToCartAsync">
                                @if (_adding)
                                {
                                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                                }
                                @L["Common.AddToCart"]
                            </MudButton>
                        </MudStack>

                        <MudDivider />

                        <MudStack Spacing="1">
                            <MudText Typo="Typo.caption" Class="text-muted">SKU: @_product.SKU</MudText>
                        </MudStack>
                    </MudStack>
                </MudItem>
            </MudGrid>
        </MudContainer>
    </section>

    <section style="padding:0 0 80px;">
        <MudContainer MaxWidth="MaxWidth.Large">
            <MudDivider Class="mb-8" />
            <MudGrid Spacing="6">
                <!-- Write a review -->
                <MudItem xs="12" md="5">
                    <MudText Typo="Typo.h5" Style="font-weight:700;" Class="mb-2">@L["Reviews.WriteTitle"]</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">@L["Reviews.WriteHint"]</MudText>

                    <MudStack Spacing="3">
                        <div>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">@L["Reviews.RatingLabel"]</MudText>
                            <MudRating @bind-SelectedValue="_newRating" MaxValue="5" />
                        </div>
                        <MudTextField @bind-Value="_newTitle" Label="@L["Reviews.TitleLabel"]"
                                      Variant="Variant.Outlined" MaxLength="150" Immediate="true" />
                        <MudTextField @bind-Value="_newBody" Label="@L["Reviews.BodyLabel"]"
                                      Variant="Variant.Outlined" Lines="4" MaxLength="2000" Immediate="true" />
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="btn-pill"
                                   Disabled="@(_submitting || _newRating == 0 || string.IsNullOrWhiteSpace(_newTitle) || string.IsNullOrWhiteSpace(_newBody))"
                                   OnClick="SubmitReviewAsync">
                            @if (_submitting)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                            }
                            @L["Reviews.Submit"]
                        </MudButton>
                    </MudStack>
                </MudItem>

                <!-- Existing reviews -->
                <MudItem xs="12" md="7">
                    <MudText Typo="Typo.h5" Style="font-weight:700;" Class="mb-4">
                        @L["Reviews.ListTitle"] (@_reviews.Count)
                    </MudText>

                    @if (_reviews.Count == 0)
                    {
                        <MudText Typo="Typo.body2" Color="Color.Secondary">@L["Reviews.Empty"]</MudText>
                    }
                    else
                    {
                        <MudStack Spacing="4">
                            @foreach (var review in _reviews)
                            {
                                <MudPaper Elevation="0" Style="padding:16px;border:1px solid var(--mud-palette-divider);border-radius:12px;">
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                        <StarRating Value="review.Rating" ShowCount="false" />
                                        @if (review.IsVerifiedPurchase)
                                        {
                                            <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Text"
                                                     Icon="@Icons.Material.Filled.Verified">
                                                @L["Reviews.VerifiedPurchase"]
                                            </MudChip>
                                        }
                                    </MudStack>
                                    <MudText Typo="Typo.subtitle1" Style="font-weight:600;margin-top:8px;">@review.Title</MudText>
                                    <MudText Typo="Typo.body2" Color="Color.Secondary" Style="line-height:1.6;">@review.Body</MudText>
                                    <MudText Typo="Typo.caption" Class="text-muted" Style="display:block;margin-top:8px;">
                                        @review.CreatedAt.ToLocalTime().ToString("d")
                                    </MudText>
                                </MudPaper>
                            }
                        </MudStack>
                    }
                </MudItem>
            </MudGrid>
        </MudContainer>
    </section>
}

@code {
    [Parameter] public string Category { get; set; } = string.Empty;
    [Parameter] public string Slug { get; set; } = string.Empty;

    private ProductDto? _product;
    private bool _loading = true;
    private bool _adding;
    private int _quantity = 1;

    private List<ReviewDto> _reviews = [];
    private int _newRating;
    private string _newTitle = string.Empty;
    private string _newBody = string.Empty;
    private bool _submitting;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var res = await Catalog.GetProductBySlugAsync(Slug);
            _product = res.Value;
            if (!res.IsSuccess && res.Error!.Kind != ApiErrorKind.NotFound)
                Snackbar.Add(res.Error!.Message, Severity.Error);

            if (_product is not null)
                await LoadReviewsAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(L["ProductDetails.Error", ex.Message], Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task LoadReviewsAsync()
    {
        if (_product is null) return;
        var res = await Catalog.GetReviewsAsync(_product.Id);
        if (res.IsSuccess)
            _reviews = res.Value ?? [];
    }

    private async Task SubmitReviewAsync()
    {
        if (_product is null) return;
        _submitting = true;
        try
        {
            var result = await Catalog.CreateReviewAsync(
                _product.Id, new CreateReviewRequest(_newRating, _newTitle.Trim(), _newBody.Trim()));

            if (result.IsSuccess)
            {
                Snackbar.Add(L["Reviews.SubmitSuccess"], Severity.Success);
                _newRating = 0;
                _newTitle = string.Empty;
                _newBody = string.Empty;

                // Refresh reviews and the product so the average rating updates.
                await LoadReviewsAsync();
                var refreshed = await Catalog.GetProductBySlugAsync(Slug);
                if (refreshed.IsSuccess)
                    _product = refreshed.Value;
            }
            else
            {
                Snackbar.Add(result.Error!.Message, Severity.Error);
            }
        }
        finally
        {
            _submitting = false;
        }
    }

    private async Task AddToCartAsync()
    {
        if (_product is null) return;
        _adding = true;
        try
        {
            var result = await Ordering.AddToCartAsync(_product.Id, _quantity);
            if (result.IsSuccess)
            {
                Snackbar.Add(L["Common.AddedToCart", _quantity, _product.Name], Severity.Success);
                await CartState.RefreshAsync();
            }
            else
            {
                Snackbar.Add(result.Error!.Message, Severity.Error);
            }
        }
        finally
        {
            _adding = false;
        }
    }
}

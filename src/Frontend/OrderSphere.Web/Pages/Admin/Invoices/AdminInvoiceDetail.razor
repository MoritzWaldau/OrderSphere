@page "/admin/invoices/{InvoiceId:guid}"
@inject IAdminInvoicingClient AdminInvoicing
@inject ISnackbar Snackbar
@inject IStringLocalizer<AppStrings> L

<PageTitle>@L["Admin.Invoices.Detail.PageTitle"]</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="py-8">
    <MudButton Variant="Variant.Text" StartIcon="@Icons.Material.Outlined.ArrowBack"
               Href="/admin/invoices" Class="mb-4">
        @L["Admin.Invoices.Detail.BackToList"]
    </MudButton>

    @if (_loading)
    {
        <MudStack AlignItems="AlignItems.Center" Class="py-12">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
        </MudStack>
    }
    else if (_invoice is null)
    {
        <MudPaper Elevation="0" Class="pa-12 text-center" Style="border-radius:16px;border:1px solid var(--mud-palette-divider);">
            <MudIcon Icon="@Icons.Material.Outlined.SearchOff" Color="Color.Secondary" Style="font-size:64px;" Class="mb-3" />
            <MudText Typo="Typo.h6">@L["Admin.Invoices.Detail.NotFound"]</MudText>
        </MudPaper>
    }
    else
    {
        <MudGrid>
            <MudItem xs="12" md="8">
                <MudStack Spacing="4">
                    <MudPaper Elevation="0" Class="pa-6" Style="border-radius:16px;border:1px solid var(--mud-palette-divider);">
                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-4">
                            <MudStack Spacing="0">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">@L["Admin.Invoices.ColNumber"]</MudText>
                                <MudText Typo="Typo.h5" Class="os-mono" Style="font-weight:700;">@_invoice.InvoiceNumber</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                    @Formatting.DateTime(_invoice.IssuedAt.ToLocalTime())
                                </MudText>
                            </MudStack>
                            <MudChip T="string" Color="@StatusColor(_invoice.Status)" Size="Size.Medium"
                                     Variant="Variant.Filled" Style="border-radius:100px;font-weight:600;">
                                @StatusLabel(_invoice.Status)
                            </MudChip>
                        </MudStack>
                        <MudDivider Class="mb-3" />
                        <MudText Typo="Typo.body2" Color="Color.Secondary">@_invoice.CustomerName</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">@_invoice.CustomerEmail</MudText>
                    </MudPaper>

                    <MudPaper Elevation="0" Class="pa-6" Style="border-radius:16px;border:1px solid var(--mud-palette-divider);">
                        <MudText Typo="Typo.h6" Class="mb-4" Style="font-weight:600;">@L["Admin.Invoices.Detail.OriginalAmounts"]</MudText>
                        <MudStack Spacing="2">
                            <MudStack Row="true" Justify="Justify.SpaceBetween">
                                <MudText Typo="Typo.body2" Class="text-muted">@L["Admin.Invoices.Detail.Net"]</MudText>
                                <MudText Typo="Typo.body2">@Formatting.Currency(_invoice.NetAmount)</MudText>
                            </MudStack>
                            <MudStack Row="true" Justify="Justify.SpaceBetween">
                                <MudText Typo="Typo.body2" Class="text-muted">@L["Admin.Invoices.Detail.Tax"] (@_invoice.TaxRate.ToString("P0"))</MudText>
                                <MudText Typo="Typo.body2">@Formatting.Currency(_invoice.TaxAmount)</MudText>
                            </MudStack>
                            <MudDivider />
                            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                <MudText Typo="Typo.h6" Style="font-weight:600;">@L["Admin.Invoices.Detail.Total"]</MudText>
                                <MudText Typo="Typo.h6" Style="font-weight:700;">@Formatting.Currency(_invoice.Total)</MudText>
                            </MudStack>
                        </MudStack>
                    </MudPaper>

                    @if (_invoice.Adjustments.Count > 0)
                    {
                        <MudPaper Elevation="0" Class="pa-6" Style="border-radius:16px;border:1px solid var(--mud-palette-divider);">
                            <MudText Typo="Typo.h6" Class="mb-4" Style="font-weight:600;">@L["Admin.Invoices.Detail.AdjustedAmounts"]</MudText>
                            <MudStack Spacing="2">
                                <MudStack Row="true" Justify="Justify.SpaceBetween">
                                    <MudText Typo="Typo.body2" Class="text-muted">@L["Admin.Invoices.Detail.Net"]</MudText>
                                    <MudText Typo="Typo.body2">@Formatting.Currency(_invoice.AdjustedNet)</MudText>
                                </MudStack>
                                <MudStack Row="true" Justify="Justify.SpaceBetween">
                                    <MudText Typo="Typo.body2" Class="text-muted">@L["Admin.Invoices.Detail.Tax"]</MudText>
                                    <MudText Typo="Typo.body2">@Formatting.Currency(_invoice.AdjustedTax)</MudText>
                                </MudStack>
                                <MudDivider />
                                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                    <MudText Typo="Typo.h6" Style="font-weight:600;">@L["Admin.Invoices.Detail.AdjustedTotal"]</MudText>
                                    <MudText Typo="Typo.h6" Style="font-weight:700;color:var(--mud-palette-primary);">
                                        @Formatting.Currency(_invoice.AdjustedTotal)
                                    </MudText>
                                </MudStack>
                            </MudStack>

                            <MudDivider Class="my-4" />

                            <MudText Typo="Typo.subtitle2" Class="mb-2" Style="font-weight:600;">@L["Admin.Invoices.Detail.History"]</MudText>
                            <MudSimpleTable Dense="true" Hover="false" Bordered="false" Striped="false" Style="background:transparent;">
                                <thead>
                                    <tr>
                                        <th>@L["Admin.Invoices.Detail.ColType"]</th>
                                        <th>@L["Admin.Invoices.Detail.ColReason"]</th>
                                        <th>@L["Admin.Invoices.ColAmount"]</th>
                                        <th>@L["Admin.Invoices.Detail.ColAppliedBy"]</th>
                                        <th>@L["Admin.Invoices.ColDate"]</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var adjustment in _invoice.Adjustments)
                                    {
                                        <tr>
                                            <td>@AdjustmentTypeLabel(adjustment.Type)</td>
                                            <td>@adjustment.Reason</td>
                                            <td>-@Formatting.Currency(adjustment.AmountNet)</td>
                                            <td>@adjustment.AppliedBy</td>
                                            <td>@Formatting.DateTime(adjustment.AppliedAt.ToLocalTime())</td>
                                        </tr>
                                    }
                                </tbody>
                            </MudSimpleTable>
                        </MudPaper>
                    }

                    <MudButton Href="@AdminInvoicing.GetPdfUrl(_invoice.OrderId)" Target="_blank"
                               Variant="Variant.Outlined" Color="Color.Primary" Class="btn-pill-outline" Style="align-self:flex-start;"
                               StartIcon="@Icons.Material.Outlined.PictureAsPdf">
                        @L["Admin.Invoices.ViewInvoice"]
                    </MudButton>
                </MudStack>
            </MudItem>

            <MudItem xs="12" md="4">
                <MudStack Spacing="4" Style="position:sticky;top:80px;">
                    <MudPaper Elevation="0" Class="pa-6" Style="border-radius:16px;border:1px solid var(--mud-palette-divider);">
                        <MudText Typo="Typo.h6" Class="mb-4" Style="font-weight:600;">@L["Admin.Invoices.Detail.ApplyDiscount"]</MudText>
                        <MudRadioGroup T="string" @bind-Value="_discountMode" Class="mb-2">
                            <MudRadio T="string" Value="@("absolute")" Color="Color.Primary">@L["Admin.Invoices.Detail.DiscountModeAbsolute"]</MudRadio>
                            <MudRadio T="string" Value="@("percentage")" Color="Color.Primary">@L["Admin.Invoices.Detail.DiscountModePercentage"]</MudRadio>
                        </MudRadioGroup>
                        @if (_discountMode == "absolute")
                        {
                            <MudNumericField T="decimal?" @bind-Value="_discountAmount" Label="@L["Admin.Invoices.Detail.AmountLabel"]"
                                             Variant="Variant.Outlined" Margin="Margin.Dense" Min="0.01m" Class="mb-2" />
                        }
                        else
                        {
                            <MudNumericField T="decimal?" @bind-Value="_discountPercentage" Label="@L["Admin.Invoices.Detail.PercentageLabel"]"
                                             Variant="Variant.Outlined" Margin="Margin.Dense" Min="0.01m" Max="100m" Class="mb-2" />
                        }
                        <MudTextField @bind-Value="_discountReason" Label="@L["Admin.Invoices.Detail.ReasonLabel"]"
                                      Variant="Variant.Outlined" Margin="Margin.Dense" Lines="2" Class="mb-3" />
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                                   Disabled="@(_busy || !CanSubmitDiscount)" OnClick="SubmitDiscountAsync">
                            @L["Admin.Invoices.Detail.SubmitDiscount"]
                        </MudButton>
                    </MudPaper>

                    <MudPaper Elevation="0" Class="pa-6" Style="border-radius:16px;border:1px solid var(--mud-palette-divider);">
                        <MudText Typo="Typo.h6" Class="mb-4" Style="font-weight:600;">@L["Admin.Invoices.Detail.IssueCredit"]</MudText>
                        <MudNumericField T="decimal?" @bind-Value="_creditAmount" Label="@L["Admin.Invoices.Detail.AmountLabel"]"
                                         Variant="Variant.Outlined" Margin="Margin.Dense" Min="0.01m" Class="mb-2" />
                        <MudTextField @bind-Value="_creditReason" Label="@L["Admin.Invoices.Detail.ReasonLabel"]"
                                      Variant="Variant.Outlined" Margin="Margin.Dense" Lines="2" Class="mb-3" />
                        <MudButton Variant="Variant.Filled" Color="Color.Secondary" FullWidth="true"
                                   Disabled="@(_busy || !CanSubmitCredit)" OnClick="SubmitCreditAsync">
                            @L["Admin.Invoices.Detail.SubmitCredit"]
                        </MudButton>
                    </MudPaper>
                </MudStack>
            </MudItem>
        </MudGrid>
    }
</MudContainer>

@code {
    [Parameter] public Guid InvoiceId { get; set; }

    private AdminInvoiceDto? _invoice;
    private bool _loading = true;
    private bool _busy;

    private string _discountMode = "absolute";
    private decimal? _discountAmount;
    private decimal? _discountPercentage;
    private string _discountReason = string.Empty;

    private decimal? _creditAmount;
    private string _creditReason = string.Empty;

    private bool CanSubmitDiscount =>
        !string.IsNullOrWhiteSpace(_discountReason) &&
        ((_discountMode == "absolute" && _discountAmount is > 0) ||
         (_discountMode == "percentage" && _discountPercentage is > 0));

    private bool CanSubmitCredit => !string.IsNullOrWhiteSpace(_creditReason) && _creditAmount is > 0;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        try
        {
            var result = await AdminInvoicing.GetByIdAsync(InvoiceId);
            _invoice = result.Value;
            if (!result.IsSuccess && result.Error!.Kind != ApiErrorKind.NotFound)
                Snackbar.Add(result.Error!.Message, Severity.Error);
        }
        catch (Exception ex)
        {
            Snackbar.Add(L["Common.LoadError", ex.Message], Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task SubmitDiscountAsync()
    {
        _busy = true;
        try
        {
            var result = _discountMode == "absolute"
                ? await AdminInvoicing.ApplyDiscountAsync(InvoiceId, _discountAmount, null, _discountReason)
                : await AdminInvoicing.ApplyDiscountAsync(InvoiceId, null, _discountPercentage, _discountReason);

            if (result.IsSuccess)
            {
                Snackbar.Add(L["Admin.Invoices.Detail.AdjustmentApplied"], Severity.Success);
                _invoice = result.Value;
                _discountAmount = null;
                _discountPercentage = null;
                _discountReason = string.Empty;
            }
            else
            {
                Snackbar.Add(result.Error!.Message, Severity.Error);
            }
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task SubmitCreditAsync()
    {
        _busy = true;
        try
        {
            var result = await AdminInvoicing.IssueCreditNoteAsync(InvoiceId, _creditAmount!.Value, _creditReason);
            if (result.IsSuccess)
            {
                Snackbar.Add(L["Admin.Invoices.Detail.AdjustmentApplied"], Severity.Success);
                _invoice = result.Value;
                _creditAmount = null;
                _creditReason = string.Empty;
            }
            else
            {
                Snackbar.Add(result.Error!.Message, Severity.Error);
            }
        }
        finally
        {
            _busy = false;
        }
    }

    private string StatusLabel(string s) => s switch
    {
        "Issued" => L["Admin.Invoices.StatusIssued"],
        "Adjusted" => L["Admin.Invoices.StatusAdjusted"],
        "CreditIssued" => L["Admin.Invoices.StatusCreditIssued"],
        _ => s
    };

    private static Color StatusColor(string s) => s switch
    {
        "Adjusted" => Color.Warning,
        "CreditIssued" => Color.Info,
        _ => Color.Success
    };

    private string AdjustmentTypeLabel(string type) => type switch
    {
        "Discount" => L["Admin.Invoices.Detail.TypeDiscount"],
        "Credit" => L["Admin.Invoices.Detail.TypeCredit"],
        _ => type
    };
}

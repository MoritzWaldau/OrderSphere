@page "/privacy"
@layout MainLayout

<PageTitle>Datenschutz — OrderSphere</PageTitle>

<section style="background: linear-gradient(135deg, #0071E3 0%, #0051A8 100%); padding: 60px 0;">
    <MudContainer>
        <MudText Typo="Typo.h2" Align="Align.Center" Style="color: #FFFFFF; letter-spacing: -0.02em;">
            Datenschutzerklärung
        </MudText>
    </MudContainer>
</section>

<section style="background: #F5F5F7; padding: 60px 0; min-height: 60vh;">
    <MudContainer MaxWidth="MaxWidth.Medium">
        <MudPaper Elevation="0" Class="pa-8"
                  Style="border-radius: 20px; border: 1px solid var(--mud-palette-divider); background: #FFFFFF;">

            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mb-6">
                Platzhalter-Datenschutzerklärung. Vor Live-Schaltung durch eine geprüfte Version (z.B. von einem Anwalt oder DSGVO-Generator) ersetzen.
            </MudAlert>

            <MudText Typo="Typo.h5" Class="mb-3" Style="font-weight: 600;">
                1. Verantwortlicher
            </MudText>
            <MudText Typo="Typo.body1" Class="mb-6">
                Verantwortlich für die Datenverarbeitung auf dieser Website ist die OrderSphere GmbH,
                Musterstraße 1, 12345 Musterstadt. Kontakt: support@ordersphere.dev
            </MudText>

            <MudText Typo="Typo.h5" Class="mb-3" Style="font-weight: 600;">
                2. Erhebung und Speicherung personenbezogener Daten
            </MudText>
            <MudText Typo="Typo.body1" Class="mb-6">
                Wir erheben personenbezogene Daten ausschließlich, wenn du sie uns aktiv übermittelst,
                z.B. bei der Registrierung, Bestellung oder Kontaktaufnahme. Erhoben werden Name,
                E-Mail-Adresse, Lieferanschrift und Zahlungsdaten zur Abwicklung deiner Bestellung.
            </MudText>

            <MudText Typo="Typo.h5" Class="mb-3" Style="font-weight: 600;">
                3. Zwecke der Datenverarbeitung
            </MudText>
            <MudText Typo="Typo.body1" Class="mb-6">
                Die Verarbeitung erfolgt zur Vertragserfüllung (Art. 6 Abs. 1 lit. b DSGVO),
                zur Erfüllung gesetzlicher Pflichten (lit. c) sowie auf Basis berechtigter Interessen (lit. f),
                etwa zur Verbesserung unseres Angebots.
            </MudText>

            <MudText Typo="Typo.h5" Class="mb-3" Style="font-weight: 600;">
                4. Cookies
            </MudText>
            <MudText Typo="Typo.body1" Class="mb-6">
                Wir verwenden technisch notwendige Cookies, um die Funktion der Website sicherzustellen
                (z.B. Login, Warenkorb). Details findest du in unserer
                <MudLink Href="/cookies">Cookie-Richtlinie</MudLink>.
            </MudText>

            <MudText Typo="Typo.h5" Class="mb-3" Style="font-weight: 600;">
                5. Deine Rechte
            </MudText>
            <MudText Typo="Typo.body1" Class="mb-6">
                Du hast jederzeit das Recht auf Auskunft (Art. 15 DSGVO), Berichtigung (Art. 16),
                Löschung (Art. 17), Einschränkung der Verarbeitung (Art. 18), Datenübertragbarkeit (Art. 20)
                und Widerspruch (Art. 21). Wende dich dazu an support@ordersphere.dev.
            </MudText>

            <MudText Typo="Typo.h5" Class="mb-3" Style="font-weight: 600;">
                6. Speicherdauer
            </MudText>
            <MudText Typo="Typo.body1">
                Wir speichern deine Daten nur so lange, wie es für die genannten Zwecke erforderlich ist
                oder gesetzliche Aufbewahrungspflichten (z.B. nach HGB oder AO) bestehen.
            </MudText>
        </MudPaper>
    </MudContainer>
</section>

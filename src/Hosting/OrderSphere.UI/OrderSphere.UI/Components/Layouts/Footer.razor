<footer>
    <div class="footer-main">
        <MudContainer MaxWidth="MaxWidth.Large">
            <MudGrid>
                <MudItem xs="12" md="4">
                    <MudLink Href="/" Underline="Underline.None" Class="d-flex align-center gap-2">
                        <div class="os-logo-mark">○</div>
                        <MudText Typo="Typo.h6" Class="os-display" Style="font-weight: 600; color: var(--mud-palette-text-primary);">
                            OrderSphere
                        </MudText>
                    </MudLink>
                    <MudText Typo="Typo.body2" Class="mt-3 text-muted" Style="max-width: 280px; line-height: 1.7;">
                        Sorgfältig ausgewählte Tech-Werkzeuge.
                    </MudText>
                </MudItem>

                @foreach (var section in _sections)
                {
                    <MudItem xs="6" md="2">
                        <MudText Typo="Typo.overline" Style="font-weight: 700; color: var(--mud-palette-text-primary);">@section.Title</MudText>
                        <MudStack Spacing="1" Class="mt-3">
                            @foreach (var link in section.Links)
                            {
                                <a href="@link.Href" class="footer-link">@link.Label</a>
                            }
                        </MudStack>
                    </MudItem>
                }
            </MudGrid>
        </MudContainer>
    </div>

    <div class="footer-bottom">
        <MudContainer MaxWidth="MaxWidth.Large">
            <div style="display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 12px;">
                <span class="os-mono" style="font-size: 0.75rem; color: var(--mud-palette-text-secondary);">
                    © @DateTime.Now.Year OrderSphere
                </span>
                <div style="display: flex; gap: 20px;">
                    <a href="/imprint" class="footer-legal-link">Impressum</a>
                    <a href="/privacy" class="footer-legal-link">Datenschutz</a>
                    <a href="/terms" class="footer-legal-link">AGB</a>
                </div>
            </div>
        </MudContainer>
    </div>
</footer>

@code {
    private readonly List<FooterSection> _sections =
    [
        new("Shop", [
            new("Alle Produkte", "/shop"),
            new("Kategorien", "/categories"),
            new("Angebote", "/offers"),
            new("Suche", "/search"),
        ]),
        new("Konto", [
            new("Anmelden", "/account/login"),
            new("Registrieren", "/account/register"),
            new("Bestellungen", "/account/orders"),
            new("Einstellungen", "/account/settings"),
        ]),
        new("Hilfe", [
            new("Kontakt", "/contact"),
            new("FAQ", "/faq"),
            new("Rückgabe", "/returns"),
            new("Versand", "/shipping"),
        ]),
        new("Unternehmen", [
            new("Über uns", "/about"),
            new("Impressum", "/imprint"),
            new("Datenschutz", "/privacy"),
            new("AGB", "/terms"),
        ]),
    ];

    private record FooterLink(string Label, string Href);
    private record FooterSection(string Title, List<FooterLink> Links);
}

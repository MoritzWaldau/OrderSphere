@page "/categories"
@layout MainLayout
@inherits OrderSphereComponentBase
@rendermode InteractiveServer
@using OrderSphere.Application.Features.Category.GetCategories

<PageTitle>Kategorien — OrderSphere</PageTitle>

<PageHero Title="Kategorien"
          Subtitle="Entdecke unser Sortiment nach Themen sortiert." />

<section class="page-section">
    <MudContainer>
        @if (IsLoading)
        {
            <MudStack AlignItems="AlignItems.Center" Class="py-12">
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
            </MudStack>
        }
        else if (_categories.Count == 0)
        {
            <MudPaper Elevation="0" Class="surface-card-lg pa-12 text-center">
                <MudIcon Icon="@Icons.Material.Outlined.Category"
                         Color="Color.Primary"
                         Style="font-size: 80px;" Class="mb-4" />
                <MudText Typo="Typo.h5" Style="font-weight: 600;">
                    Noch keine Kategorien verfügbar
                </MudText>
            </MudPaper>
        }
        else
        {
            <MudGrid Spacing="4">
                @foreach (var category in _categories)
                {
                    <MudItem xs="12" sm="6" md="4">
                        <MudPaper Elevation="0"
                                  Class="category-card pa-6"
                                  Style="height: 100%;"
                                  @onclick="@(() => NavManager.NavigateTo($"/shop/category/{category.Name}"))">
                            <MudStack Spacing="3">
                                <MudIcon Icon="@GetCategoryIcon(category.Name)"
                                         Color="Color.Primary"
                                         Style="font-size: 56px;" />
                                <MudText Typo="Typo.h5" Style="font-weight: 600;">
                                    @category.Name
                                </MudText>
                                @if (!string.IsNullOrWhiteSpace(category.Description))
                                {
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                                        @category.Description
                                    </MudText>
                                }
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mt-2">
                                    <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Filled"
                                             Style="border-radius: 100px;">
                                        @category.ProductCount @(category.ProductCount == 1 ? "Produkt" : "Produkte")
                                    </MudChip>
                                </MudStack>
                            </MudStack>
                        </MudPaper>
                    </MudItem>
                }
            </MudGrid>
        }
    </MudContainer>
</section>

@code {
    private IReadOnlyList<CategoryDto> _categories = Array.Empty<CategoryDto>();

    protected override async Task LoadDataAsync()
    {
        var result = await Sender.Send(new GetCategoriesQuery());

        if (result.IsSuccess)
        {
            _categories = result.Value;
        }
        else
        {
            Snackbar.Add(result.Error.Description, Severity.Error);
        }
    }

    private static string GetCategoryIcon(string name) => name.ToLowerInvariant() switch
    {
        var n when n.Contains("laptop") => Icons.Material.Outlined.Laptop,
        var n when n.Contains("phone") || n.Contains("smartphone") => Icons.Material.Outlined.PhoneIphone,
        var n when n.Contains("tablet") => Icons.Material.Outlined.Tablet,
        var n when n.Contains("zubehör") || n.Contains("accessor") => Icons.Material.Outlined.Headphones,
        var n when n.Contains("audio") => Icons.Material.Outlined.Speaker,
        var n when n.Contains("monitor") || n.Contains("display") => Icons.Material.Outlined.Monitor,
        var n when n.Contains("kamera") || n.Contains("camera") => Icons.Material.Outlined.PhotoCamera,
        _ => Icons.Material.Outlined.Devices
    };
}
